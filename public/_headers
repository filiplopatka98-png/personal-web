# Cloudflare Pages — security + caching headers.
# Astro copies public/_headers → dist/_headers, which CF Pages applies at the edge.
# (GitHub Pages ignores this file, so it's a no-op until the site runs on CF Pages.)
#
# CSP allowlist is derived from the actual build: scripts self + Umami + hCaptcha;
# fetch to Web3Forms + Umami beacon + hCaptcha; inline CSS/JS (Astro inlines styles)
# needs 'unsafe-inline'; self-hosted fonts; hCaptcha challenge iframe via frame-src.
# Keep this in sync with the meta CSP in BaseLayout.astro and public/.htaccess.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cloud.umami.is https://js.hcaptcha.com https://*.hcaptcha.com; style-src 'self' 'unsafe-inline' https://*.hcaptcha.com; img-src 'self' data: https://*.hcaptcha.com; font-src 'self'; connect-src 'self' https://cloud.umami.is https://api.web3forms.com https://*.hcaptcha.com; frame-src https://*.hcaptcha.com https://hcaptcha.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests

# Hashed, immutable build assets + fonts — cache hard (safe: content-hashed names).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
