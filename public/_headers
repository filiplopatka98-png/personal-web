# Cloudflare Pages — security + caching headers.
# Astro copies public/_headers → dist/_headers, which CF Pages applies at the edge.
# (GitHub Pages ignores this file, so it's a no-op until the site runs on CF Pages.)
#
# CSP allowlist is derived from the actual build: scripts self + Umami; fetch to
# Web3Forms + Umami beacon; inline CSS/JS (Astro inlines styles) needs 'unsafe-inline';
# self-hosted fonts; no iframes/embeds. Tighten to hashes/nonces only if the build
# ever stops inlining.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cloud.umami.is; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloud.umami.is https://api.web3forms.com; form-action 'self' https://api.web3forms.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests

# Hashed, immutable build assets + fonts — cache hard (safe: content-hashed names).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
