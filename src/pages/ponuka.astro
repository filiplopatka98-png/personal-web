---
import BaseLayout from '../layouts/BaseLayout.astro';
import BriefWizard from '../components/BriefWizard.astro';
import { t } from '../i18n';

const lang = 'sk';
---
<BaseLayout
  lang={lang}
  canonicalPath="/ponuka/"
  altLangUrl="/en/brief/"
  title={`${t('nav.brief', lang)} — Filip Lopatka`}
  description={t('brief.lead', lang)}
>
  {/* BriefWizard renders its own header (eyebrow + h1 + lead + progress) and
      body (form + nav) sections per handoff layout — no PageHead wrapper. */}
  <BriefWizard lang={lang} />
</BaseLayout>
