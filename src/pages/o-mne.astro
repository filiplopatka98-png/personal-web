---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTAButton from '../components/CTAButton.astro';
import { t } from '../i18n';
import { getStaticRoute } from '../i18n/routes';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const lang = 'sk';
const contactHref = `${baseUrl}${getStaticRoute('contact', lang)}`;
---
<BaseLayout lang={lang} canonicalPath="/o-mne/" altLangUrl="/en/about/" title={`${t('about.title', lang)} — Filip Lopatka`}>
  <article class="py-16 max-w-prose">
    <SectionHeader number="01" eyebrow={t('about.subtitle', lang)} title={t('about.title', lang)} level={1} />

    <p class="text-lg leading-relaxed mb-12">{t('about.intro', lang)}</p>

    <section class="mb-12">
      <h2 class="font-serif font-normal mb-4">{t('about.approach.title', lang)}</h2>
      <p class="text-base leading-relaxed">{t('about.approach.body', lang)}</p>
    </section>

    <section class="mb-12">
      <h2 class="font-serif font-normal mb-4">{t('about.values.title', lang)}</h2>
      <ul class="space-y-3 list-none pl-0">
        <li class="border-l-2 border-accent pl-4 py-1">{t('about.value.craft', lang)}</li>
        <li class="border-l-2 border-accent pl-4 py-1">{t('about.value.speed', lang)}</li>
        <li class="border-l-2 border-accent pl-4 py-1">{t('about.value.ownership', lang)}</li>
        <li class="border-l-2 border-accent pl-4 py-1">{t('about.value.ai', lang)}</li>
      </ul>
    </section>

    <section class="border-t border-border pt-8">
      <h2 class="font-serif font-normal mb-3">{t('about.cta.title', lang)}</h2>
      <p class="mb-6 text-text-muted">{t('about.cta.body', lang)}</p>
      <CTAButton href={contactHref}>{t('about.cta.button', lang)}</CTAButton>
    </section>
  </article>
</BaseLayout>
