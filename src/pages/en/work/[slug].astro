---
import { getCollection, type CollectionEntry } from 'astro:content';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join, resolve } from 'node:path';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Reveal from '../../../components/Reveal.astro';
import Plate from '../../../components/Plate.astro';
import { t } from '../../../i18n';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const projectRoot = resolve(__dirname, '../../../..');

function mockupPath(slug: string, type: 'hero' | 'mobile'): string | null {
  const rel = `/projects/${slug}-${type}.png`;
  const abs = join(projectRoot, 'public', rel);
  return existsSync(abs) ? rel : null;
}

export async function getStaticPaths() {
  const all = await getCollection('projects');
  return all
    .filter((p) => p.slug.startsWith('en/'))
    .map((entry) => ({
      params: { slug: entry.slug.replace(/^en\//, '') },
      props: { entry },
    }));
}

interface Props { entry: CollectionEntry<'projects'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const lang = 'en';
const cleanSlug = entry.slug.replace(/^en\//, '');

const allProjects = (await getCollection('projects'))
  .filter((p) => p.slug.startsWith('en/'))
  .sort((a, b) => a.data.order - b.data.order);
const idx = allProjects.findIndex((p) => p.slug === entry.slug);
const next = allProjects[(idx + 1) % allProjects.length];
const nextSlug = next.slug.replace(/^en\//, '');

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const accentColor = `var(--${data.accent})`;

const heroMockupRel = mockupPath(cleanSlug, 'hero');
const mobileMockupRel = mockupPath(cleanSlug, 'mobile');
const secondaryMockupRel = mockupPath(`${cleanSlug}-screen2`, 'hero');
const heroMockupSrc = heroMockupRel ? `${baseUrl}${heroMockupRel}` : null;
const mobileMockupSrc = mobileMockupRel ? `${baseUrl}${mobileMockupRel}` : null;
const secondaryMockupSrc = secondaryMockupRel ? `${baseUrl}${secondaryMockupRel}` : null;

const projectUrlPath = `${baseUrl}/en/work/${cleanSlug}/`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const fullProjectUrl = `${siteUrl}${projectUrlPath}`;

const projectLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: data.name,
  description: data.brief,
  creator: {
    '@type': 'Person',
    name: 'Filip Lopatka',
    url: `${siteUrl}${baseUrl}/`,
  },
  dateCreated: data.year,
  url: fullProjectUrl,
  about: data.kind,
  inLanguage: 'en-US',
  ...(data.url && { sameAs: [`https://${data.url}`] }),
};
---
<BaseLayout
  lang={lang}
  canonicalPath={`/en/work/${cleanSlug}/`}
  altLangUrl={`/praca/${cleanSlug}/`}
  title={`${data.name} — Filip Lopatka`}
  description={data.brief}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(projectLd)}></script>

  <section class="proj-header">
    <Reveal>
      <a href={`${baseUrl}/en/work/`} class="back-link mono" data-cursor="hover">{t('cta.back', lang)}</a>
    </Reveal>
    <Reveal delay={0.05} class="proj-header-grid">
      <div>
        <div class="proj-eyebrow mono">{t('project.caseStudy', lang)} · {data.year}</div>
        <h1 class="proj-name display">{data.name}</h1>
        <div class="proj-kind mono">{data.kind}</div>
      </div>
      <dl class="proj-meta-grid">
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.client', lang)}</dt>
          <dd>{data.client}</dd>
        </div>
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.role', lang)}</dt>
          <dd>{data.role}</dd>
        </div>
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.duration', lang)}</dt>
          <dd>{data.duration}</dd>
        </div>
        {data.url && (
          <div class="proj-meta-cell">
            <dt class="mono">{t('project.url', lang)}</dt>
            <dd>{data.url}</dd>
          </div>
        )}
      </dl>
    </Reveal>
  </section>

  <section class="proj-hero">
    <Reveal>
      <Plate
        label={`${data.name} · hero`}
        color={accentColor}
        ratio="16/9"
        caption={heroMockupSrc ? (data.heroCaption ?? data.url) : 'screen-01.png'}
        radius={20}
        imageSrc={heroMockupSrc ?? undefined}
        imageAlt={`${data.name} — desktop preview`}
      />
    </Reveal>
  </section>

  {data.metrics.length > 0 && (
    <section class="proj-metrics">
      <div class="metrics-grid">
        {data.metrics.map((m, i) => (
          <Reveal delay={i * 0.08}>
            <div class="metric-value display">{m.value}</div>
            <div class="metric-label mono">{m.label}</div>
          </Reveal>
        ))}
      </div>
    </section>
  )}

  <section class="proj-body">
    <div class="proj-body-grid">
      <Reveal>
        <div class="proj-section-eyebrow mono">{t('project.brief', lang)}</div>
        <div class="proj-brief-title display">{data.brief}</div>
      </Reveal>
      <Reveal delay={0.1} class="proj-body-prose">
        <Content />
      </Reveal>
    </div>
  </section>

  {data.process.length > 0 && (
    <section class="proj-process">
      <Reveal>
        <div class="proj-section-eyebrow mono proj-process-eyebrow">{t('project.process', lang)}</div>
      </Reveal>
      <div class="process-list">
        {data.process.map((p, i) => (
          <Reveal delay={i * 0.05} class="process-row">
            <div class="process-num mono">0{i + 1}</div>
            <div class="process-title display">{p.title}</div>
            <div class="process-duration mono">{p.duration}</div>
            <div class="process-desc">{p.desc}</div>
          </Reveal>
        ))}
      </div>
    </section>
  )}

  <section class:list={['proj-screens', mobileMockupSrc && 'has-mobile-mockup']}>
    <div class="screens-grid">
      <Reveal>
        <Plate
          label="mobile"
          color={accentColor}
          ratio={mobileMockupSrc ? '600/1100' : '4/3'}
          caption={mobileMockupSrc ? (data.mobileCaption ?? 'mobile view') : 'checkout flow'}
          imageSrc={mobileMockupSrc ?? undefined}
          imageAlt={`${data.name} — mobile preview`}
        />
      </Reveal>
      <Reveal delay={0.08}>
        <Plate
          label={secondaryMockupSrc ? `${data.name} · secondary view` : 'screen-03'}
          color={secondaryMockupSrc ? accentColor : 'var(--accent)'}
          ratio={secondaryMockupSrc ? '16/9' : '4/3'}
          caption={secondaryMockupSrc ? (data.secondaryCaption ?? '—') : 'product detail'}
          imageSrc={secondaryMockupSrc ?? undefined}
          imageAlt={`${data.name} — secondary preview`}
        />
      </Reveal>
    </div>
  </section>

  <section class="proj-stack-live">
    <div class="stack-block">
      <div class="stack-eyebrow mono">{t('project.stack', lang).toUpperCase()}</div>
      <div class="stack-list mono">
        {data.stack.map((s, i) => (
          <Fragment>
            <span>{s}</span>
            {i < data.stack.length - 1 && <span class="stack-sep" aria-hidden="true">·</span>}
          </Fragment>
        ))}
      </div>
    </div>
    {data.url && (
      <a href={`https://${data.url}`} target="_blank" rel="noopener noreferrer" class="live-link mono" data-cursor="hover">
        {t('cta.liveSite', lang)} {data.url} →
      </a>
    )}
  </section>

  <section class="proj-next">
    <Reveal>
      <div class="next-eyebrow mono">{t('project.next', lang).toUpperCase()}</div>
      <a href={`${baseUrl}/en/work/${nextSlug}/`} class="next-link" data-cursor="hover">
        <div class="next-name display">{next.data.name} <span class="next-arrow">→</span></div>
        <div class="next-kind mono">{next.data.kind}</div>
      </a>
    </Reveal>
  </section>
</BaseLayout>

<style>
  .proj-header {
    padding: 120px 32px 32px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .back-link {
    font-size: 13px;
    color: var(--ink-soft);
    font-family: var(--font-mono);
    text-decoration: none;
  }
  .back-link::before { content: '← '; }
  :global(.proj-header-grid) {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: end;
  }
  .proj-eyebrow {
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 14px;
    font-family: var(--font-mono);
  }
  .proj-name {
    font-size: 96px;
    line-height: 0.92;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .proj-kind {
    font-size: 14px;
    margin-top: 16px;
    color: var(--ink-soft);
    font-family: var(--font-mono);
  }
  .proj-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 13px;
    margin: 0;
  }
  .proj-meta-cell {
    border-top: 1px solid var(--divider);
    padding-top: 10px;
  }
  .proj-meta-cell dt {
    color: var(--ink-soft);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .proj-meta-cell dd {
    margin: 4px 0 0;
    color: var(--ink);
  }

  .proj-hero {
    padding: 16px 32px 32px;
    max-width: 1320px;
    margin: 0 auto;
  }

  .proj-metrics {
    padding: 40px 32px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  :global(.metrics-grid > *) {
    background: var(--glass-fill);
    backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    -webkit-backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    padding: 28px;
    box-shadow:
      0 30px 60px -24px var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight);
  }
  .metric-value {
    font-size: 80px;
    line-height: 0.9;
    color: var(--accent);
    font-family: var(--font-display);
  }
  .metric-label {
    font-size: 12px;
    color: var(--ink-soft);
    margin-top: 12px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .proj-body {
    padding: 64px 32px;
    max-width: 1320px;
    margin: 0 auto;
  }
  :global(.proj-body-grid) {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 56px;
  }
  .proj-section-eyebrow {
    font-size: 11px;
    color: var(--ink-soft);
    margin-bottom: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .proj-brief-title {
    font-size: 32px;
    line-height: 1.2;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  :global(.proj-body-prose) {
    font-size: 18px;
    line-height: 1.65;
    color: var(--ink);
  }
  :global(.proj-body-prose p) {
    margin: 0;
  }
  :global(.proj-body-prose p + p) {
    margin-top: 20px;
  }

  .proj-process {
    padding: 56px 32px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .proj-process-eyebrow {
    font-size: 13px;
    margin-bottom: 24px;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink-soft);
  }
  .process-list {
    background: var(--glass-fill);
    backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    -webkit-backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: 28px;
    padding: 12px 32px;
    box-shadow:
      0 30px 60px -24px var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight);
  }
  :global(.process-row) {
    display: grid !important;
    grid-template-columns: 60px 1fr 200px 2fr;
    gap: 32px;
    padding: 20px 0;
    border-top: 1px solid var(--divider);
  }
  :global(.process-list > .process-row:first-child) {
    border-top: 0;
  }
  .process-num {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
  }
  .process-title {
    font-size: 24px;
    font-family: var(--font-display);
    line-height: 1.1;
    color: var(--ink);
  }
  .process-duration {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
  }
  .process-desc {
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .proj-screens {
    padding: 56px 32px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .screens-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }
  .proj-screens.has-mobile-mockup .screens-grid {
    grid-template-columns: 1fr 2.385fr;
    gap: 32px;
    align-items: center;
  }

  .proj-stack-live {
    padding: 32px;
    max-width: 1320px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
    background: var(--glass-fill);
    backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    -webkit-backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: 28px;
    box-shadow:
      0 30px 60px -24px var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight);
    color: var(--ink);
  }
  .stack-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    margin-bottom: 8px;
    letter-spacing: 0.06em;
  }
  .stack-list {
    font-family: var(--font-mono);
    font-size: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 16px;
  }
  .stack-sep {
    color: var(--ink-soft);
    margin-left: 16px;
  }
  .live-link {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 14px;
    text-decoration: none;
  }
  .live-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .proj-next {
    padding: 80px 32px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .next-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 16px;
  }
  .next-link {
    display: block;
    text-decoration: none;
    color: var(--ink);
  }
  .next-name {
    font-family: var(--font-display);
    font-size: 96px;
    line-height: 0.95;
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .next-arrow {
    color: var(--accent);
  }
  .next-kind {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 12px;
  }

  @media (max-width: 1024px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 24px;
      padding-right: 24px;
    }
    .proj-header { padding-top: 100px; }
    .proj-hero { padding: 12px 24px 24px; }
    .proj-metrics { padding: 32px 24px; }
    .proj-stack-live { padding: 24px; }
    .proj-name { font-size: 72px; }
    .proj-brief-title { font-size: 28px; }
    .next-name { font-size: 72px; }
    .metric-value { font-size: 64px; }
    :global(.process-row) {
      grid-template-columns: 40px 1fr 140px 2fr;
      gap: 20px;
    }
    :global(.proj-body-grid) { gap: 32px; }
  }

  @media (max-width: 768px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 16px;
      padding-right: 16px;
    }
    .proj-header { padding-top: 100px; }
    .proj-hero { padding: 8px 16px 16px; }
    .proj-metrics { padding: 24px 16px; }
    .proj-stack-live { padding: 24px 20px; }

    :global(.proj-header-grid) {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    :global(.proj-body-grid) {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .proj-name { font-size: 56px; }
    .proj-brief-title { font-size: 24px; }
    .next-name { font-size: 48px; }

    .metrics-grid { grid-template-columns: 1fr; gap: 12px; }
    .metric-value { font-size: 56px; }

    .screens-grid,
    .proj-screens.has-mobile-mockup .screens-grid {
      grid-template-columns: 1fr;
    }
    .proj-meta-grid { grid-template-columns: 1fr 1fr; }

    :global(.process-row) {
      grid-template-columns: 1fr !important;
      gap: 4px;
      padding: 18px 0;
    }
    .process-num {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .process-duration {
      order: -1;
      margin-bottom: 4px;
    }

    .proj-stack-live {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 12px;
      padding-right: 12px;
    }
    .proj-hero { padding: 8px 12px 12px; }
    .proj-metrics { padding: 24px 12px; }
    .proj-stack-live { padding: 20px 16px; }
    .proj-name { font-size: 44px; }
    .proj-brief-title { font-size: 22px; }
    .next-name { font-size: 36px; }
    .proj-meta-grid { grid-template-columns: 1fr; }
    .metric-value { font-size: 48px; }
  }
</style>
