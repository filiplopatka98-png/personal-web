---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Reveal from '../../../components/Reveal.astro';
import Plate from '../../../components/Plate.astro';
import { t } from '../../../i18n';

// Optimized project mockups, resolved from src/assets at build time.
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/projects/*.png',
  { eager: true },
);
function mockupImage(name: string): ImageMetadata | null {
  return projectImages[`/src/assets/projects/${name}.png`]?.default ?? null;
}

export async function getStaticPaths() {
  const all = await getCollection('projects');
  return all
    .filter((p) => p.slug.startsWith('en/'))
    .map((entry) => ({
      params: { slug: entry.slug.replace(/^en\//, '') },
      props: { entry },
    }));
}

interface Props { entry: CollectionEntry<'projects'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const lang = 'en';
const cleanSlug = entry.slug.replace(/^en\//, '');

const allProjects = (await getCollection('projects'))
  .filter((p) => p.slug.startsWith('en/'))
  .sort((a, b) => a.data.order - b.data.order);
const idx = allProjects.findIndex((p) => p.slug === entry.slug);
const next = allProjects[(idx + 1) % allProjects.length];
const nextSlug = next.slug.replace(/^en\//, '');

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const accentColor = `var(--${data.accent})`;

const heroImage = mockupImage(`${cleanSlug}-hero`);
const mobileImage = mockupImage(`${cleanSlug}-mobile`);
const secondaryImage = mockupImage(`${cleanSlug}-screen2-hero`);

const projectUrlPath = `${baseUrl}/en/work/${cleanSlug}/`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const fullProjectUrl = `${siteUrl}${projectUrlPath}`;

const projectLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: data.name,
  description: data.brief,
  creator: {
    '@type': 'Person',
    name: 'Filip Lopatka',
    url: `${siteUrl}${baseUrl}/`,
  },
  dateCreated: data.year,
  url: fullProjectUrl,
  about: data.kind,
  inLanguage: 'en-US',
  ...(data.url && { sameAs: [`https://${data.url}`] }),
};
---
<BaseLayout
  lang={lang}
  canonicalPath={`/en/work/${cleanSlug}/`}
  altLangUrl={`/praca/${cleanSlug}/`}
  title={`${data.name} — case study | Filip Lopatka`}
  description={data.brief}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(projectLd)}></script>

  <section class="proj-header">
    <Reveal>
      <a href={`${baseUrl}/en/work/`} class="back-link mono" data-cursor="hover">{t('cta.back', lang)}</a>
    </Reveal>
    <Reveal delay={0.05} class="proj-header-grid">
      <div>
        <div class="proj-eyebrow mono">{t('project.caseStudy', lang)} · {data.year}</div>
        <h1 class="proj-name display">{data.name}</h1>
        <div class="proj-kind mono">{data.kind}</div>
      </div>
      <dl class="proj-meta-grid">
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.client', lang)}</dt>
          <dd>{data.client}</dd>
        </div>
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.role', lang)}</dt>
          <dd>{data.role}</dd>
        </div>
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.duration', lang)}</dt>
          <dd>{data.duration}</dd>
        </div>
        {data.url && (
          <div class="proj-meta-cell">
            <dt class="mono">{t('project.url', lang)}</dt>
            <dd>{data.url}</dd>
          </div>
        )}
      </dl>
    </Reveal>
  </section>

  <section class="proj-hero">
    <Reveal>
      <Plate
        label={`${data.name} · hero`}
        color={accentColor}
        ratio="16/9"
        caption={heroImage ? (data.heroCaption ?? data.url) : 'screen-01.png'}
        radius={20}
        image={heroImage ?? undefined}
        imageAlt={`${data.name} — desktop preview`}
        sizes="(max-width: 1024px) 100vw, 1100px"
      />
    </Reveal>
  </section>

  {data.metrics.length > 0 && (
    <section class="proj-metrics">
      <div class="metrics-grid">
        {data.metrics.map((m, i) => (
          <Reveal delay={i * 0.08}>
            <div class="metric-value display">{m.value}</div>
            <div class="metric-label mono">{m.label}</div>
          </Reveal>
        ))}
      </div>
    </section>
  )}

  <section class="proj-body">
    <div class="proj-body-grid">
      <Reveal>
        <div class="proj-section-eyebrow mono">{t('project.brief', lang)}</div>
        <div class="proj-brief-title display">{data.brief}</div>
      </Reveal>
      <Reveal delay={0.1} class="proj-body-prose">
        <Content />
      </Reveal>
    </div>
  </section>

  {data.process.length > 0 && (
    <section class="proj-process">
      <Reveal>
        <div class="proj-section-eyebrow mono proj-process-eyebrow">{t('project.process', lang)}</div>
      </Reveal>
      <div class="process-list">
        {data.process.map((p, i) => (
          <Reveal delay={i * 0.05} class="process-row">
            <div class="process-num mono">0{i + 1}</div>
            <div class="process-title display">{p.title}</div>
            <div class="process-duration mono">{p.duration}</div>
            <div class="process-desc">{p.desc}</div>
          </Reveal>
        ))}
      </div>
    </section>
  )}

  <section class:list={['proj-screens', mobileImage && 'has-mobile-mockup']}>
    <div class="screens-grid">
      <Reveal>
        <Plate
          label="mobile"
          color={accentColor}
          ratio={mobileImage ? '600/1100' : '4/3'}
          caption={mobileImage ? (data.mobileCaption ?? 'mobile view') : 'checkout flow'}
          image={mobileImage ?? undefined}
          imageAlt={`${data.name} — mobile preview`}
          sizes="(max-width: 768px) 100vw, 420px"
        />
      </Reveal>
      <Reveal delay={0.08}>
        <Plate
          label={secondaryImage ? `${data.name} · secondary view` : 'screen-03'}
          color={secondaryImage ? accentColor : 'var(--accent2)'}
          ratio={secondaryImage ? '16/9' : '4/3'}
          caption={secondaryImage ? (data.secondaryCaption ?? '—') : 'product detail'}
          image={secondaryImage ?? undefined}
          imageAlt={`${data.name} — secondary preview`}
          sizes="(max-width: 768px) 100vw, 640px"
        />
      </Reveal>
    </div>
  </section>

  <section class="proj-stack-live">
    <div class="stack-block">
      <div class="stack-eyebrow mono">{t('project.stack', lang).toUpperCase()}</div>
      <div class="stack-list mono">
        {data.stack.map((s, i) => (
          <Fragment>
            <span>{s}</span>
            {i < data.stack.length - 1 && <span class="stack-sep" aria-hidden="true">·</span>}
          </Fragment>
        ))}
      </div>
    </div>
    {data.url && (
      <a href={`https://${data.url}`} target="_blank" rel="nofollow noopener noreferrer" class="live-link mono" data-cursor="hover">
        {t('cta.liveSite', lang)} {data.url} →
      </a>
    )}
  </section>

  <section class="proj-next">
    <Reveal>
      <div class="next-eyebrow mono">{t('project.next', lang).toUpperCase()}</div>
      <a href={`${baseUrl}/en/work/${nextSlug}/`} class="next-link" data-cursor="hover">
        <div class="next-name display">{next.data.name} <span class="next-arrow">→</span></div>
        <div class="next-kind mono">{next.data.kind}</div>
      </a>
    </Reveal>
  </section>
</BaseLayout>

<style>
  .proj-header { padding: 60px 56px 40px; }
  .back-link {
    font-size: 13px;
    color: var(--ink);
    opacity: 0.78;
    font-family: var(--font-mono);
    text-decoration: none;
  }
  .back-link::before { content: '← '; }
  :global(.proj-header-grid) {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: end;
  }
  .proj-eyebrow {
    font-size: 13px;
    opacity: 0.78;
    margin-bottom: 14px;
    font-family: var(--font-mono);
  }
  .proj-name {
    font-size: 96px;
    line-height: 0.92;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .proj-kind {
    font-size: 14px;
    margin-top: 16px;
    opacity: 0.7;
    font-family: var(--font-mono);
  }
  .proj-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 13px;
    margin: 0;
  }
  .proj-meta-cell {
    border-top: 1px solid color-mix(in srgb, var(--ink) 13%, transparent);
    padding-top: 10px;
  }
  .proj-meta-cell dt {
    opacity: 0.78;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .proj-meta-cell dd { margin: 4px 0 0; }

  .proj-hero { padding: 0 56px 32px; }

  .proj-metrics {
    padding: 40px 56px;
    background: var(--bg2);
    border-top: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .metric-value {
    font-size: 80px;
    line-height: 0.9;
    color: var(--accent);
    font-family: var(--font-display);
  }
  .metric-label {
    font-size: 12px;
    opacity: 0.78;
    margin-top: 12px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .proj-body { padding: 80px 56px; }
  :global(.proj-body-grid) {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 64px;
  }
  .proj-section-eyebrow {
    font-size: 12px;
    opacity: 0.78;
    margin-bottom: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .proj-brief-title {
    font-size: 32px;
    line-height: 1.2;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  :global(.proj-body-prose) {
    font-size: 18px;
    line-height: 1.65;
  }
  :global(.proj-body-prose p) { margin: 0; }
  :global(.proj-body-prose p + p) { margin-top: 20px; }

  .proj-process {
    padding: 60px 56px;
    background: var(--bg2);
  }
  .proj-process-eyebrow {
    font-size: 13px;
    margin-bottom: 32px;
    text-transform: none;
    letter-spacing: 0;
  }
  .process-list { display: flex; flex-direction: column; }
  :global(.process-row) {
    display: grid !important;
    grid-template-columns: 60px 1fr 200px 2fr;
    gap: 32px;
    padding: 24px 0;
    border-top: 1px solid color-mix(in srgb, var(--ink) 13%, transparent);
  }
  .process-num {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.78;
  }
  .process-title {
    font-size: 24px;
    font-family: var(--font-display);
    line-height: 1.1;
  }
  .process-duration {
    font-family: var(--font-mono);
    font-size: 12px;
    opacity: 0.78;
  }
  .process-desc {
    font-size: 15px;
    line-height: 1.5;
    opacity: 0.8;
  }

  .proj-screens { padding: 60px 56px; }
  .screens-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }
  /* Phone canvas 760/1250 = 0.608 vs laptop canvas 1740/1200 ≈ 1.45.
     col2/col1 = 1.45 / 0.608 ≈ 2.385 → equal visual height. */
  .proj-screens.has-mobile-mockup .screens-grid {
    grid-template-columns: 1fr 2.385fr;
    gap: 32px;
    align-items: center;
  }

  .proj-stack-live {
    padding: 40px 56px;
    background: var(--ink);
    color: var(--bg);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }
  .stack-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    opacity: 0.78;
    margin-bottom: 8px;
    letter-spacing: 0.06em;
  }
  .stack-list {
    font-family: var(--font-mono);
    font-size: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 16px;
  }
  .stack-sep { opacity: 0.5; margin-left: 16px; }
  .live-link {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 14px;
    text-decoration: none;
  }
  .live-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .proj-next {
    padding: 80px 56px;
    border-top: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .next-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.78;
    margin-bottom: 16px;
  }
  .next-link {
    display: block;
    text-decoration: none;
    color: var(--ink);
  }
  .next-name {
    font-family: var(--font-display);
    font-size: 96px;
    line-height: 0.95;
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .next-arrow { color: var(--accent); }
  .next-kind {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.78;
    margin-top: 12px;
  }

  @media (max-width: 1024px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 32px;
      padding-right: 32px;
    }
    .proj-hero { padding: 0 32px 24px; }
    .proj-metrics { padding: 32px; }
    .proj-stack-live { padding: 32px; }
    .proj-name { font-size: 72px; }
    .proj-brief-title { font-size: 28px; }
    .next-name { font-size: 72px; }
    .metric-value { font-size: 64px; }
    :global(.process-row) {
      grid-template-columns: 40px 1fr 140px 2fr;
      gap: 20px;
    }
    :global(.proj-body-grid) { gap: 36px; }
  }

  @media (max-width: 768px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 20px;
      padding-right: 20px;
    }
    .proj-hero { padding: 0 20px 20px; }
    .proj-metrics { padding: 32px 20px; }
    .proj-stack-live { padding: 32px 20px; }

    :global(.proj-header-grid) { grid-template-columns: 1fr; gap: 32px; }
    :global(.proj-body-grid) { grid-template-columns: 1fr; gap: 32px; }

    .proj-name { font-size: 56px; }
    .proj-brief-title { font-size: 26px; }
    .next-name { font-size: 48px; }

    .metrics-grid { grid-template-columns: 1fr; gap: 24px; }
    .metric-value { font-size: 56px; }

    .screens-grid,
    .proj-screens.has-mobile-mockup .screens-grid {
      grid-template-columns: 1fr;
    }
    .proj-meta-grid { grid-template-columns: 1fr 1fr; }

    :global(.process-row) {
      grid-template-columns: 1fr !important;
      gap: 4px;
      padding: 18px 0;
    }
    .process-num {
      font-size: 12px;
      opacity: 0.78;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .process-duration { order: -1; margin-bottom: 4px; }

    .proj-stack-live { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 480px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 16px;
      padding-right: 16px;
    }
    .proj-name { font-size: 44px; }
    .proj-brief-title { font-size: 22px; }
    .next-name { font-size: 36px; }
    .proj-meta-grid { grid-template-columns: 1fr; }
    .metric-value { font-size: 48px; }
  }
</style>
