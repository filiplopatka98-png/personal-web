---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n';
import Badge from '../../components/Badge.astro';
import CTAButton from '../../components/CTAButton.astro';
import MarkHighlight from '../../components/MarkHighlight.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout lang="en" canonicalPath="/en/" altLangUrl="/">
  <section class="py-24">
    <Badge>FREELANCE</Badge>
    <h1 class="font-serif font-normal mt-4 mb-6">
      Builds websites that
      <MarkHighlight>bring clients</MarkHighlight>.
    </h1>
    <CTAButton href={`${baseUrl}/en/projects/`}>View projects</CTAButton>
  </section>
</BaseLayout>
