---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHead from '../../../components/PageHead.astro';
import Reveal from '../../../components/Reveal.astro';
import { t } from '../../../i18n';

const lang = 'en';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const articles = (await getCollection('articles'))
  .filter((a) => a.slug.startsWith('en/'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const titleHtml = `${t('blog.title.before', lang)}<em>${t('blog.title.em', lang)}</em>${t('blog.title.after', lang)}`;

const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
---
<BaseLayout lang={lang} canonicalPath="/en/blog/" altLangUrl="/blog/" title={`${t('nav.blog', lang)} — Filip Lopatka`}>
  <PageHead
    eyebrow={t('blog.eyebrow', lang)}
    titleHtml={titleHtml}
    lead={t('blog.lead', lang)}
  />

  <section class="blog-section">
    {articles.length === 0 && (
      <div class="blog-empty">
        <p class="blog-empty-msg">{t('blog.empty', lang)}</p>
        <a href={`${baseUrl}/`} class="blog-empty-link mono" data-cursor="hover">{t('cta.back', lang)} →</a>
      </div>
    )}
    <div class="blog-list">
      {articles.map((a, i) => {
        const cleanSlug = a.slug.replace(/^en\//, '');
        const dateStr = fmt.format(a.data.date);
        return (
          <Reveal delay={i * 0.06}>
            <a
              href={`${baseUrl}/en/blog/${cleanSlug}/`}
              class="blog-row"
              data-cursor="hover"
            >
              <div class="blog-row-date mono">{dateStr}</div>
              <div class="blog-row-main">
                <h2 class="blog-row-title display">{a.data.title}</h2>
                <p class="blog-row-excerpt">{a.data.excerpt}</p>
                {a.data.tags.length > 0 && (
                  <div class="blog-row-tags">
                    {a.data.tags.map((tag) => (
                      <span class="blog-row-tag mono">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="blog-row-aside">
                <div class="blog-row-read mono">{a.data.read} min read</div>
                <div class="blog-row-cta mono">{t('cta.read', lang)} →</div>
              </div>
            </a>
          </Reveal>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-section {
    padding: 48px 32px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .blog-empty {
    text-align: center;
    padding: 80px 0;
    max-width: 480px;
    margin: 0 auto;
  }
  .blog-empty-msg {
    font-family: var(--font-display);
    font-size: 24px;
    font-style: italic;
    line-height: 1.4;
    color: var(--ink-soft);
    margin: 0 0 24px;
  }
  .blog-empty-link {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
  }

  .blog-row {
    display: grid !important;
    grid-template-columns: 160px 1fr 200px;
    gap: 32px;
    padding: 28px 32px;
    border-radius: 24px;
    background: var(--glass-fill);
    backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    -webkit-backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    border: 1px solid var(--glass-border);
    box-shadow:
      0 30px 60px -24px var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight);
    color: var(--ink);
    text-decoration: none;
    align-items: baseline;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .blog-row:hover {
    transform: translateY(-4px);
  }

  .blog-row-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
  }

  .blog-row-title {
    font-family: var(--font-display);
    font-size: 42px;
    line-height: 1.05;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .blog-row-excerpt {
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 12px 0 0;
    max-width: 600px;
  }
  .blog-row-tags {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .blog-row-tag {
    border: 1px solid var(--glass-border);
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--ink-soft);
  }

  .blog-row-aside {
    text-align: right;
  }
  .blog-row-read {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
  }
  .blog-row-cta {
    margin-top: 12px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 13px;
  }

  @media (max-width: 1024px) {
    .blog-section { padding: 40px 24px; }
    .blog-row {
      grid-template-columns: 110px 1fr 140px;
      gap: 24px;
      padding: 24px 28px;
    }
    .blog-row-title { font-size: 32px; }
    .blog-row-excerpt { font-size: 15px; }
  }

  @media (max-width: 768px) {
    .blog-section { padding: 32px 16px; }
    .blog-row {
      grid-template-columns: 1fr !important;
      gap: 8px;
      padding: 24px;
      border-radius: 20px;
      align-items: stretch;
    }
    .blog-row-date {
      order: -1;
    }
    .blog-row-title { font-size: 26px; }
    .blog-row-aside {
      text-align: left;
      display: flex;
      gap: 16px;
      align-items: baseline;
      margin-top: 8px;
      order: 99;
    }
  }

  @media (max-width: 480px) {
    .blog-section { padding: 24px 12px; }
    .blog-row-title { font-size: 22px; }
  }
</style>
