---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Reveal from '../../../components/Reveal.astro';
import Blob from '../../../components/Blob.astro';
import { t } from '../../../i18n';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  return all
    .filter((a) => a.slug.startsWith('en/'))
    .map((entry) => ({
      params: { slug: entry.slug.replace(/^en\//, '') },
      props: { entry },
    }));
}

interface Props { entry: CollectionEntry<'articles'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const lang = 'en';
const cleanSlug = entry.slug.replace(/^en\//, '');

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const fmt = new Intl.DateTimeFormat('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const dateStr = fmt.format(data.date);
---
<BaseLayout
  lang={lang}
  canonicalPath={`/en/blog/${cleanSlug}/`}
  altLangUrl={`/blog/${cleanSlug}/`}
  title={`${data.title} — Filip Lopatka`}
  description={data.excerpt}
>
  <article class="article-page">
    <!-- Back link -->
    <div class="article-nav">
      <Reveal>
        <a href={`${baseUrl}/en/blog/`} class="back-link mono" data-cursor="hover">← {t('article.backToBlog', lang)}</a>
      </Reveal>
    </div>

    <!-- Header -->
    <header class="article-header">
      <Blob color="var(--accent3)" size={280} position="top: -40px; right: 80px; opacity: 0.3;" />
      <Reveal>
        <div class="article-meta-top mono">
          <time datetime={data.date.toISOString()}>{dateStr}</time>
          <span class="dot">·</span>
          <span>{data.read} {t('article.read', lang)}</span>
        </div>
        <h1 class="article-title display">{data.title}</h1>
        <p class="article-excerpt">{data.excerpt}</p>
        {data.tags.length > 0 && (
          <div class="article-tags">
            {data.tags.map((tag) => (
              <span class="article-tag mono">#{tag}</span>
            ))}
          </div>
        )}
      </Reveal>
    </header>

    <!-- Body prose -->
    <div class="article-body">
      <Reveal>
        <div class="article-prose">
          <Content />
        </div>
      </Reveal>
    </div>

    <!-- Author block -->
    <section class="article-author">
      <Reveal>
        <div class="author-row">
          <div class="author-avatar">fl</div>
          <div>
            <div class="author-eyebrow mono">{t('article.about', lang)}</div>
            <p class="author-text">{t('article.aboutText', lang)}</p>
          </div>
        </div>
      </Reveal>
    </section>

    <!-- Back to blog -->
    <div class="article-back">
      <Reveal>
        <a href={`${baseUrl}/en/blog/`} class="back-cta-link" data-cursor="hover">
          <span class="back-arrow">←</span>
          <span>{t('article.backToBlog', lang)}</span>
        </a>
      </Reveal>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 60px 56px 80px;
  }

  .article-nav {
    margin-bottom: 32px;
  }

  .back-link {
    font-size: 13px;
    color: var(--ink);
    opacity: 0.6;
    font-family: var(--font-mono);
    text-decoration: none;
  }

  .article-header {
    position: relative;
    padding: 40px 0 60px;
    border-bottom: var(--border-soft);
    margin-bottom: 40px;
    overflow: hidden;
  }

  .article-meta-top {
    font-family: var(--font-mono);
    font-size: 12px;
    opacity: 0.6;
    margin-bottom: 24px;
    display: flex;
    gap: 8px;
    align-items: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    position: relative;
    z-index: 2;
  }
  .article-meta-top .dot { opacity: 0.4; }

  .article-title {
    font-size: 56px;
    line-height: 1.05;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    position: relative;
    z-index: 2;
  }

  .article-excerpt {
    font-size: 22px;
    line-height: 1.5;
    margin: 24px 0 0;
    opacity: 0.85;
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-style: italic;
  }

  .article-tags {
    margin-top: 32px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }

  .article-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    background: color-mix(in srgb, var(--ink) 8%, transparent);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    text-transform: lowercase;
  }

  .article-body {
    margin-bottom: 60px;
  }

  .article-prose {
    font-size: 19px;
    line-height: 1.7;
  }

  .article-prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 36px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 56px 0 16px;
  }

  .article-prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.2;
    margin: 36px 0 12px;
  }

  .article-prose :global(p) {
    margin: 0 0 24px;
    opacity: 0.9;
  }

  .article-prose :global(p:first-child::first-letter) {
    font-family: var(--font-display);
    font-size: 4em;
    font-weight: 400;
    float: left;
    line-height: 0.85;
    padding: 0.1em 0.1em 0 0;
    color: var(--accent);
  }

  .article-prose :global(strong) {
    font-weight: 600;
  }

  .article-prose :global(em) {
    font-style: italic;
  }

  .article-prose :global(code) {
    background: color-mix(in srgb, var(--ink) 8%, transparent);
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .article-prose :global(pre) {
    background: var(--bg2);
    padding: 20px;
    border-radius: var(--radius-card);
    overflow-x: auto;
    margin: 28px 0;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.5;
  }

  .article-prose :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: inherit;
  }

  .article-prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 24px;
    margin: 32px 0;
    font-style: italic;
    opacity: 0.85;
  }

  .article-prose :global(ul), .article-prose :global(ol) {
    margin: 0 0 24px;
    padding-left: 24px;
  }

  .article-prose :global(li) {
    margin: 8px 0;
    opacity: 0.9;
  }

  .article-prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .article-author {
    border-top: var(--border-soft);
    border-bottom: var(--border-soft);
    padding: 40px 0;
    margin-bottom: 40px;
  }

  .author-row {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 24px;
    align-items: start;
  }

  .author-avatar {
    width: 64px;
    height: 64px;
    background: var(--ink);
    border-radius: 16px;
    display: grid;
    place-items: center;
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 600;
  }

  .author-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.6;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .author-text {
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    opacity: 0.85;
  }

  .article-back {
    text-align: center;
  }

  .back-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 14px 24px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 13px;
    transition: all 0.2s;
  }

  .back-cta-link:hover {
    background: var(--ink);
    color: var(--bg);
  }

  @media (max-width: 768px) {
    .article-page {
      padding: 40px 20px 60px;
      max-width: 100%;
    }
    .article-title {
      font-size: 36px;
    }
    .article-excerpt {
      font-size: 18px;
    }
    .article-prose {
      font-size: 17px;
    }
    .article-prose :global(h2) {
      font-size: 28px;
    }
    .author-row {
      grid-template-columns: 48px 1fr;
      gap: 16px;
    }
    .author-avatar {
      width: 48px;
      height: 48px;
      font-size: 16px;
    }
  }
</style>
