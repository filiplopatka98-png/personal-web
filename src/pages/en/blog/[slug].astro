---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Reveal from '../../../components/Reveal.astro';
import { t } from '../../../i18n';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  return all
    .filter((a) => a.slug.startsWith('en/'))
    .map((entry) => ({
      params: { slug: entry.slug.replace(/^en\//, '') },
      props: { entry },
    }));
}

interface Props { entry: CollectionEntry<'articles'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const lang = 'en';
const cleanSlug = entry.slug.replace(/^en\//, '');
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const allArticles = (await getCollection('articles'))
  .filter((a) => a.slug.startsWith('en/'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx = allArticles.findIndex((a) => a.slug === entry.slug);
const next = allArticles[(idx + 1) % allArticles.length];
const nextSlug = next.slug.replace(/^en\//, '');

const fmt = new Intl.DateTimeFormat('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const dateStr = fmt.format(data.date);
const monthYearFmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
const dateShort = monthYearFmt.format(data.date);

const articleUrlPath = `${baseUrl}/en/blog/${cleanSlug}/`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const fullArticleUrl = `${siteUrl}${articleUrlPath}`;

const shareTitle = encodeURIComponent(data.title);
const shareUrl = encodeURIComponent(fullArticleUrl);
const xShareUrl = `https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  datePublished: data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Filip Lopatka',
    url: `${siteUrl}${baseUrl}/`,
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': fullArticleUrl },
  description: data.excerpt,
  inLanguage: 'en-US',
  keywords: data.tags.join(', '),
  wordCount: entry.body.split(/\s+/).length,
  timeRequired: `PT${data.read}M`,
};
---
<BaseLayout
  lang={lang}
  canonicalPath={`/en/blog/${cleanSlug}/`}
  altLangUrl={`/blog/${cleanSlug}/`}
  title={`${data.title} — Filip Lopatka`}
  description={data.excerpt}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(articleLd)}></script>

  <section class="article-header">
    <Reveal>
      <a href={`${baseUrl}/en/blog/`} class="back-link mono" data-cursor="hover">{t('article.backToBlog', lang)}</a>
    </Reveal>
    <Reveal delay={0.05} class="article-header-content">
      <div class="article-meta-row mono">
        <time datetime={data.date.toISOString()}>{dateStr}</time>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span>{data.read} {t('article.read', lang)}</span>
        {data.tags.map((tag) => (
          <span class="article-tag-inline">#{tag.toLowerCase().replace(/\s+/g, '')}</span>
        ))}
      </div>
      <h1 class="article-title display">{data.title}</h1>
      <p class="article-excerpt">{data.excerpt}</p>
    </Reveal>
  </section>

  <section class="article-body">
    <Reveal class="article-prose">
      <Content />
    </Reveal>

    <div class="article-share">
      <div class="share-author mono">— Filip Lopatka, {dateShort}</div>
      <div class="share-links mono">
        <a href={xShareUrl} target="_blank" rel="noopener noreferrer" data-cursor="hover">X →</a>
        <a href={linkedinShareUrl} target="_blank" rel="noopener noreferrer" data-cursor="hover">LinkedIn →</a>
        <button
          type="button"
          class="share-copy-btn mono"
          data-share-copy
          data-share-url={fullArticleUrl}
          data-share-copied-label={t('article.shareCopied', lang)}
          data-cursor="hover"
        >
          <span data-share-copy-label>{t('article.shareCopy', lang)}</span>
        </button>
      </div>
    </div>
  </section>

  <section class="article-next">
    <Reveal>
      <div class="next-eyebrow mono">{t('article.next', lang).toUpperCase()}</div>
      <a href={`${baseUrl}/en/blog/${nextSlug}/`} class="next-link" data-cursor="hover">
        <h2 class="next-title display">
          {next.data.title} <span class="next-arrow">→</span>
        </h2>
      </a>
    </Reveal>
  </section>
</BaseLayout>

<script>
  function initArticleShare() {
    document.querySelectorAll<HTMLButtonElement>('[data-share-copy]').forEach((btn) => {
      if ((btn as any).__shareInit) return;
      (btn as any).__shareInit = true;
      btn.addEventListener('click', async () => {
        const url = btn.dataset.shareUrl;
        if (!url) return;
        const label = btn.querySelector<HTMLElement>('[data-share-copy-label]');
        const copiedLabel = btn.dataset.shareCopiedLabel || '✓';
        try {
          await navigator.clipboard.writeText(url);
          if (label) {
            const original = label.textContent;
            label.textContent = copiedLabel;
            setTimeout(() => { if (label && original) label.textContent = original; }, 1800);
          }
        } catch {
          if (label) label.textContent = '✗';
        }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initArticleShare);
  } else {
    initArticleShare();
  }
  document.addEventListener('astro:page-load', initArticleShare);
</script>

<style>
  .article-header {
    padding: 60px 56px 40px;
    max-width: 880px;
    margin: 0 auto;
  }
  .back-link {
    font-size: 13px;
    color: var(--ink);
    opacity: 0.6;
    font-family: var(--font-mono);
    text-decoration: none;
  }
  .back-link::before { content: '← '; }
  :global(.article-header-content) { margin-top: 32px; }
  .article-meta-row {
    font-family: var(--font-mono);
    font-size: 12px;
    opacity: 0.6;
    margin-bottom: 16px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  .meta-sep { opacity: 0.5; }
  .article-tag-inline {
    color: var(--accent);
    font-family: var(--font-mono);
  }
  .article-title {
    font-size: 72px;
    line-height: 1.02;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .article-excerpt {
    font-size: 22px;
    line-height: 1.5;
    margin: 24px 0 0;
    opacity: 0.7;
    font-family: var(--font-display);
    font-style: italic;
  }

  .article-body {
    padding: 24px 56px 80px;
    max-width: 760px;
    margin: 0 auto;
  }
  :global(.article-prose) {
    font-size: 18px;
    line-height: 1.7;
  }
  :global(.article-prose h2) {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 36px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 48px 0 16px;
  }
  :global(.article-prose h3) {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.2;
    margin: 32px 0 12px;
  }
  :global(.article-prose p) { margin: 0 0 20px; }
  :global(.article-prose strong) { font-weight: 600; }
  :global(.article-prose em) { font-style: italic; }
  :global(.article-prose code) {
    background: color-mix(in srgb, var(--ink) 8%, transparent);
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  :global(.article-prose pre) {
    background: var(--bg2);
    padding: 20px;
    border-radius: var(--radius-card);
    overflow-x: auto;
    margin: 28px 0;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.5;
  }
  :global(.article-prose pre code) {
    background: transparent;
    padding: 0;
    font-size: inherit;
  }
  :global(.article-prose blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 24px;
    margin: 32px 0;
    font-style: italic;
    opacity: 0.85;
  }
  :global(.article-prose ul), :global(.article-prose ol) {
    margin: 0 0 24px;
    padding-left: 24px;
  }
  :global(.article-prose li) { margin: 8px 0; }
  :global(.article-prose a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .article-share {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid color-mix(in srgb, var(--ink) 13%, transparent);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .share-author {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.6;
  }
  .share-links {
    display: flex;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .share-links a,
  .share-copy-btn {
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .share-copy-btn {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    cursor: pointer;
  }
  .share-links a:hover,
  .share-copy-btn:hover { opacity: 0.7; }

  .article-next {
    padding: 60px 56px;
    background: var(--bg2);
    border-top: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .next-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.6;
    margin-bottom: 16px;
  }
  .next-link {
    text-decoration: none;
    color: var(--ink);
    display: block;
  }
  .next-title {
    font-family: var(--font-display);
    font-size: 56px;
    line-height: 1.05;
    font-weight: 400;
    letter-spacing: -0.02em;
    max-width: 900px;
    margin: 0;
  }
  .next-arrow { color: var(--accent); }

  @media (max-width: 1024px) {
    .article-header { padding: 48px 32px 32px; }
    .article-body { padding: 24px 32px 64px; }
    .article-next { padding: 48px 32px; }
    .article-title { font-size: 56px; }
    .article-excerpt { font-size: 20px; }
    .next-title { font-size: 44px; }
  }
  @media (max-width: 768px) {
    .article-header { padding: 40px 20px 24px; max-width: 100%; }
    .article-body { padding: 16px 20px 56px; max-width: 100%; }
    .article-next { padding: 40px 20px; }
    .article-title { font-size: 40px; line-height: 1.05; }
    .article-excerpt { font-size: 18px; }
    :global(.article-prose) { font-size: 17px; }
    :global(.article-prose h2) { font-size: 28px; margin-top: 36px; }
    :global(.article-prose h3) { font-size: 20px; }
    .next-title { font-size: 32px; }
    .article-share { flex-direction: column; gap: 12px; }
  }
  @media (max-width: 480px) {
    .article-header { padding: 32px 16px 20px; }
    .article-body { padding: 12px 16px 40px; }
    .article-next { padding: 32px 16px; }
    .article-title { font-size: 32px; }
    .article-excerpt { font-size: 16px; }
    :global(.article-prose h2) { font-size: 24px; }
    .next-title { font-size: 26px; }
  }
</style>
