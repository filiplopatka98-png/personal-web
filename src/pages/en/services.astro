---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { t } from '../../i18n';

const lang = 'en';
const services = (await getCollection('services'))
  .filter((s) => s.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout lang={lang} canonicalPath="/en/services/" altLangUrl="/sluzby/" title={`${t('services.title', lang)} — Filip Lopatka`}>
  <section class="py-16">
    <SectionHeader number="02" eyebrow={t('services.eyebrow', lang)} title={t('services.title', lang)} level={1} />
    <p class="text-lg max-w-prose mb-12">{t('services.intro', lang)}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((entry) => <ServiceCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
