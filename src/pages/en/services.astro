---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceRow from '../../components/ServiceRow.astro';
import ServiceModal from '../../components/ServiceModal.astro';
import { t } from '../../i18n';

const lang = 'en';
const services = (await getCollection('services'))
  .filter((s) => s.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout lang={lang} canonicalPath="/en/services/" altLangUrl="/sluzby/" title={`${t('services.title', lang)} — Filip Lopatka`}>
  <section class="py-20 max-w-wide">
    <SectionHeader number="02" eyebrow={t('services.eyebrow', lang)} title={t('services.title', lang)} level={1} />
    <p class="text-lg max-w-prose mb-12">{t('services.intro', lang)}</p>

    <div>
      {services.map((entry, i) => {
        const num = String(i + 1).padStart(2, '0');
        const modalId = `service-modal-${entry.data.slugKey}-${lang}`;
        return (
          <>
            <ServiceRow entry={entry} modalId={modalId} number={num} />
            <ServiceModal entry={entry} modalId={modalId} number={num} lang={lang} />
          </>
        );
      })}
    </div>
  </section>
</BaseLayout>
