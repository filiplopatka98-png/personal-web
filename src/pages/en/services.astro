---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHead from '../../components/PageHead.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Reveal from '../../components/Reveal.astro';
import { t } from '../../i18n';
import { getStaticRoute } from '../../i18n/routes';
import { processSteps } from '../../data/process';

const lang = 'en';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const services = (await getCollection('services'))
  .filter((s) => s.slug.startsWith('en/'))
  .sort((a, b) => a.data.order - b.data.order);

const titleHtml = `${t('services.title.before', lang)}<em>${t('services.title.em', lang)}</em>${t('services.title.after', lang)}`;
const steps = processSteps[lang];
---
<BaseLayout lang={lang} canonicalPath="/en/services/" altLangUrl="/sluzby/" title={`${t('nav.services', lang)} — Filip Lopatka`}>
  <PageHead
    eyebrow={t('services.eyebrow', lang)}
    titleHtml={titleHtml}
    lead={t('services.lead', lang)}
  />

  <section class="services-section">
    <div class="services-grid">
      {services.map((s, i) => (
        <Reveal delay={(i % 2) * 0.08}>
          <ServiceCard entry={s} lang={lang} index={i + 1} />
        </Reveal>
      ))}
    </div>
  </section>

  <section class="process-section">
    <Reveal>
      <div class="process-eyebrow mono">{t('services.processEyebrow', lang)}</div>
      <h2 class="process-title display">{t('services.processTitle', lang)}</h2>
    </Reveal>
    <div class="process-grid">
      {steps.map((step, i) => (
        <Reveal delay={i * 0.05}>
          <div class="process-step">
            <div class="step-num mono">{step.num}</div>
            <div class="step-title display">{step.title}</div>
            <p class="step-desc">{step.desc}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </section>

  <section class="services-final-cta">
    <Reveal>
      <h2 class="final-cta-title display">
        {t('services.finalCta.title.before', lang)}<em class="final-cta-em">{t('services.finalCta.title.em', lang)}</em>{t('services.finalCta.title.after', lang)}
      </h2>
      <p class="final-cta-lead">{t('services.finalCta.lead', lang)}</p>
      <a href={`${baseUrl}${getStaticRoute('brief', lang)}`} class="final-cta-btn mono" data-cursor="hover">
        {t('cta.briefStart', lang)} →
      </a>
    </Reveal>
  </section>
</BaseLayout>

<style>
  .services-section {
    padding: 56px 32px;
  }
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 1320px;
    margin: 0 auto;
    align-items: stretch;
  }

  .process-section {
    padding: 80px 32px;
    position: relative;
  }
  .process-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 14px;
    letter-spacing: 0.06em;
    max-width: 1320px;
    margin-left: auto;
    margin-right: auto;
  }
  .process-title {
    font-size: 64px;
    margin: 0 0 48px;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 1320px;
    margin-left: auto;
    margin-right: auto;
  }
  .process-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .process-step {
    padding: 28px;
    border-radius: 24px;
    background: var(--glass-fill);
    backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    -webkit-backdrop-filter: blur(var(--glass-blur, 28px)) saturate(180%);
    border: 1px solid var(--glass-border);
    box-shadow:
      0 30px 60px -24px var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight);
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .step-title {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1.1;
    margin-bottom: 12px;
    color: var(--ink);
  }
  .step-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }

  .services-final-cta {
    padding: 100px 32px;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }
  .final-cta-title {
    font-size: 80px;
    line-height: 1;
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .final-cta-em {
    color: var(--accent);
    font-style: italic;
  }
  .final-cta-lead {
    font-size: 18px;
    color: var(--ink-soft);
    max-width: 520px;
    margin: 0 auto 32px;
    line-height: 1.5;
  }
  .final-cta-btn {
    display: inline-block;
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--accent) 78%, white) 0%,
      color-mix(in oklab, var(--accent) 92%, transparent) 100%);
    color: var(--ink-on-accent);
    border: 1px solid color-mix(in oklab, var(--accent) 60%, white 40%);
    padding: 16px 28px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 14px;
    text-decoration: none;
    box-shadow:
      0 18px 36px -14px color-mix(in oklab, var(--accent) 70%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 1024px) {
    .services-section { padding: 48px 24px; }
    .process-section { padding: 64px 24px; }
    .services-final-cta { padding: 80px 24px; }
    .services-grid { gap: 20px; }
    .process-grid { grid-template-columns: 1fr 1fr; gap: 20px; }
    .process-title { font-size: 52px; }
    .final-cta-title { font-size: 64px; }
  }
  @media (max-width: 768px) {
    .services-section { padding: 40px 16px; }
    .process-section { padding: 56px 16px; }
    .services-final-cta { padding: 64px 16px; }
    .services-grid { grid-template-columns: 1fr; gap: 16px; }
    .process-grid { grid-template-columns: 1fr; gap: 16px; }
    .process-title { font-size: 38px; }
    .final-cta-title { font-size: 48px; }
    .final-cta-lead { font-size: 16px; }
  }
  @media (max-width: 480px) {
    .services-section { padding: 32px 12px; }
    .process-section { padding: 48px 12px; }
    .services-final-cta { padding: 56px 12px; }
    .process-title { font-size: 32px; }
    .final-cta-title { font-size: 40px; }
  }
</style>
