---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHead from '../../components/PageHead.astro';
import BriefWizard from '../../components/BriefWizard.astro';
import { t } from '../../i18n';

const lang = 'en';
const titleHtml = `${t('brief.title.before', lang)}<em>${t('brief.title.em', lang)}</em>${t('brief.title.after', lang)}`;
---
<BaseLayout lang={lang} canonicalPath="/en/brief/" altLangUrl="/ponuka/" title={`${t('nav.brief', lang)} — Filip Lopatka`}>
  <PageHead
    eyebrow={t('brief.eyebrow', lang)}
    titleHtml={titleHtml}
    lead={t('brief.lead', lang)}
    blobColor="var(--accent2)"
  />
  <section class="brief-wrap">
    <BriefWizard lang={lang} />
  </section>
</BaseLayout>

<style>
  .brief-wrap {
    padding: 60px 56px;
    max-width: 760px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .brief-wrap { padding: 40px 20px; }
  }
</style>
