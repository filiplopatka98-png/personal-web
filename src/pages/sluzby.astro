---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHead from '../components/PageHead.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Reveal from '../components/Reveal.astro';
import Blob from '../components/Blob.astro';
import { t } from '../i18n';
import { getStaticRoute } from '../i18n/routes';
import { processSteps } from '../data/process';

const lang = 'sk';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const services = (await getCollection('services'))
  .filter((s) => s.slug.startsWith('sk/'))
  .sort((a, b) => a.data.order - b.data.order);

const titleHtml = `${t('services.title.before', lang)}<em>${t('services.title.em', lang)}</em>${t('services.title.after', lang)}`;
const steps = processSteps[lang];
---
<BaseLayout lang={lang} canonicalPath="/sluzby/" altLangUrl="/en/services/" title={`${t('nav.services', lang)} — Filip Lopatka`}>
  <PageHead
    eyebrow={t('services.eyebrow', lang)}
    titleHtml={titleHtml}
    lead={t('services.lead', lang)}
  />

  <section class="services-section">
    <div class="services-grid">
      {services.map((s, i) => (
        <Reveal delay={(i % 2) * 0.08}>
          <ServiceCard entry={s} lang={lang} index={i + 1} />
        </Reveal>
      ))}
    </div>
  </section>

  <section class="process-section">
    <Blob color="var(--accent3)" size={280} position="bottom: 40px; right: 80px; opacity: 0.5;" />
    <Reveal>
      <div class="process-eyebrow mono">{t('services.processEyebrow', lang)}</div>
      <h2 class="process-title display">{t('services.processTitle', lang)}</h2>
    </Reveal>
    <div class="process-grid">
      {steps.map((step, i) => (
        <Reveal delay={i * 0.05}>
          <div class="process-step">
            <div class="step-num mono">{step.num}</div>
            <div class="step-title display">{step.title}</div>
            <p class="step-desc">{step.desc}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </section>

  <section class="services-final-cta">
    <Reveal>
      <h2 class="final-cta-title display">
        {t('services.finalCta.title.before', lang)}<em class="final-cta-em">{t('services.finalCta.title.em', lang)}</em>{t('services.finalCta.title.after', lang)}
      </h2>
      <p class="final-cta-lead">{t('services.finalCta.lead', lang)}</p>
      <a href={`${baseUrl}${getStaticRoute('brief', lang)}`} class="final-cta-btn mono" data-cursor="hover">
        {t('cta.briefStart', lang)} →
      </a>
    </Reveal>
  </section>
</BaseLayout>

<style>
  /* Services grid — handoff line 219: 60px 56px section, 1fr 1fr grid, gap 32. */
  .services-section {
    padding: 60px 56px;
  }
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: stretch;
  }

  /* Process — handoff line 268: 80px 56px, bg2 (NO top/bottom borders). */
  .process-section {
    padding: 80px 56px;
    background: var(--bg2);
    position: relative;
    overflow: hidden;
  }
  .process-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.6;
    margin-bottom: 14px;
    letter-spacing: 0.06em;
    position: relative;
  }
  /* Process h2 — handoff line 271: 64px (was 56). */
  .process-title {
    font-size: 64px;
    margin: 0 0 48px;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    position: relative;
  }
  .process-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
    position: relative;
  }
  /* Process step — handoff line 275: borderTop 2px solid accent, paddingTop 20. */
  .process-step {
    border-top: 2px solid var(--accent);
    padding-top: 20px;
  }
  /* Step num — handoff line 276: mono 11/0.5 (NOT display 36 in accent). */
  .step-num {
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.65;
    margin-bottom: 8px;
  }
  /* Step title — handoff line 277: display 28/1.1 (NOT 20). */
  .step-title {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .step-desc {
    font-size: 14px;
    line-height: 1.55;
    opacity: 0.75;
    margin: 0;
  }

  /* Final CTA — handoff line 285: 100px 56px, text-align center, h2 80px. */
  .services-final-cta {
    padding: 100px 56px;
    text-align: center;
  }
  .final-cta-title {
    font-size: 80px;
    line-height: 1;
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .final-cta-em {
    color: var(--accent-text);
    font-style: italic;
  }
  .final-cta-lead {
    font-size: 18px;
    opacity: 0.7;
    max-width: 520px;
    margin: 0 auto 32px;
    line-height: 1.5;
  }
  .final-cta-btn {
    display: inline-block;
    background: var(--ink);
    color: var(--bg);
    padding: 16px 28px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 14px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .final-cta-btn:hover {
    background: var(--accent);
    color: var(--ink);
  }

  @media (max-width: 1024px) {
    .services-section { padding: 48px 32px; }
    .process-section { padding: 64px 32px; }
    .services-final-cta { padding: 80px 32px; }
    .services-grid { gap: 28px; }
    .process-grid { grid-template-columns: 1fr 1fr; gap: 28px; }
    .process-title { font-size: 52px; }
    .final-cta-title { font-size: 64px; }
  }
  @media (max-width: 768px) {
    .services-section { padding: 40px 20px; }
    .process-section { padding: 56px 20px; }
    .services-final-cta { padding: 64px 20px; }
    .services-grid { grid-template-columns: 1fr; gap: 24px; }
    .process-grid { grid-template-columns: 1fr; gap: 24px; }
    .process-title { font-size: 38px; }
    .final-cta-title { font-size: 48px; }
    .final-cta-lead { font-size: 16px; }
  }
  @media (max-width: 480px) {
    .services-section { padding: 32px 16px; }
    .process-section { padding: 48px 16px; }
    .services-final-cta { padding: 56px 16px; }
    .process-title { font-size: 32px; }
    .final-cta-title { font-size: 40px; }
  }
</style>
