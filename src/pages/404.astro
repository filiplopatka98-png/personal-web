---
import BaseLayout from '../layouts/BaseLayout.astro';
import Reveal from '../components/Reveal.astro';
import { t } from '../i18n';
import { getStaticRoute } from '../i18n/routes';

const lang = 'sk';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout lang={lang} canonicalPath="/404/" title="404 — Filip Lopatka">
  <div class="not-found">
    <Reveal class="not-found-content">
      <div class="not-found-num display">404</div>
      <h1 class="not-found-title display">
        {t('notFound.title.before', lang)}<em>{t('notFound.title.em', lang)}</em>{t('notFound.title.after', lang)}
      </h1>
      <p class="not-found-lead">{t('notFound.lead', lang)}</p>
      <div class="not-found-ctas">
        <a href={`${baseUrl}/`} class="btn-primary" data-cursor="hover">← {t('notFound.backHome', lang)}</a>
        <a href={`${baseUrl}${getStaticRoute('work', lang)}`} class="btn-ghost" data-cursor="hover">{t('notFound.seeWork', lang)}</a>
      </div>
    </Reveal>
  </div>
</BaseLayout>

<style>
  .not-found {
    padding: 160px 32px 100px;
    text-align: center;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  :global(.not-found-content) {
    position: relative;
    z-index: 2;
  }
  .not-found-num {
    font-size: 280px;
    line-height: 0.85;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--accent);
    text-shadow: 0 0 80px color-mix(in oklab, var(--accent) 50%, transparent);
  }
  .not-found-title {
    font-size: 56px;
    line-height: 1.05;
    margin: 24px 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .not-found-title :global(em) {
    color: var(--accent);
    font-style: italic;
    padding-left: 0.08em;
    padding-right: 0.06em;
  }
  .not-found-lead {
    font-size: 18px;
    color: var(--ink-soft);
    max-width: 480px;
    margin: 0 auto 32px;
  }
  .not-found-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--accent) 78%, white) 0%,
      color-mix(in oklab, var(--accent) 92%, transparent) 100%);
    color: var(--ink-on-accent);
    border: 1px solid color-mix(in oklab, var(--accent) 60%, white 40%);
    padding: 14px 24px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    box-shadow:
      0 18px 36px -14px color-mix(in oklab, var(--accent) 70%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  .btn-ghost {
    background: var(--glass-fill-flat);
    color: var(--ink);
    border: 1px solid var(--glass-border);
    padding: 14px 24px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: inset 0 1px 0 var(--glass-highlight);
  }
  @media (max-width: 1024px) {
    .not-found { padding: 120px 24px 80px; }
    .not-found-num { font-size: 200px; }
    .not-found-title { font-size: 48px; }
  }
  @media (max-width: 768px) {
    .not-found {
      padding: 90px 16px 56px;
    }
    .not-found-num {
      font-size: 160px;
    }
    .not-found-title {
      font-size: 36px;
    }
  }
  @media (max-width: 480px) {
    .not-found { padding: 80px 12px 48px; }
    .not-found-num { font-size: 120px; }
    .not-found-title { font-size: 28px; }
  }
</style>
