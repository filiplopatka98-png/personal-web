---
import { getCollection, type CollectionEntry } from 'astro:content';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join, resolve } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Reveal from '../../components/Reveal.astro';
import Plate from '../../components/Plate.astro';
import { t } from '../../i18n';

// Project root resolution for runtime file existence checks (build time).
const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const projectRoot = resolve(__dirname, '../../..');

function mockupPath(slug: string, type: 'hero' | 'mobile'): string | null {
  const rel = `/projects/${slug}-${type}.png`;
  const abs = join(projectRoot, 'public', rel);
  return existsSync(abs) ? rel : null;
}

export async function getStaticPaths() {
  const all = await getCollection('projects');
  return all
    .filter((p) => p.slug.startsWith('sk/'))
    .map((entry) => ({
      params: { slug: entry.slug.replace(/^sk\//, '') },
      props: { entry },
    }));
}

interface Props { entry: CollectionEntry<'projects'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const lang = 'sk';
const cleanSlug = entry.slug.replace(/^sk\//, '');

// Find next project (by order, wrap around)
const allProjects = (await getCollection('projects'))
  .filter((p) => p.slug.startsWith('sk/'))
  .sort((a, b) => a.data.order - b.data.order);
const idx = allProjects.findIndex((p) => p.slug === entry.slug);
const next = allProjects[(idx + 1) % allProjects.length];
const nextSlug = next.slug.replace(/^sk\//, '');

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const accentColor = `var(--${data.accent})`;

// Real mockup detection — generated by `npm run shots <url>`.
const heroMockupRel = mockupPath(cleanSlug, 'hero');
const mobileMockupRel = mockupPath(cleanSlug, 'mobile');
const heroMockupSrc = heroMockupRel ? `${baseUrl}${heroMockupRel}` : null;
const mobileMockupSrc = mobileMockupRel ? `${baseUrl}${mobileMockupRel}` : null;

// JSON-LD: CreativeWork
const projectUrlPath = `${baseUrl}/praca/${cleanSlug}/`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const fullProjectUrl = `${siteUrl}${projectUrlPath}`;

const projectLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: data.name,
  description: data.brief,
  creator: {
    '@type': 'Person',
    name: 'Filip Lopatka',
    url: `${siteUrl}${baseUrl}/`,
  },
  dateCreated: data.year,
  url: fullProjectUrl,
  about: data.kind,
  inLanguage: 'sk-SK',
  ...(data.url && { sameAs: [`https://${data.url}`] }),
};
---
<BaseLayout
  lang={lang}
  canonicalPath={`/praca/${cleanSlug}/`}
  altLangUrl={`/en/work/${cleanSlug}/`}
  title={`${data.name} — Filip Lopatka`}
  description={data.brief}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(projectLd)}></script>

  {/* Header — handoff line 97: 60/56/40, grid 1.4fr 1fr, alignItems:end */}
  <section class="proj-header">
    <Reveal>
      <a href={`${baseUrl}/praca/`} class="back-link mono" data-cursor="hover">{t('cta.back', lang)}</a>
    </Reveal>
    <Reveal delay={0.05} class="proj-header-grid">
      <div>
        <div class="proj-eyebrow mono">{t('project.caseStudy', lang)} · {data.year}</div>
        <h1 class="proj-name display">{data.name}</h1>
        <div class="proj-kind mono">{data.kind}</div>
      </div>
      <dl class="proj-meta-grid">
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.client', lang)}</dt>
          <dd>{data.client}</dd>
        </div>
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.role', lang)}</dt>
          <dd>{data.role}</dd>
        </div>
        <div class="proj-meta-cell">
          <dt class="mono">{t('project.duration', lang)}</dt>
          <dd>{data.duration}</dd>
        </div>
        {data.url && (
          <div class="proj-meta-cell">
            <dt class="mono">{t('project.url', lang)}</dt>
            <dd>{data.url}</dd>
          </div>
        )}
      </dl>
    </Reveal>
  </section>

  {/* Hero plate — handoff line 124: 0/56/32 padding, radius 20.
      Uses real laptop mockup PNG when generated (npm run shots), else CSS placeholder. */}
  <section class="proj-hero">
    <Reveal>
      <Plate
        label={`${data.name} · hero`}
        color={accentColor}
        ratio="16/9"
        caption={heroMockupSrc ? data.url : 'screen-01.png'}
        radius={20}
        imageSrc={heroMockupSrc ?? undefined}
        imageAlt={`${data.name} — desktop náhľad`}
      />
    </Reveal>
  </section>

  {/* Metrics — handoff line 131: 40/56, bg2, top+bottom borders, 3-col, value 80px accent */}
  {data.metrics.length > 0 && (
    <section class="proj-metrics">
      <div class="metrics-grid">
        {data.metrics.map((m, i) => (
          <Reveal delay={i * 0.08}>
            <div class="metric-value display">{m.value}</div>
            <div class="metric-label mono">{m.label}</div>
          </Reveal>
        ))}
      </div>
    </section>
  )}

  {/* Brief + body — handoff line 143: 80/56, grid 1fr 2fr gap 64, no bg */}
  <section class="proj-body">
    <div class="proj-body-grid">
      <Reveal>
        <div class="proj-section-eyebrow mono">{t('project.brief', lang)}</div>
        <div class="proj-brief-title display">{data.brief}</div>
      </Reveal>
      <Reveal delay={0.1} class="proj-body-prose">
        <Content />
      </Reveal>
    </div>
  </section>

  {/* Process — handoff line 156: 60/56, bg2, NO h2, 4-col rows */}
  {data.process.length > 0 && (
    <section class="proj-process">
      <Reveal>
        <div class="proj-section-eyebrow mono proj-process-eyebrow">{t('project.process', lang)}</div>
      </Reveal>
      <div class="process-list">
        {data.process.map((p, i) => (
          <Reveal delay={i * 0.05} class="process-row">
            <div class="process-num mono">0{i + 1}</div>
            <div class="process-title display">{p.title}</div>
            <div class="process-duration mono">{p.duration}</div>
            <div class="process-desc">{p.desc}</div>
          </Reveal>
        ))}
      </div>
    </section>
  )}

  {/* Screens — handoff line 173: 60/56, 2-col grid, ratio 4/3.
      When a mobile mockup exists, first slot becomes the phone mockup
      (portrait) and grid shifts to 1fr 1.5fr to give the second plate
      more horizontal room. Otherwise: 2 equal Plate placeholders. */}
  <section class:list={['proj-screens', mobileMockupSrc && 'has-mobile-mockup']}>
    <div class="screens-grid">
      <Reveal>
        <Plate
          label="mobile"
          color={accentColor}
          ratio={mobileMockupSrc ? '600/1100' : '4/3'}
          caption={mobileMockupSrc ? 'mobilný pohľad' : 'checkout flow'}
          imageSrc={mobileMockupSrc ?? undefined}
          imageAlt={`${data.name} — mobilný náhľad`}
        />
      </Reveal>
      <Reveal delay={0.08}>
        <Plate label="screen-03" color="var(--accent2)" ratio="4/3" caption="product detail" />
      </Reveal>
    </div>
  </section>

  {/* Stack + live — handoff line 181: 40/56, bg ink, color bg, flex space-between */}
  <section class="proj-stack-live">
    <div class="stack-block">
      <div class="stack-eyebrow mono">{t('project.stack', lang).toUpperCase()}</div>
      <div class="stack-list mono">
        {data.stack.map((s, i) => (
          <Fragment>
            <span>{s}</span>
            {i < data.stack.length - 1 && <span class="stack-sep" aria-hidden="true">·</span>}
          </Fragment>
        ))}
      </div>
    </div>
    {data.url && (
      <a href={`https://${data.url}`} target="_blank" rel="noopener noreferrer" class="live-link mono" data-cursor="hover">
        {t('cta.liveSite', lang)} {data.url} →
      </a>
    )}
  </section>

  {/* Next project — handoff line 192: 80/56, top border, NOT dark */}
  <section class="proj-next">
    <Reveal>
      <div class="next-eyebrow mono">{t('project.next', lang).toUpperCase()}</div>
      <a href={`${baseUrl}/praca/${nextSlug}/`} class="next-link" data-cursor="hover">
        <div class="next-name display">{next.data.name} <span class="next-arrow">→</span></div>
        <div class="next-kind mono">{next.data.kind}</div>
      </a>
    </Reveal>
  </section>
</BaseLayout>

<style>
  /* ── Header — handoff 97-121 ────────────────────────────────────────── */
  .proj-header {
    padding: 60px 56px 40px;
  }
  .back-link {
    font-size: 13px;
    color: var(--ink);
    opacity: 0.6;
    font-family: var(--font-mono);
    text-decoration: none;
  }
  .back-link::before {
    content: '← ';
  }
  :global(.proj-header-grid) {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: end;
  }
  .proj-eyebrow {
    font-size: 13px;
    opacity: 0.6;
    margin-bottom: 14px;
    font-family: var(--font-mono);
  }
  .proj-name {
    font-size: 96px;
    line-height: 0.92;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .proj-kind {
    font-size: 14px;
    margin-top: 16px;
    opacity: 0.7;
    font-family: var(--font-mono);
  }
  .proj-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 13px;
    margin: 0;
  }
  .proj-meta-cell {
    border-top: 1px solid color-mix(in srgb, var(--ink) 13%, transparent);
    padding-top: 10px;
  }
  .proj-meta-cell dt {
    opacity: 0.65;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .proj-meta-cell dd {
    margin: 4px 0 0;
  }

  /* ── Hero plate — handoff 124 ───────────────────────────────────────── */
  .proj-hero {
    padding: 0 56px 32px;
  }

  /* ── Metrics — handoff 131: bg2, top+bottom border 1px ink1f, value 80, label 12 mono uppercase */
  .proj-metrics {
    padding: 40px 56px;
    background: var(--bg2);
    border-top: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .metric-value {
    font-size: 80px;
    line-height: 0.9;
    color: var(--accent);
    font-family: var(--font-display);
  }
  .metric-label {
    font-size: 12px;
    opacity: 0.6;
    margin-top: 12px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Brief + body — handoff 143: 80/56, grid 1fr 2fr, NO bg ─────────── */
  .proj-body {
    padding: 80px 56px;
  }
  :global(.proj-body-grid) {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 64px;
  }
  .proj-section-eyebrow {
    font-size: 11px;
    opacity: 0.6;
    margin-bottom: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  /* Brief title — handoff line 147: display 32/1.2 (was 48/1.05). */
  .proj-brief-title {
    font-size: 32px;
    line-height: 1.2;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  /* Body prose — handoff line 149: 18/1.65, plain p with 20px top margin
     between paragraphs. NO drop cap. */
  :global(.proj-body-prose) {
    font-size: 18px;
    line-height: 1.65;
  }
  :global(.proj-body-prose p) {
    margin: 0;
  }
  :global(.proj-body-prose p + p) {
    margin-top: 20px;
  }

  /* ── Process — handoff 156: 60/56 bg2. NO h2, only eyebrow. 4-col rows. */
  .proj-process {
    padding: 60px 56px;
    background: var(--bg2);
  }
  .proj-process-eyebrow {
    font-size: 13px;
    margin-bottom: 32px;
    text-transform: none;
    letter-spacing: 0;
  }
  .process-list {
    display: flex;
    flex-direction: column;
  }
  /* 4-col grid: num / title / duration / desc — handoff line 162. */
  :global(.process-row) {
    display: grid !important;
    grid-template-columns: 60px 1fr 200px 2fr;
    gap: 32px;
    padding: 24px 0;
    border-top: 1px solid color-mix(in srgb, var(--ink) 13%, transparent);
  }
  .process-num {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.6;
  }
  .process-title {
    font-size: 24px;
    font-family: var(--font-display);
    line-height: 1.1;
  }
  .process-duration {
    font-family: var(--font-mono);
    font-size: 12px;
    opacity: 0.6;
  }
  .process-desc {
    font-size: 15px;
    line-height: 1.5;
    opacity: 0.8;
  }

  /* ── Screens — handoff 173: 60/56, 2-col gap 24, ratio 4/3 ──────────── */
  .proj-screens {
    padding: 60px 56px;
  }
  .screens-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }
  /* When the first slot is a portrait phone mockup, give the second
     screen plate more width so it doesn't compress against the phone. */
  .proj-screens.has-mobile-mockup .screens-grid {
    grid-template-columns: 1fr 1.6fr;
    gap: 32px;
    align-items: center;
  }

  /* ── Stack + live — handoff 181: dark band, flex space-between ─────── */
  .proj-stack-live {
    padding: 40px 56px;
    background: var(--ink);
    color: var(--bg);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }
  .stack-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.65;
    margin-bottom: 8px;
    letter-spacing: 0.06em;
  }
  .stack-list {
    font-family: var(--font-mono);
    font-size: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 16px;
  }
  .stack-sep {
    opacity: 0.5;
    margin-left: 16px;
  }
  .live-link {
    color: var(--accent-text);
    font-family: var(--font-mono);
    font-size: 14px;
    text-decoration: none;
  }
  .live-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ── Next project — handoff 192: 80/56, top border, NOT dark ───────── */
  .proj-next {
    padding: 80px 56px;
    border-top: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .next-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.6;
    margin-bottom: 16px;
  }
  .next-link {
    display: block;
    text-decoration: none;
    color: var(--ink);
  }
  .next-name {
    font-family: var(--font-display);
    font-size: 96px;
    line-height: 0.95;
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .next-arrow {
    color: var(--accent);
  }
  .next-kind {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.6;
    margin-top: 12px;
  }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 32px;
      padding-right: 32px;
    }
    .proj-hero { padding: 0 32px 24px; }
    .proj-metrics { padding: 32px; }
    .proj-stack-live { padding: 32px; }
    .proj-name { font-size: 72px; }
    .proj-brief-title { font-size: 28px; }
    .next-name { font-size: 72px; }
    .metric-value { font-size: 64px; }
    /* Process: 4-col → 4-col tight per RESPONSIVE.md "40px 1fr 140px 2fr". */
    :global(.process-row) {
      grid-template-columns: 40px 1fr 140px 2fr;
      gap: 20px;
    }
    :global(.proj-body-grid) { gap: 36px; }
  }

  @media (max-width: 768px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 20px;
      padding-right: 20px;
    }
    .proj-hero { padding: 0 20px 20px; }
    .proj-metrics { padding: 32px 20px; }
    .proj-stack-live { padding: 32px 20px; }

    :global(.proj-header-grid) {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    :global(.proj-body-grid) {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .proj-name { font-size: 56px; }
    .proj-brief-title { font-size: 26px; }
    .next-name { font-size: 48px; }

    .metrics-grid { grid-template-columns: 1fr; gap: 24px; }
    .metric-value { font-size: 56px; }

    .screens-grid { grid-template-columns: 1fr; }
    .proj-meta-grid { grid-template-columns: 1fr 1fr; }

    /* Process row collapses to single column with date as small eyebrow. */
    :global(.process-row) {
      grid-template-columns: 1fr !important;
      gap: 4px;
      padding: 18px 0;
    }
    .process-num {
      font-size: 11px;
      opacity: 0.55;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .process-duration {
      order: -1;
      margin-bottom: 4px;
    }

    .proj-stack-live {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .proj-header, .proj-body, .proj-process, .proj-screens, .proj-next {
      padding-left: 16px;
      padding-right: 16px;
    }
    .proj-name { font-size: 44px; }
    .proj-brief-title { font-size: 22px; }
    .next-name { font-size: 36px; }
    .proj-meta-grid { grid-template-columns: 1fr; }
    .metric-value { font-size: 48px; }
  }
</style>
