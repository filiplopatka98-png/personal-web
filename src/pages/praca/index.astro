---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHead from '../../components/PageHead.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Reveal from '../../components/Reveal.astro';
import { t } from '../../i18n';
import { jsonLd } from '../../utils/jsonld';
import { buildItemList } from '../../utils/itemList';

const lang = 'sk';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = (await getCollection('projects'))
  .filter((p) => p.id.startsWith('sk/'))
  .sort((a, b) => a.data.order - b.data.order);

const projectCount = projects.length;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const itemListLd = buildItemList(
  projects.map((p) => ({
    url: `${siteUrl}${baseUrl}/praca/${p.id.replace(/^sk\//, '')}/`,
    name: p.data.name,
  })),
  'Realizované projekty',
);
const titleHtml = `${t('work.title.before', lang)}<em>${t('work.title.em', lang)}</em>${t('work.title.after', lang)}`;

// Derive filter chips from the tech in each project's kind ("… · WordPress"),
// so only filters that actually match a project are shown — no dead options.
const FILTER_LABELS: Record<string, string> = { woocommerce: 'E-shop' };
const filters: { value: string; label: string }[] = [];
const seenFilters = new Set<string>();
for (const p of projects) {
  const tech = p.data.kind.split('·').pop()?.trim() ?? '';
  const value = tech.toLowerCase();
  if (tech && !seenFilters.has(value)) {
    seenFilters.add(value);
    filters.push({ value, label: FILTER_LABELS[value] ?? tech });
  }
}
---
<BaseLayout lang={lang} canonicalPath="/praca/" altLangUrl="/en/work/" title="Realizované projekty — weby a eshopy | Filip Lopatka" description="Vybrané realizácie — firemné weby a eshopy s reálnymi výsledkami: rýchlosť, konverzie a Core Web Vitals.">
  <script is:inline slot="head" type="application/ld+json" set:html={jsonLd(itemListLd)}></script>
  <PageHead
    eyebrow={`${projectCount} ${t('work.eyebrow', lang)}`}
    titleHtml={titleHtml}
    lead={t('work.lead', lang)}
  />

  <section class="filter-section">
    <Reveal class="filter-row">
      <span class="mono filter-label">{t('work.filter', lang)}</span>
      <button data-filter="all" class="chip is-active" data-cursor="hover">{t('work.filterAll', lang)}</button>
      {filters.map((f) => (
        <button data-filter={f.value} class="chip" data-cursor="hover">{f.label}</button>
      ))}
    </Reveal>
  </section>

  <section class="work-section">
    <div class="work-grid">
      {projects.map((p) => (
        <Reveal as="div" class="project-wrap" data-project-card data-kind={p.data.kind.toLowerCase()}>
          <ProjectCard entry={p} lang={lang} variant="work" />
        </Reveal>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .filter-section {
    padding: 32px 56px;
    border-bottom: var(--border-soft);
    background: var(--bg2);
  }
  /*
   * .filter-row is on a <Reveal> wrapper; Astro doesn't propagate the page's
   * data-astro-cid scope marker to elements rendered by child components, so
   * the rule must be :global() to match the rendered <div>.
   */
  :global(.filter-row) {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
  :global(.filter-row .filter-label) {
    font-size: 12px;
    opacity: 0.65;
    margin-right: 8px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  :global(.filter-row .chip) {
    border: 1px solid color-mix(in srgb, var(--ink) 33%, transparent);
    background: transparent;
    color: var(--ink);
    padding: 8px 16px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }
  :global(.filter-row .chip.is-active) {
    border-color: var(--ink);
    background: var(--ink);
    color: var(--bg);
  }
  .work-section { padding: 60px 56px; }
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 1024px) {
    .filter-section { padding: 28px 32px; }
    .work-section { padding: 56px 32px; }
    .work-grid { gap: 36px; }
  }
  @media (max-width: 768px) {
    .filter-section, .work-section { padding: 32px 20px; }
    .work-grid { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 480px) {
    .filter-section, .work-section { padding: 24px 16px; }
  }
</style>

<script>
  function initWorkFilter() {
    const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
    const cards = document.querySelectorAll<HTMLElement>('[data-project-card]');
    if (!chips.length || !cards.length) return;

    // Normalize: drop hyphens so "Eshop redesign" matches "e-shop" filter, etc.
    const normalize = (s: string) => s.toLowerCase().replace(/-/g, '');

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('is-active'));
        chip.classList.add('is-active');
        const filter = normalize(chip.dataset.filter || 'all');
        cards.forEach((card) => {
          const kind = normalize(card.dataset.kind || '');
          card.style.display = (filter === 'all' || kind.includes(filter)) ? '' : 'none';
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWorkFilter);
  } else {
    initWorkFilter();
  }
  document.addEventListener('astro:page-load', initWorkFilter);
</script>
