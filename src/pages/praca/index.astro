---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHead from '../../components/PageHead.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Reveal from '../../components/Reveal.astro';
import { t } from '../../i18n';

const lang = 'sk';

const projects = (await getCollection('projects'))
  .filter((p) => p.slug.startsWith('sk/'))
  .sort((a, b) => a.data.order - b.data.order);

const projectCount = projects.length;
const titleHtml = `${t('work.title.before', lang)}<em>${t('work.title.em', lang)}</em>${t('work.title.after', lang)}`;
---
<BaseLayout lang={lang} canonicalPath="/praca/" altLangUrl="/en/work/" title={`${t('nav.work', lang)} — Filip Lopatka`}>
  <PageHead
    eyebrow={`${projectCount} ${t('work.eyebrow', lang)}`}
    titleHtml={titleHtml}
    lead={t('work.lead', lang)}
  />

  <section class="filter-section">
    <Reveal class="filter-row">
      <span class="mono filter-label">{t('work.filter', lang)}</span>
      <button data-filter="all" class="chip is-active" data-cursor="hover">{t('work.filterAll', lang)}</button>
      <button data-filter="e-shop" class="chip" data-cursor="hover">{t('work.filterEshop', lang)}</button>
      <button data-filter="next.js" class="chip" data-cursor="hover">{t('work.filterNext', lang)}</button>
      <button data-filter="wp" class="chip" data-cursor="hover">{t('work.filterWp', lang)}</button>
      <button data-filter="astro" class="chip" data-cursor="hover">{t('work.filterAstro', lang)}</button>
    </Reveal>
  </section>

  <section class="work-section">
    <div class="work-grid">
      {projects.map((p) => (
        <Reveal as="div" class="project-wrap" data-project-card data-kind={p.data.kind.toLowerCase()}>
          <ProjectCard entry={p} lang={lang} variant="work" />
        </Reveal>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .filter-section {
    padding: 24px 32px 0;
  }
  :global(.filter-row) {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    max-width: 1320px;
    margin: 0 auto;
  }
  :global(.filter-row .filter-label) {
    font-size: 12px;
    color: var(--ink-soft);
    margin-right: 8px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  :global(.filter-row .chip) {
    border: 1px solid var(--glass-border);
    background: var(--glass-fill-flat);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    color: var(--ink);
    padding: 8px 16px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: inset 0 1px 0 var(--glass-highlight);
  }
  :global(.filter-row .chip.is-active) {
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--accent) 78%, white) 0%,
      color-mix(in oklab, var(--accent) 92%, transparent) 100%);
    border-color: color-mix(in oklab, var(--accent) 60%, white 40%);
    color: var(--ink-on-accent);
  }
  .work-section { padding: 56px 32px; }
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 1320px;
    margin: 0 auto;
  }
  @media (max-width: 1024px) {
    .filter-section { padding: 20px 24px 0; }
    .work-section { padding: 48px 24px; }
    .work-grid { gap: 20px; }
  }
  @media (max-width: 768px) {
    .filter-section { padding: 16px 16px 0; }
    .work-section { padding: 32px 16px; }
    .work-grid { grid-template-columns: 1fr; gap: 20px; }
  }
  @media (max-width: 480px) {
    .filter-section { padding: 12px 12px 0; }
    .work-section { padding: 24px 12px; }
  }
</style>

<script>
  function initWorkFilter() {
    const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
    const cards = document.querySelectorAll<HTMLElement>('[data-project-card]');
    if (!chips.length || !cards.length) return;

    // Normalize: drop hyphens so "Eshop redesign" matches "e-shop" filter, etc.
    const normalize = (s: string) => s.toLowerCase().replace(/-/g, '');

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('is-active'));
        chip.classList.add('is-active');
        const filter = normalize(chip.dataset.filter || 'all');
        cards.forEach((card) => {
          const kind = normalize(card.dataset.kind || '');
          card.style.display = (filter === 'all' || kind.includes(filter)) ? '' : 'none';
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWorkFilter);
  } else {
    initWorkFilter();
  }
  document.addEventListener('astro:page-load', initWorkFilter);
</script>
