---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Reveal from '../../components/Reveal.astro';
import { t } from '../../i18n';
import { visibleArticles } from '../../content/launch';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  return visibleArticles(all.filter((a) => a.slug.startsWith('sk/')))
    .map((entry) => ({
      params: { slug: entry.slug.replace(/^sk\//, '') },
      props: { entry },
    }));
}

interface Props { entry: CollectionEntry<'articles'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const lang = 'sk';
const cleanSlug = entry.slug.replace(/^sk\//, '');
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

// Find next article (sorted newest first, wrap around)
const allArticles = visibleArticles((await getCollection('articles'))
  .filter((a) => a.slug.startsWith('sk/')))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx = allArticles.findIndex((a) => a.slug === entry.slug);
const next = allArticles[(idx + 1) % allArticles.length];
const nextSlug = next.slug.replace(/^sk\//, '');

const fmt = new Intl.DateTimeFormat('sk-SK', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const dateStr = fmt.format(data.date);
const monthYearFmt = new Intl.DateTimeFormat('sk-SK', { month: 'short', year: 'numeric' });
const dateShort = monthYearFmt.format(data.date);

const articleUrlPath = `${baseUrl}/blog/${cleanSlug}/`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const fullArticleUrl = `${siteUrl}${articleUrlPath}`;

// Share URLs (encoded)
const shareTitle = encodeURIComponent(data.title);
const shareUrl = encodeURIComponent(fullArticleUrl);
const xShareUrl = `https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  datePublished: data.date.toISOString(),
  dateModified: (data.updated ?? data.date).toISOString(),
  author: {
    '@type': 'Person',
    '@id': `${siteUrl}${baseUrl}/#person`,
    name: 'Filip Lopatka',
    url: `${siteUrl}${baseUrl}/`,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${siteUrl}${baseUrl}/#organization`,
    name: 'Filip Lopatka — Web Developer',
    logo: { '@type': 'ImageObject', url: `${siteUrl}${baseUrl}/og-default.png` },
  },
  image: `${siteUrl}${baseUrl}/og-default.png`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': fullArticleUrl },
  description: data.excerpt,
  inLanguage: 'sk-SK',
  keywords: data.tags.join(', '),
  wordCount: entry.body.split(/\s+/).length,
  timeRequired: `PT${data.read}M`,
};
---
<BaseLayout
  lang={lang}
  canonicalPath={`/blog/${cleanSlug}/`}
  altLangUrl={`/en/blog/${cleanSlug}/`}
  title={data.title}
  description={data.excerpt}
  ogType="article"
  article={{
    publishedTime: data.date.toISOString(),
    modifiedTime: (data.updated ?? data.date).toISOString(),
    author: 'Filip Lopatka',
    tags: data.tags,
  }}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(articleLd)}></script>

  {/* Header — handoff line 358: 60/56/40, max-width 880 */}
  <section class="article-header">
    <Reveal>
      <a href={`${baseUrl}/blog/`} class="back-link mono" data-cursor="hover">{t('article.backToBlog', lang)}</a>
    </Reveal>
    <Reveal delay={0.05} class="article-header-content">
      <div class="article-meta-row mono">
        <time datetime={data.date.toISOString()}>{dateStr}</time>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span>{data.read} {t('article.read', lang)}</span>
        {data.tags.map((tag) => (
          <span class="article-tag-inline">#{tag.toLowerCase().replace(/\s+/g, '')}</span>
        ))}
      </div>
      <h1 class="article-title display">{data.title}</h1>
      <p class="article-excerpt">{data.excerpt}</p>
    </Reveal>
  </section>

  {/* Body — handoff line 373: 24/56/80, max-width 760 */}
  <section class="article-body">
    <Reveal class="article-prose">
      <Content />
    </Reveal>

    {/* Share footer — handoff line 383: marginTop 64, paddingTop 32, top border */}
    <div class="article-share">
      <div class="share-author mono">— Filip Lopatka, {dateShort}</div>
      <div class="share-links mono">
        <a href={xShareUrl} target="_blank" rel="nofollow noopener noreferrer" data-cursor="hover">X →</a>
        <a href={linkedinShareUrl} target="_blank" rel="nofollow noopener noreferrer" data-cursor="hover">LinkedIn →</a>
        <button
          type="button"
          class="share-copy-btn mono"
          data-share-copy
          data-share-url={fullArticleUrl}
          data-share-copied-label={t('article.shareCopied', lang)}
          data-cursor="hover"
        >
          <span data-share-copy-label>{t('article.shareCopy', lang)}</span>
        </button>
      </div>
    </div>
  </section>

  {/* Next article — handoff line 394: 60/56, bg2, top border ink1f */}
  <section class="article-next">
    <Reveal>
      <div class="next-eyebrow mono">{t('article.next', lang).toUpperCase()}</div>
      <a href={`${baseUrl}/blog/${nextSlug}/`} class="next-link" data-cursor="hover">
        <h2 class="next-title display">
          {next.data.title} <span class="next-arrow">→</span>
        </h2>
      </a>
    </Reveal>
  </section>
</BaseLayout>

<script>
  function initArticleShare() {
    document.querySelectorAll<HTMLButtonElement>('[data-share-copy]').forEach((btn) => {
      if ((btn as any).__shareInit) return;
      (btn as any).__shareInit = true;
      btn.addEventListener('click', async () => {
        const url = btn.dataset.shareUrl;
        if (!url) return;
        const label = btn.querySelector<HTMLElement>('[data-share-copy-label]');
        const copiedLabel = btn.dataset.shareCopiedLabel || '✓';
        try {
          await navigator.clipboard.writeText(url);
          if (label) {
            const original = label.textContent;
            label.textContent = copiedLabel;
            setTimeout(() => { if (label && original) label.textContent = original; }, 1800);
          }
        } catch {
          if (label) label.textContent = '✗';
        }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initArticleShare);
  } else {
    initArticleShare();
  }
  document.addEventListener('astro:page-load', initArticleShare);
</script>

<style>
  /* ── Header — handoff 358: 60/56/40, max-width 880 ─────────────────── */
  .article-header {
    padding: 60px 56px 40px;
    max-width: 880px;
    margin: 0 auto;
  }
  .back-link {
    font-size: 13px;
    color: var(--ink);
    opacity: 0.78;
    font-family: var(--font-mono);
    text-decoration: none;
  }
  .back-link::before { content: '← '; }
  :global(.article-header-content) {
    margin-top: 32px;
  }
  .article-meta-row {
    font-family: var(--font-mono);
    font-size: 12px;
    color: color-mix(in srgb, var(--ink) 78%, var(--bg));
    margin-bottom: 16px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  .meta-sep { opacity: 0.78; }
  .article-tag-inline {
    color: var(--accent-text);
    font-family: var(--font-mono);
  }
  /* h1 — handoff line 367: 72px display 1.02 -0.02em (was 56) */
  .article-title {
    font-size: 72px;
    line-height: 1.02;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  /* Excerpt — handoff line 368: 22 1.5 0.7 marginTop 24 display italic */
  .article-excerpt {
    font-size: 22px;
    line-height: 1.5;
    margin: 24px 0 0;
    opacity: 0.7;
    font-family: var(--font-display);
    font-style: italic;
  }

  /* ── Body — handoff 373: 24/56/80, max-width 760 ───────────────────── */
  .article-body {
    padding: 24px 56px 80px;
    max-width: 760px;
    margin: 0 auto;
  }
  /* Prose — handoff 376-378: h2 36/1.15, h3 24/1.2, p 18/1.7, NO drop cap */
  :global(.article-prose) {
    font-size: 18px;
    line-height: 1.7;
  }
  :global(.article-prose > :first-child) { margin-top: 0; }
  :global(.article-prose h2) {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 36px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 48px 0 16px;
    scroll-margin-top: 96px;
  }
  :global(.article-prose h3) {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.2;
    margin: 32px 0 12px;
    scroll-margin-top: 96px;
  }
  :global(.article-prose p) {
    margin: 0 0 20px;
  }
  :global(.article-prose strong) { font-weight: 600; }
  :global(.article-prose em) { font-style: italic; }
  :global(.article-prose code) {
    background: color-mix(in srgb, var(--ink) 7%, transparent);
    padding: 2px 7px;
    border-radius: 5px;
    border: 1px solid color-mix(in srgb, var(--ink) 8%, transparent);
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  :global(.article-prose pre) {
    background: var(--bg2);
    padding: 20px 22px;
    border-radius: var(--radius-card);
    border: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    overflow-x: auto;
    margin: 28px 0;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.5;
  }
  :global(.article-prose pre code) {
    background: transparent;
    padding: 0;
    border: 0;
    font-size: inherit;
  }
  :global(.article-prose blockquote) {
    border-left: 3px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
    padding: 12px 24px;
    margin: 32px 0;
    font-style: italic;
    font-size: 1.05em;
    opacity: 0.9;
  }
  :global(.article-prose blockquote p:last-child) { margin-bottom: 0; }
  /* Lists — accent markers, comfortable spacing, nested support. */
  :global(.article-prose ul), :global(.article-prose ol) {
    margin: 0 0 24px;
    padding-left: 26px;
  }
  :global(.article-prose ul) { list-style: square; }
  :global(.article-prose li) {
    margin: 8px 0;
    padding-left: 6px;
  }
  :global(.article-prose li::marker) {
    color: var(--accent);
    font-weight: 600;
  }
  :global(.article-prose ol li::marker) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  :global(.article-prose ul ul), :global(.article-prose ol ol),
  :global(.article-prose ul ol), :global(.article-prose ol ul) {
    margin: 8px 0;
  }
  :global(.article-prose a) {
    color: var(--accent-text);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  :global(.article-prose a:hover) { text-decoration-thickness: 2px; }
  :global(.article-prose img) {
    max-width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-card);
    margin: 28px 0;
  }
  :global(.article-prose hr) {
    border: 0;
    height: 1px;
    background: color-mix(in srgb, var(--ink) 14%, transparent);
    margin: 48px 0;
  }
  /* Tables — comparison/data tables in articles. Table element itself is the
     horizontal-scroll container (no wrapper markup from markdown) so wide
     tables scroll instead of overflowing the page on mobile. Zebra rows +
     tinted mono header for scannability. */
  :global(.article-prose table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 32px 0;
    font-size: 15px;
    line-height: 1.5;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: var(--radius-card);
  }
  :global(.article-prose thead tr) {
    border-bottom: 2px solid color-mix(in srgb, var(--ink) 20%, transparent);
  }
  :global(.article-prose th) {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
    padding: 12px 16px;
    white-space: nowrap;
    background: var(--bg2);
  }
  :global(.article-prose td) {
    padding: 11px 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    vertical-align: top;
  }
  :global(.article-prose tbody tr:nth-child(even)) {
    background: color-mix(in srgb, var(--ink) 3%, transparent);
  }
  :global(.article-prose tbody tr:hover) {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }
  :global(.article-prose tbody tr:last-child td) { border-bottom: none; }

  /* ── Share footer — handoff 383: marginTop 64, top border 1px ink22 ── */
  .article-share {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid color-mix(in srgb, var(--ink) 13%, transparent);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .share-author {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.78;
  }
  .share-links {
    display: flex;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .share-links a,
  .share-copy-btn {
    /* Darker accent variant for AA contrast on small mono share links. */
    color: var(--accent-text);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .share-copy-btn {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    cursor: pointer;
  }
  .share-links a:hover,
  .share-copy-btn:hover { opacity: 0.7; }

  /* ── Next article — handoff 394: 60/56, bg2, top border ink1f ──────── */
  .article-next {
    padding: 60px 56px;
    background: var(--bg2);
    border-top: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .next-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.78;
    margin-bottom: 16px;
  }
  .next-link {
    text-decoration: none;
    color: var(--ink);
    display: block;
  }
  .next-title {
    font-family: var(--font-display);
    font-size: 56px;
    line-height: 1.05;
    font-weight: 400;
    letter-spacing: -0.02em;
    max-width: 900px;
    margin: 0;
  }
  .next-arrow { color: var(--accent); }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .article-header { padding: 48px 32px 32px; }
    .article-body { padding: 24px 32px 64px; }
    .article-next { padding: 48px 32px; }
    .article-title { font-size: 56px; }
    .article-excerpt { font-size: 20px; }
    .next-title { font-size: 44px; }
  }
  @media (max-width: 768px) {
    .article-header { padding: 40px 20px 24px; max-width: 100%; }
    .article-body { padding: 16px 20px 56px; max-width: 100%; }
    .article-next { padding: 40px 20px; }
    .article-title { font-size: 40px; line-height: 1.05; }
    .article-excerpt { font-size: 18px; }
    :global(.article-prose) { font-size: 17px; }
    :global(.article-prose h2) { font-size: 28px; margin-top: 36px; }
    :global(.article-prose h3) { font-size: 20px; }
    .next-title { font-size: 32px; }
    .article-share { flex-direction: column; gap: 12px; }
  }
  @media (max-width: 480px) {
    .article-header { padding: 32px 16px 20px; }
    .article-body { padding: 12px 16px 40px; }
    .article-next { padding: 32px 16px; }
    .article-title { font-size: 32px; }
    .article-excerpt { font-size: 16px; }
    :global(.article-prose h2) { font-size: 24px; }
    .next-title { font-size: 26px; }
  }
</style>
