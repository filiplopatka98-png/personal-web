---
import { getRelativeLocaleUrl } from 'astro:i18n';
import '../styles/global.css';
const lang = 'sk';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preload" href="/personal-web/fonts/fraunces-variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/personal-web/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />
    <title>Filip Lopatka — Web Developer</title>
  </head>
  <body class="bg-bg text-text">
    <main class="max-w-content mx-auto px-6 py-16">
      <h1 class="font-serif">Filip Lopatka</h1>
      <p class="text-text-muted">Web developer / SK placeholder</p>
      <a href={getRelativeLocaleUrl('en', '')} class="hover:text-accent-hover">English version →</a>
    </main>
  </body>
</html>
