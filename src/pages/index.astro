---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Reveal from '../components/Reveal.astro';
import Marquee from '../components/Marquee.astro';
import HeroDefault from '../components/HeroDefault.astro';
import HeroMini from '../components/HeroMini.astro';
import HeroSwitcher from '../components/HeroSwitcher.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ExperienceList from '../components/ExperienceList.astro';
import TestimonialsBlock from '../components/TestimonialsBlock.astro';
import { t } from '../i18n';
import { getStaticRoute } from '../i18n/routes';

const lang = 'sk';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = (await getCollection('projects'))
  .filter((p) => p.slug.startsWith('sk/'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const articles = (await getCollection('articles'))
  .filter((a) => a.slug.startsWith('sk/'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---
<BaseLayout lang={lang} canonicalPath="/" altLangUrl="/en/">

  <section class="home-hero">
    <Reveal class="home-hero-toprow">
      <div class="mono small">01 — {t('home.intro', lang)}</div>
      <div class="mono small right">{t('home.locationCity', lang)}<br/>{t('home.locationTz', lang)}</div>
    </Reveal>

    {/* Two hero variants — switcher (HeroSwitcher, bottom-left) toggles between
        "Default" (generic intro) and "Live preview" (recent project showcase).
        Both render server-side; client JS hides the inactive one. */}
    <div data-hero-variant="default" class="hero-variant"><HeroDefault lang={lang} /></div>
    <div data-hero-variant="mini" class="hero-variant" style="display:none"><HeroMini lang={lang} /></div>

    <Reveal delay={0.2} class="home-hero-bottom">
      <p class="home-hero-lead">{t('home.intro.lead', lang)}</p>
      <div class="home-hero-ctas">
        <a href={`${baseUrl}${getStaticRoute('brief', lang)}`} data-cursor="hover" class="btn-primary">{t('cta.schedule', lang)} →</a>
      </div>
    </Reveal>
  </section>

  <Marquee lang={lang} />

  <section class="home-work">
    <Reveal class="section-header">
      <div>
        <div class="mono small">02 — {t('home.workEyebrow', lang)}</div>
        <h2 class="display">{t('home.workTitle', lang)}</h2>
      </div>
      <a href={`${baseUrl}${getStaticRoute('work', lang)}`} class="mono section-all" data-cursor="hover">{t('cta.allWork', lang)} →</a>
    </Reveal>
    <div class="work-grid">
      {projects.map((p) => (
        <Reveal>
          <ProjectCard entry={p} lang={lang} variant="home" />
        </Reveal>
      ))}
    </div>
  </section>

  <section class="home-about">
    <div class="about-grid">
      <Reveal>
        <div class="mono small">03 — {t('home.aboutEyebrow', lang)}</div>
        <h2 class="display about-headline">
          {t('home.aboutTitle.before', lang)} <em class="about-em">{t('home.aboutTitle.em', lang)}</em>{t('home.aboutTitle.after', lang)}
        </h2>
        <p class="about-lead">{t('home.aboutLead', lang)}</p>
      </Reveal>

      <Reveal delay={0.1}>
        <div class="mono small mb-6">04 — {t('home.experienceEyebrow', lang)}</div>
        <ExperienceList lang={lang} />
      </Reveal>
    </div>
  </section>

  <TestimonialsBlock lang={lang} />

  <section class="home-blog">
    <Reveal class="section-header">
      <div>
        <div class="mono small">06 — {t('home.journalEyebrow', lang)}</div>
        <h2 class="display blog-h2">{t('home.journalTitle', lang)}</h2>
      </div>
      <a href={`${baseUrl}${getStaticRoute('blog', lang)}`} class="mono section-all" data-cursor="hover">{t('cta.allArticles', lang)} →</a>
    </Reveal>
    <div class="blog-grid">
      {articles.map((a) => (
        <Reveal>
          <ArticleCard entry={a} lang={lang} />
        </Reveal>
      ))}
    </div>
  </section>

  <HeroSwitcher lang={lang} />

</BaseLayout>

<style>
  .home-hero { position: relative; padding: 120px 32px 56px; min-height: 600px; }
  :global(.home-hero-toprow) {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
    max-width: 1320px;
    margin-left: auto;
    margin-right: auto;
  }
  :global(.home-hero-toprow .right) { text-align: right; }
  .small {
    font-size: 13px;
    color: var(--ink-soft);
    font-family: var(--font-mono);
  }
  :global(.home-hero-bottom) {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: 48px;
    gap: 32px;
    flex-wrap: wrap;
    max-width: 1320px;
    margin-left: auto;
    margin-right: auto;
  }
  .home-hero-lead {
    max-width: 420px;
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
  }
  .home-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--accent) 78%, white) 0%,
      color-mix(in oklab, var(--accent) 92%, transparent) 100%);
    color: var(--ink-on-accent);
    border: 1px solid color-mix(in oklab, var(--accent) 60%, white 40%);
    padding: 13px 24px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    box-shadow:
      0 18px 36px -14px color-mix(in oklab, var(--accent) 70%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  .btn-ghost {
    background: var(--glass-fill-flat);
    color: var(--ink);
    border: 1px solid var(--glass-border);
    padding: 13px 24px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: inset 0 1px 0 var(--glass-highlight);
  }

  .home-work, .home-blog { padding: 64px 32px; }
  :global(.section-header) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 40px;
    gap: 24px;
    max-width: 1320px;
    margin-left: auto;
    margin-right: auto;
  }
  :global(.section-header .mono.small) { margin-bottom: 8px; }
  :global(.section-header h2) { font-size: 64px; line-height: 1; margin: 0; font-family: var(--font-display); color: var(--ink); }
  :global(.section-header .section-all) { font-size: 13px; white-space: nowrap; color: var(--ink); font-family: var(--font-mono); text-decoration: none; }
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 1320px;
    margin: 0 auto;
  }

  .home-about {
    padding: 64px 32px;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 56px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .about-headline {
    font-size: 56px;
    margin: 0 0 24px;
    line-height: 1.05;
    font-family: var(--font-display);
    color: var(--ink);
  }
  .about-em {
    color: var(--accent);
    font-style: italic;
    padding-left: 0.06em;
  }
  .about-lead {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 540px;
  }
  .mb-6 { margin-bottom: 24px; }

  .home-blog {}
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
    max-width: 1320px;
    margin: 0 auto;
  }
  :global(.section-header h2.blog-h2) { font-size: 48px; }

  @media (max-width: 1024px) {
    .home-hero { padding: 100px 24px 32px; }
    .home-work, .home-about, .home-blog { padding: 56px 24px; }
    :global(.section-header h2) { font-size: 52px; }
    :global(.section-header h2.blog-h2) { font-size: 44px; }
    .about-headline { font-size: 48px; }
    .blog-grid { grid-template-columns: 1fr 1fr; gap: 20px; }
    .about-grid { gap: 36px; }
    .work-grid { gap: 20px; }
    .home-hero-bottom { gap: 24px; }
  }

  @media (max-width: 768px) {
    .home-hero { padding: 90px 16px 24px; }
    .home-work, .home-about, .home-blog { padding: 48px 16px; }
    :global(.section-header h2) { font-size: 38px; }
    :global(.section-header h2.blog-h2) { font-size: 38px; }
    .work-grid, .about-grid, .blog-grid { grid-template-columns: 1fr; gap: 24px; }
    .about-headline { font-size: 40px; }
    :global(.home-hero-bottom) {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
  }

  @media (max-width: 480px) {
    .home-hero { padding: 80px 12px 20px; }
    .home-work, .home-about, .home-blog { padding: 40px 12px; }
    :global(.section-header h2) { font-size: 32px; }
    :global(.section-header h2.blog-h2) { font-size: 32px; }
    .about-headline { font-size: 36px; }
  }
</style>
