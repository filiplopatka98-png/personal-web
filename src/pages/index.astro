---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n';
---
<BaseLayout lang="sk" canonicalPath="/" altLangUrl="/en/">
  <section class="py-24">
    <p class="font-mono text-xs uppercase tracking-widest text-text-muted mb-6">
      Filip Lopatka — Web Developer
    </p>
    <h1 class="font-serif font-normal mb-6">
      {t('hero.title', 'sk')}
      <em class="text-text-muted">{t('hero.titleEm', 'sk')}</em>
    </h1>
    <p class="text-text-muted">
      Zatiaľ placeholder. Plnú homepage vyrobíme v Pláne 2.
    </p>
  </section>
</BaseLayout>
