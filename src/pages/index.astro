---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/Badge.astro';
import CTAButton from '../components/CTAButton.astro';
import GhostButton from '../components/GhostButton.astro';
import MarkHighlight from '../components/MarkHighlight.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Testimonial from '../components/Testimonial.astro';
import { t } from '../i18n';
import { getStaticRoute } from '../i18n/routes';

const lang = 'sk';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const services = (await getCollection('services'))
  .filter((s) => s.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const projects = (await getCollection('projects'))
  .filter((p) => p.data.lang === lang && p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);

const testimonials = (await getCollection('testimonials'))
  .filter((entry) => entry.data.lang === lang && entry.data.featured)
  .slice(0, 1);
---
<BaseLayout lang={lang} canonicalPath="/" altLangUrl="/en/">
  <!-- Hero -->
  <section class="py-20 md:py-28">
    <p class="font-mono text-xs uppercase tracking-widest text-text-muted mb-6">
      Filip Lopatka — Web Developer
    </p>
    <h1 class="font-serif font-normal mb-8 max-w-prose">
      Buduje weby, ktoré <MarkHighlight>prinášajú klientov</MarkHighlight>.
      <em class="text-text-muted block mt-2">WordPress, AI, frontend.</em>
    </h1>
    <div class="flex flex-wrap gap-4 items-center">
      <Badge>{t('common.availableForProjects', lang)}</Badge>
      <CTAButton href={`${baseUrl}${getStaticRoute('projects', lang)}`}>{t('hero.cta', lang)}</CTAButton>
      <GhostButton href={`${baseUrl}${getStaticRoute('contact', lang)}`}>{t('hero.ctaSecondary', lang)}</GhostButton>
    </div>
  </section>

  <!-- Services preview -->
  <section class="py-16 border-t border-border">
    <SectionHeader number="01" eyebrow={t('home.servicesEyebrow', lang)} title={t('services.title', lang)} />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      {services.map((entry) => <ServiceCard entry={entry} />)}
    </div>
    <GhostButton href={`${baseUrl}${getStaticRoute('services', lang)}`}>{t('home.servicesViewAll', lang)}</GhostButton>
  </section>

  <!-- Projects preview -->
  <section class="py-16 border-t border-border">
    <SectionHeader number="02" eyebrow={t('home.projectsEyebrow', lang)} title={t('projects.title', lang)} />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      {projects.map((entry) => <ProjectCard entry={entry} lang={lang} />)}
    </div>
    <GhostButton href={`${baseUrl}${getStaticRoute('projects', lang)}`}>{t('home.projectsViewAll', lang)}</GhostButton>
  </section>

  <!-- Testimonials preview -->
  {testimonials.length > 0 && (
    <section class="py-16 border-t border-border">
      <SectionHeader number="03" eyebrow={t('home.testimonialsEyebrow', lang)} />
      {testimonials.map((entry) => <Testimonial entry={entry} />)}
    </section>
  )}

  <!-- Contact CTA -->
  <section class="py-16 border-t border-border">
    <SectionHeader number="04" eyebrow={t('home.contactEyebrow', lang)} title={t('nav.contact', lang)} />
    <p class="text-lg max-w-prose mb-8">{t('home.contactBody', lang)}</p>
    <CTAButton href={`${baseUrl}${getStaticRoute('contact', lang)}`}>{t('home.contactCTA', lang)}</CTAButton>
  </section>
</BaseLayout>
