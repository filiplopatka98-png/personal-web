---
import '../styles/global.css';
import { t, type Lang } from '../i18n';

export interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  altLangUrl?: string;
  canonicalPath: string;
}

const { lang, title, description, altLangUrl, canonicalPath } = Astro.props;

const fullTitle = title ?? t('site.title', lang);
const fullDesc = description ?? t('site.description', lang);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${baseUrl}${canonicalPath}`;
---
<!doctype html>
<html lang={lang} data-theme="warm">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={fullDesc} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preload" href={`${baseUrl}/fonts/instrument-serif.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${baseUrl}/fonts/geist-regular.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
