---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import OverlayMenu from '../components/OverlayMenu.astro';
import CustomCursor from '../components/CustomCursor.astro';
import { t, type Lang } from '../i18n';
import { jsonLd } from '../utils/jsonld';

/**
 * 🔒 SITE-WIDE INDEXATION TOGGLE — pre-launch state.
 *
 * `false` → emits `<meta name="robots" content="noindex, nofollow">` on every
 * page so Google/Bing won't index pre-release content. robots.txt stays
 * permissive so crawlers can read the meta (without crawl access they'd
 * index the URL anyway with no description).
 *
 * **BEFORE PUBLIC LAUNCH:** flip this to `true`, rebuild, deploy. Then
 * submit sitemap in Search Console.
 *
 * Tracked in docs/superpowers/plans/2026-05-07-launch-roadmap.md → F0.
 */
const SITE_INDEXABLE = true as boolean;

export interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  altLangUrl?: string;
  /** Path of the current page for canonical (must start and end with `/`). */
  canonicalPath: string;
  /**
   * Path to OG image relative to baseUrl (e.g. "/og-default.png" or
   * "/og/projekt-tatra.png"). Defaults to /og-default.png.
   */
  ogImage?: string;
  /** Emit a page-level noindex (e.g. 404). Independent of the global SITE_INDEXABLE gate. */
  noindex?: boolean;
  /** Human-readable name for the final breadcrumb crumb (e.g. article/project title). */
  breadcrumbName?: string;
  /** og:type — 'website' (default) or 'article' for blog posts. */
  ogType?: 'website' | 'article';
  /** Article metadata; emitted as article:* OG tags when ogType==='article'. */
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
}

const {
  lang,
  title,
  description,
  altLangUrl,
  canonicalPath,
  ogImage,
  noindex = false,
  breadcrumbName,
  ogType = 'website',
  article,
} = Astro.props;

const fullTitle = title ?? t('site.title', lang);
const fullDesc = description ?? t('site.description', lang);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${baseUrl}${canonicalPath}`;
const altUrl = altLangUrl ? `${siteUrl}${baseUrl}${altLangUrl}` : null;
const skUrl = lang === 'sk' ? canonicalUrl : altUrl;
const enUrl = lang === 'en' ? canonicalUrl : altUrl;
const ogImageUrl = `${siteUrl}${baseUrl}${ogImage ?? '/og-default.png'}`;

// JSON-LD: Person schema (always inline)
const personId = `${siteUrl}${baseUrl}/#person`;
const orgId = `${siteUrl}${baseUrl}/#organization`;
const logoUrl = `${siteUrl}${baseUrl}/og-default.png`;
const postalAddress = {
  '@type': 'PostalAddress',
  addressLocality: 'Veľké Kostoľany',
  addressRegion: 'Trnavský kraj',
  addressCountry: 'SK',
};
const socialProfiles = [
  'https://www.linkedin.com/in/filip-lopatka-wordpress-dev/',
  'https://www.facebook.com/filip.lopatka98',
  'https://www.instagram.com/lopatkafilip/',
];

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': personId,
  name: 'Filip Lopatka',
  url: `${siteUrl}${baseUrl}/`,
  jobTitle: 'Web Developer',
  description: fullDesc,
  email: 'mailto:filip@lopatka.sk',
  telephone: '+421904902736',
  address: postalAddress,
  worksFor: { '@id': orgId },
  sameAs: socialProfiles,
  knowsAbout: ['WordPress', 'Next.js', 'React', 'Astro', 'WooCommerce', 'Performance', 'SEO'],
};

// JSON-LD: Organization — the freelance business behind the site (publisher of
// articles, E-E-A-T signal). Linked to the Person via founder/@id.
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': orgId,
  name: 'Filip Lopatka — Web Developer',
  url: `${siteUrl}${baseUrl}/`,
  logo: { '@type': 'ImageObject', url: logoUrl },
  image: logoUrl,
  description: fullDesc,
  email: 'mailto:filip@lopatka.sk',
  telephone: '+421904902736',
  address: postalAddress,
  areaServed: ['SK', 'CZ', 'AT', 'DE', 'Worldwide'],
  founder: { '@id': personId },
  sameAs: socialProfiles,
  knowsAbout: ['WordPress', 'WooCommerce', 'Next.js', 'Astro', 'Web Performance', 'Core Web Vitals', 'SEO'],
};

// Localized labels for known route segments — so breadcrumbs read "Práca"
// not "praca" and "Services" not "services" in SERPs / AI answers.
const SEGMENT_LABELS: Record<string, string> = {
  praca: 'Práca', work: 'Work',
  sluzby: 'Služby', services: 'Services',
  blog: 'Blog',
  ponuka: 'Ponuka', brief: 'Brief',
  'ochrana-osobnych-udajov': 'Ochrana osobných údajov', privacy: 'Privacy',
  impressum: 'Impressum', imprint: 'Imprint',
};

// JSON-LD: BreadcrumbList — built from canonicalPath segments (skip if root)
function buildBreadcrumbs(): unknown | null {
  const segments = canonicalPath.split('/').filter(Boolean);
  if (segments.length === 0) return null;
  const items: Array<Record<string, unknown>> = [
    { '@type': 'ListItem', position: 1, name: lang === 'sk' ? 'Domov' : 'Home', item: `${siteUrl}${baseUrl}/` },
  ];
  let pathSoFar = lang === 'sk' ? '' : '/en';
  const contentSegments = segments.filter((seg, i) => !(lang === 'en' && i === 0 && seg === 'en'));
  contentSegments.forEach((seg, i) => {
    pathSoFar += `/${seg}`;
    const isLeaf = i === contentSegments.length - 1;
    // Prefer an explicit human name for the leaf (article/project title);
    // otherwise a localized section label; otherwise de-slugify as a fallback.
    const name = (isLeaf && breadcrumbName)
      ? breadcrumbName
      : SEGMENT_LABELS[seg] ?? decodeURIComponent(seg).replace(/-/g, ' ');
    items.push({
      '@type': 'ListItem',
      position: items.length + 1,
      name,
      item: `${siteUrl}${baseUrl}${pathSoFar}/`,
    });
  });
  return { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: items };
}
const breadcrumbLd = buildBreadcrumbs();

// JSON-LD: WebSite (home only) — establishes site identity/name for search engines.
const isHome = canonicalPath === '/' || canonicalPath === '/en/';
const websiteLd = isHome
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Filip Lopatka',
      url: `${siteUrl}${baseUrl}/`,
      inLanguage: lang === 'sk' ? 'sk-SK' : 'en-US',
      publisher: { '@id': orgId },
    }
  : null;
---
<!doctype html>
<html lang={lang} data-theme="warm">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Security headers that work via <meta> (GitHub Pages can't send real HTTP
        headers). CSP mirrors the Cloudflare _headers policy minus frame-ancestors
        (meta-ignored). HSTS / X-Content-Type-Options / Permissions-Policy /
        frame-ancestors still require real headers → Cloudflare proxy. */}
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cloud.umami.is; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloud.umami.is https://api.web3forms.com; form-action 'self' https://api.web3forms.com; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={fullDesc} />

    {(!SITE_INDEXABLE || noindex) && (
      <meta name="robots" content={SITE_INDEXABLE ? 'noindex, follow' : 'noindex, nofollow'} />
    )}

    <link rel="canonical" href={canonicalUrl} />
    {skUrl && <link rel="alternate" hreflang="sk" href={skUrl} />}
    {enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {skUrl && <link rel="alternate" hreflang="x-default" href={skUrl} />}

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={fullDesc} />
    <meta property="og:type" content={ogType} />
    {ogType === 'article' && article && (
      <>
        {article.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
        {article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
        {/* OG spec: article:author is a profile URL, not a name. */}
        {article.author && <meta property="article:author" content={socialProfiles[0]} />}
        {article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === 'sk' ? 'sk_SK' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'sk' ? 'en_US' : 'sk_SK'} />
    <meta property="og:site_name" content="Filip Lopatka" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={fullDesc} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <link rel="preload" href={`${baseUrl}/fonts/instrument-serif.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${baseUrl}/fonts/geist-regular.woff2`} as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />

    {/* No-JS fallback: reveal-on-scroll elements start at opacity:0 and are
        shown by JS. Without JS they'd stay invisible, so force them visible
        (and skip the transform) when scripting is unavailable. */}
    <noscript set:html={`<style>[data-reveal]{opacity:1 !important;transform:none !important}</style>`}></noscript>

    <script is:inline type="application/ld+json" set:html={jsonLd(personLd)}></script>
    <script is:inline type="application/ld+json" set:html={jsonLd(organizationLd)}></script>
    {breadcrumbLd && (
      <script is:inline type="application/ld+json" set:html={jsonLd(breadcrumbLd)}></script>
    )}
    {websiteLd && (
      <script is:inline type="application/ld+json" set:html={jsonLd(websiteLd)}></script>
    )}
    <slot name="head" />

    {/* Umami — privacy-first, cookieless analytics (no consent banner needed).
        PROD-only so localhost/preview don't pollute stats; data-domains pins it
        to the live host. Auto-tracks pageviews incl. View Transitions navs via
        the History API. */}
    {import.meta.env.PROD && (
      <link rel="preconnect" href="https://cloud.umami.is" crossorigin />
    )}
    {import.meta.env.PROD && (
      <script
        is:inline
        defer
        src="https://cloud.umami.is/script.js"
        data-website-id="082f80b3-7d25-46e5-b47e-4a20bf11b4e8"
        data-domains="lopatka.sk"
      ></script>
    )}

    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('common.skipToContent', lang)}</a>
    <CustomCursor />
    <Nav lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <OverlayMenu lang={lang} altLangUrl={altLangUrl} />
  </body>
</html>
