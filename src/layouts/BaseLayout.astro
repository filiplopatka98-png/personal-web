---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t, type Lang } from '../i18n';

export interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  /**
   * URL of the equivalent page in the other language (for hreflang + LangSwitch).
   * If undefined, the switch is hidden (showing the other lang has no equivalent).
   */
  altLangUrl?: string;
  /** URL of the current page (for canonical). */
  canonicalPath: string;
}

const { lang, title, description, altLangUrl, canonicalPath } = Astro.props;

const fullTitle = title ?? t('site.title', lang);
const fullDesc = description ?? t('site.description', lang);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${baseUrl}${canonicalPath}`;
const altUrl = altLangUrl ? `${siteUrl}${baseUrl}${altLangUrl}` : null;
const skUrl = lang === 'sk' ? canonicalUrl : altUrl;
const enUrl = lang === 'en' ? canonicalUrl : altUrl;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={fullDesc} />

    <!-- Canonical + hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    {skUrl && <link rel="alternate" hreflang="sk" href={skUrl} />}
    {enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {skUrl && <link rel="alternate" hreflang="x-default" href={skUrl} />}

    <!-- OG -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={fullDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === 'sk' ? 'sk_SK' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={fullDesc} />

    <!-- Font preloads -->
    <link rel="preload" href={`${baseUrl}/fonts/fraunces-variable.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${baseUrl}/fonts/inter-variable.woff2`} as="font" type="font/woff2" crossorigin />

    <!-- Favicon (Astro CLI generated favicon.svg + .ico) -->
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
  </head>
  <body class="bg-bg text-text">
    <a class="skip-link" href="#main">{t('common.skipToContent', lang)}</a>
    <Header lang={lang} altLangUrl={altLangUrl} />
    <main id="main" class="max-w-content mx-auto px-6">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
