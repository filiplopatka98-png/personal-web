---
import { t, type Lang } from '../i18n';
import { getStaticRoute, type StaticRouteKey } from '../i18n/routes';

export interface Props {
  lang: Lang;
  /** URL of the equivalent page in the other language (full path including base). */
  altLangUrl?: string;
}

const { lang, altLangUrl } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = lang === 'sk' ? `${baseUrl}/` : `${baseUrl}/en/`;
const altUrl = altLangUrl ? `${baseUrl}${altLangUrl}` : null;
const otherLang = lang === 'sk' ? 'en' : 'sk';
const otherLangLabel = otherLang === 'en' ? 'English' : 'Slovenčina';

type NavItem = {
  key: 'home' | StaticRouteKey;
  tKey: 'nav.home' | 'nav.work' | 'nav.services' | 'nav.blog' | 'nav.brief';
  href: string;
};

const navOrder: NavItem[] = [
  { key: 'home',     tKey: 'nav.home',     href: homeHref },
  { key: 'work',     tKey: 'nav.work',     href: `${baseUrl}${getStaticRoute('work', lang)}` },
  { key: 'services', tKey: 'nav.services', href: `${baseUrl}${getStaticRoute('services', lang)}` },
  { key: 'blog',     tKey: 'nav.blog',     href: `${baseUrl}${getStaticRoute('blog', lang)}` },
  { key: 'brief',    tKey: 'nav.brief',    href: `${baseUrl}${getStaticRoute('brief', lang)}` },
];
---
<div
  id="overlay-menu"
  class="overlay-menu"
  role="dialog"
  aria-modal="true"
  aria-labelledby="overlay-menu-heading"
  aria-hidden="true"
  inert
  tabindex="-1"
>
  <h2 id="overlay-menu-heading" class="visually-hidden">{lang === 'sk' ? 'Hlavné menu' : 'Main menu'}</h2>
  <div class="overlay-menu-header">
    <div class="overlay-menu-brand">
      <div class="overlay-menu-logo">fl</div>
      filip lopatka
    </div>
    <button
      type="button"
      data-cursor="hover"
      data-menu-close
      aria-label={t('nav.closeMenu', lang)}
      class="glass glass-flat overlay-menu-close"
    >
      ✕ {t('nav.close', lang)}
    </button>
  </div>

  <div class="menu-grid">
    <div>
      <div class="menu-section-label">{t('menu.navigation', lang)}</div>
      {navOrder.map((item, i) => (
        <a
          href={item.href}
          class="menu-link"
          style={`--menu-link-delay: ${0.1 + i * 0.06}s;`}
          data-cursor="hover"
        >
          <span class="menu-link-num">0{i + 1}</span>
          {t(item.tKey, lang)}
        </a>
      ))}
    </div>

    <div class="menu-contact glass">
      <div class="menu-section-label">{t('menu.contact', lang)}</div>
      <div class="menu-links">
        <a data-cursor="hover" href={`mailto:${t('menu.email', lang)}`}>{t('menu.email', lang)} →</a>
        <a data-cursor="hover" href={t('menu.whatsappHref', lang)} target="_blank" rel="noopener noreferrer">WhatsApp {t('menu.whatsapp', lang)} →</a>
        <a data-cursor="hover" href={`https://${t('menu.linkedin', lang)}`} target="_blank" rel="noopener noreferrer">LinkedIn →</a>
        <a data-cursor="hover" href={`https://${t('menu.facebook', lang)}`} target="_blank" rel="noopener noreferrer">Facebook →</a>
        <a data-cursor="hover" href={`https://${t('menu.instagram', lang)}`} target="_blank" rel="noopener noreferrer">Instagram →</a>
      </div>

      {altUrl && (
        <div class="menu-lang">
          <a href={altUrl} data-cursor="hover">
            {otherLangLabel} →
          </a>
        </div>
      )}

      <div class="menu-location">
        {t('menu.location', lang)}
      </div>
    </div>
  </div>
</div>

<style>
  .overlay-menu {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(8, 4, 24, 0.55);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    color: var(--ink);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .overlay-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .overlay-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 32px;
  }

  .overlay-menu-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .overlay-menu-logo {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, var(--accent), color-mix(in oklab, var(--accent) 60%, white));
    border-radius: 8px;
    display: grid;
    place-items: center;
    color: var(--ink-on-accent);
    font-weight: 600;
  }

  .overlay-menu-close {
    padding: 10px 20px;
    border: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
  }

  .menu-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    padding: 40px 32px 56px;
    gap: 56px;
  }

  .menu-section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
    margin-bottom: 24px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .menu-link {
    display: block;
    font-family: var(--font-display);
    font-size: 96px;
    line-height: 1.05;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color 0.2s, opacity 0.5s ease, transform 0.5s ease;
    transition-delay: 0s, var(--menu-link-delay), var(--menu-link-delay);
    opacity: 0;
    transform: translateY(40px);
  }

  .overlay-menu.open .menu-link {
    opacity: 1;
    transform: translateY(0);
  }

  .menu-link:hover {
    color: var(--accent);
  }

  .menu-link-num {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--ink-soft);
    margin-right: 24px;
    vertical-align: middle;
  }

  .menu-contact {
    padding: 28px 32px;
    border-radius: 28px;
    align-self: start;
  }

  .menu-links {
    display: flex;
    flex-direction: column;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 14px;
  }

  .menu-links a {
    color: var(--ink);
    text-decoration: none;
  }

  .menu-lang {
    margin-top: 32px;
  }

  .menu-lang a {
    color: var(--ink);
    text-decoration: underline;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .menu-location {
    margin-top: 48px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .overlay-menu-header { padding: 18px 24px; }
    .menu-grid { padding: 32px 24px; gap: 32px; }
    .menu-link { font-size: 72px; }
  }

  @media (max-width: 768px) {
    .overlay-menu-header { padding: 14px 20px; }
    .menu-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 24px 20px;
    }
    .menu-link {
      font-size: 52px;
      line-height: 1.05;
    }
    .menu-link-num {
      font-size: 11px;
      margin-right: 12px;
    }
    .menu-contact {
      padding: 24px;
    }
  }

  @media (max-width: 480px) {
    .menu-link { font-size: 40px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-link {
      opacity: 1;
      transform: none;
      transition: color 0.2s;
    }
    .overlay-menu { transition: none; }
  }

  @media (prefers-reduced-transparency: reduce) {
    .overlay-menu {
      background: rgba(8, 4, 24, 0.92);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }
</style>

<script>
  function initOverlayMenu() {
    const menu = document.getElementById('overlay-menu');
    if (!menu) return;
    if ((menu as any).__overlayInitialized) return;
    (menu as any).__overlayInitialized = true;

    let lastFocused: HTMLElement | null = null;

    // Selector for "tabbable" descendants. Excludes negative tabindex and
    // disabled elements; intentionally simple — this menu has only links and
    // one button, so we don't need a full library-grade matcher.
    const focusableSelector =
      'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

    function getFocusable(): HTMLElement[] {
      return Array.from(menu!.querySelectorAll<HTMLElement>(focusableSelector))
        .filter((el) => !el.hasAttribute('hidden'));
    }

    function open() {
      lastFocused = (document.activeElement as HTMLElement | null) ?? null;
      menu!.classList.add('open');
      menu!.setAttribute('aria-hidden', 'false');
      // Remove `inert` so links inside become focusable + tabbable. This is
      // the modern alternative to manually toggling tabindex on each child;
      // also fixes Lighthouse "aria-hidden contains focusable descendants".
      menu!.removeAttribute('inert');
      document.body.style.overflow = 'hidden';
      // Defer to next frame so transition can start before we move focus.
      requestAnimationFrame(() => {
        const first = getFocusable()[0];
        first?.focus();
      });
    }

    function close() {
      menu!.classList.remove('open');
      menu!.setAttribute('aria-hidden', 'true');
      menu!.setAttribute('inert', '');
      document.body.style.overflow = '';
      // Restore focus to whatever opened the menu (typically the menu button).
      lastFocused?.focus();
      lastFocused = null;
    }

    function trapTab(e: KeyboardEvent) {
      if (e.key !== 'Tab') return;
      if (!menu!.classList.contains('open')) return;
      const focusable = getFocusable();
      if (focusable.length === 0) {
        e.preventDefault();
        return;
      }
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      const active = document.activeElement;
      if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      }
    }

    document.querySelectorAll('[data-menu-open]').forEach((btn) => {
      btn.addEventListener('click', open);
    });

    document.querySelectorAll('[data-menu-close]').forEach((btn) => {
      btn.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu!.classList.contains('open')) close();
      else trapTab(e);
    });

    menu!.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setTimeout(close, 0));
    });

    document.addEventListener('astro:before-swap', () => {
      document.body.style.overflow = '';
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initOverlayMenu);
  } else {
    initOverlayMenu();
  }
  document.addEventListener('astro:page-load', initOverlayMenu);
</script>
