---
/**
 * ScrollPhone — interactive iPhone mockup with scrollable content.
 *
 * Wraps a long full-page mobile screenshot (`<slug>-mobile-tall.png`,
 * generated by `npm run shots SLUG=URL::mobile-scroll`) inside an
 * HTML/CSS iPhone frame. Visitors scroll the captured page inside the
 * phone screen — gives a real sense of mobile UX.
 *
 * Visual contract: dimensions, gradients, border-radii and shadows are
 * intentionally a 1:1 port of the puppeteer-rendered phone mockup PNG
 * (`phoneMockupHtml` in scripts/build-project-screenshots.mjs), so a
 * scrollable phone next to a static one looks like the same device.
 *
 * Scroll affordance:
 *   - bottom fade gradient inside the screen suggests more content below
 *   - an animated chevron pulses at the bottom of the screen
 *   - both fade out once the user has scrolled inside the frame
 *   - `overscroll-behavior: contain` stops wheel scroll from leaking
 *     back to the page once content reaches an edge
 */
export interface Props {
  imageSrc: string;
  imageAlt: string;
  caption?: string;
}

const { imageSrc, imageAlt, caption } = Astro.props;
---
<figure class="scroll-phone">
  <div class="scroll-phone-shadow">
    <div class="phone-frame">
      <div class="phone-island"></div>
      <div class="phone-screen" tabindex="0" aria-label={imageAlt}>
        <img src={imageSrc} alt={imageAlt} class="phone-img" loading="lazy" decoding="async" />
      </div>
      <div class="phone-fade" aria-hidden="true"></div>
      <div class="phone-chevron" aria-hidden="true">
        <svg width="20" height="12" viewBox="0 0 20 12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="2,2 10,10 18,2" />
        </svg>
      </div>
    </div>
  </div>
  {caption && (
    <figcaption class="scroll-phone-caption mono">{caption}</figcaption>
  )}
</figure>

<style>
  .scroll-phone {
    margin: 0;
    display: block;
  }

  /* Outer wrapper takes the drop-shadow — applied here (not on the frame
     itself) so the shadow follows the rounded silhouette and looks
     identical to the static phone PNG mockup. */
  .scroll-phone-shadow {
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
    filter:
      drop-shadow(0 32px 50px rgba(20, 20, 20, 0.32))
      drop-shadow(0 6px 12px rgba(0, 0, 0, 0.18));
  }

  /* Phone proportions match puppeteer's phoneMockupHtml exactly:
     460×968 logical → aspect-ratio 460/968 ≈ 0.4752.
     Border-radius/padding/shadows mirror the PNG-baked frame so a
     ScrollPhone next to a static phone-PNG plate is visually consistent. */
  .phone-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 460 / 968;
    background: linear-gradient(135deg, #2a2a2a 0%, #161616 50%, #2a2a2a 100%);
    border-radius: 12.6%;
    padding: 3.04%;
    box-sizing: border-box;
    box-shadow:
      inset 0 0 0 1.5px rgba(255, 255, 255, 0.08),
      inset 0 0 0 4px #050505;
  }

  /* Dynamic island — sits on top of the screen image (z-index 2). */
  .phone-island {
    position: absolute;
    top: 2.89%;
    left: 50%;
    transform: translateX(-50%);
    width: 26.96%;
    height: 3.31%;
    background: #050505;
    border-radius: 999px;
    z-index: 2;
    pointer-events: none;
  }

  /* Inner screen — scrollable container.
     Inner border-radius matches puppeteer's 44px on a 432px-wide screen
     area (44/432 ≈ 10.2%, or ~9.57% of the 460px outer frame width). */
  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 9.57%;
    overflow-y: auto;
    overscroll-behavior: contain;
    background: #fff;
    -webkit-overflow-scrolling: touch;
    position: relative;
    /* Hide native scrollbar — the chevron + fade are the cue */
    scrollbar-width: none;
  }
  .phone-screen::-webkit-scrollbar {
    display: none;
  }
  .phone-screen:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .phone-img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Bottom fade overlay — sits inside the frame above the screen,
     does not scroll with content. Hints there's more below. */
  .phone-fade {
    position: absolute;
    left: 3.04%;
    right: 3.04%;
    bottom: 3.04%;
    height: 14%;
    pointer-events: none;
    z-index: 3;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.92) 85%);
    border-bottom-left-radius: 9.57%;
    border-bottom-right-radius: 9.57%;
    transition: opacity 0.4s ease;
  }

  /* Animated chevron pulse pointing down — fades after first scroll. */
  .phone-chevron {
    position: absolute;
    left: 50%;
    bottom: 6%;
    transform: translateX(-50%);
    color: var(--ink);
    opacity: 0.85;
    pointer-events: none;
    z-index: 4;
    animation: scroll-pulse 1.6s ease-in-out infinite;
    transition: opacity 0.4s ease;
  }
  .phone-chevron svg {
    display: block;
  }

  @keyframes scroll-pulse {
    0%, 100% { transform: translate(-50%, 0); opacity: 0.55; }
    50%      { transform: translate(-50%, 4px); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .phone-chevron { animation: none; opacity: 0.7; }
  }

  /* Both indicators fade out once user starts scrolling */
  .scroll-phone.scrolled .phone-fade,
  .scroll-phone.scrolled .phone-chevron {
    opacity: 0;
  }

  .scroll-phone-caption {
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
    text-align: center;
  }
</style>

<script>
  // Fade the scroll indicator once the user has scrolled inside any phone.
  document.querySelectorAll<HTMLElement>('.scroll-phone').forEach((root) => {
    const screen = root.querySelector<HTMLElement>('.phone-screen');
    if (!screen) return;
    let scrolled = false;
    screen.addEventListener('scroll', () => {
      if (scrolled) return;
      if (screen.scrollTop > 12) {
        scrolled = true;
        root.classList.add('scrolled');
      }
    }, { passive: true });
  });
</script>
