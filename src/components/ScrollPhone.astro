---
/**
 * ScrollPhone — interactive phone mockup with scrollable content.
 *
 * Wraps a long full-page mobile screenshot (`<slug>-mobile-tall.png`,
 * generated by `npm run shots SLUG=URL::mobile-scroll`) inside an
 * HTML/CSS iPhone-ish frame. Visitors can scroll the captured page
 * inside the phone screen — gives a real sense of mobile UX.
 *
 * Differs from `Plate` (which displays a static pre-rendered PNG with
 * the frame already baked in): here the frame is rendered live and the
 * inner scrollable area uses native overflow.
 *
 * `overscroll-behavior: contain` prevents wheel scroll from leaking back
 * to the page once the content reaches the top/bottom of the phone — but
 * after a brief pause the page scroll resumes naturally.
 */
export interface Props {
  imageSrc: string;
  imageAlt: string;
  caption?: string;
  /** Optional accent color for the frame outline glow. */
  accentColor?: string;
}

const { imageSrc, imageAlt, caption } = Astro.props;
---
<figure class="scroll-phone">
  <div class="phone-frame">
    <div class="phone-island"></div>
    <div class="phone-screen" tabindex="0" aria-label={imageAlt}>
      <img src={imageSrc} alt={imageAlt} class="phone-img" loading="lazy" decoding="async" />
    </div>
    <div class="phone-hint mono" aria-hidden="true">↕ scroll</div>
  </div>
  {caption && (
    <figcaption class="scroll-phone-caption mono">{caption}</figcaption>
  )}
</figure>

<style>
  .scroll-phone {
    margin: 0;
    display: block;
  }

  /* Phone proportions match the static phone mockup — iPhone 14 Pro-ish.
     Frame is sized via aspect-ratio so it scales fluidly with the column. */
  .phone-frame {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 460 / 968;
    margin: 0 auto;
    background: linear-gradient(135deg, #2a2a2a 0%, #161616 50%, #2a2a2a 100%);
    border-radius: 13.6%;
    padding: 3%;
    box-sizing: border-box;
    box-shadow:
      0 32px 50px rgba(20, 20, 20, 0.32),
      0 6px 12px rgba(0, 0, 0, 0.18),
      inset 0 0 0 1.5px rgba(255, 255, 255, 0.08),
      inset 0 0 0 4px #050505;
  }

  /* Dynamic island */
  .phone-island {
    position: absolute;
    top: 5%;
    left: 50%;
    transform: translateX(-50%);
    width: 27%;
    height: 3.4%;
    background: #050505;
    border-radius: 999px;
    z-index: 2;
    pointer-events: none;
  }

  /* Inner screen — scrollable container */
  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 9.5%;
    overflow-y: auto;
    overscroll-behavior: contain;
    background: #fff;
    -webkit-overflow-scrolling: touch;
    position: relative;
    /* Hide native scrollbar — visual cue is the hint label below */
    scrollbar-width: none;
  }
  .phone-screen::-webkit-scrollbar {
    display: none;
  }
  .phone-screen:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .phone-img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Hint label that fades after first scroll */
  .phone-hint {
    position: absolute;
    bottom: -28px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: opacity 0.4s ease;
  }
  .scroll-phone.scrolled .phone-hint {
    opacity: 0;
  }

  .scroll-phone-caption {
    margin-top: 36px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }
</style>

<script>
  // Fade the "↕ scroll" hint once the user has scrolled inside any phone.
  document.querySelectorAll<HTMLElement>('.scroll-phone').forEach((root) => {
    const screen = root.querySelector<HTMLElement>('.phone-screen');
    if (!screen) return;
    let scrolled = false;
    screen.addEventListener('scroll', () => {
      if (scrolled) return;
      if (screen.scrollTop > 12) {
        scrolled = true;
        root.classList.add('scrolled');
      }
    }, { passive: true });
  });
</script>
