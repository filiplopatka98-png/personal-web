---
import { t, type Lang } from '../i18n';

export interface Props {
  currentLang: Lang;
  altLangUrl?: string;
}

const { currentLang, altLangUrl } = Astro.props;
const otherLang: Lang = currentLang === 'sk' ? 'en' : 'sk';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = altLangUrl ? `${baseUrl}${altLangUrl}` : null;
const label = otherLang === 'en' ? t('lang.switch.toEN', currentLang) : t('lang.switch.toSK', currentLang);
---
{href ? (
  <a href={href} class="font-mono text-xs uppercase tracking-wider hover:text-accent-hover" hreflang={otherLang} aria-label={label}>
    {otherLang.toUpperCase()}
  </a>
) : (
  <span class="font-mono text-xs uppercase tracking-wider opacity-40" aria-label={t('lang.switch.notAvailable', currentLang)}>
    {otherLang.toUpperCase()}
  </span>
)}
