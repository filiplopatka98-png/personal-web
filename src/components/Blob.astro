---
export interface Props {
  /** Background color (typically var(--accent), var(--accent2), var(--accent3)). */
  color: string;
  /** Size in px (default 240). */
  size?: number;
  /** Position — partial CSS (e.g. "top: -40px; right: -40px"). Provide as one CSS property string, with trailing semicolon. */
  position?: string;
  /** Animation delay in seconds (-0.5 to 5, allows negative for varied phase). */
  delay?: number;
}

const { color, size = 240, position = '', delay = 0 } = Astro.props;
const delayStr = delay !== 0 ? `animation-delay:${delay}s;` : '';
const styleStr = `width:${size}px;height:${size}px;background:${color};${position}${delayStr}`;
---
<div class="blob" style={styleStr} aria-hidden="true"></div>
