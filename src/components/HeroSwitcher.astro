---
/**
 * Hero variant switcher — production feature (NOT temporary).
 *
 * Renders a small floating panel with 2 chips so Filip can switch the home-page
 * hero variant depending on context: "Default" (generic intro) vs "Live preview"
 * (concrete recent project showcase). Selection persists in localStorage so the
 * choice survives reloads.
 *
 * The dismiss × collapses to a small reopen pill (the choice still applies).
 */
import { type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const variants: Array<{ id: string; label: string }> =
  lang === 'sk'
    ? [
        { id: 'default', label: 'Default' },
        { id: 'mini', label: 'Live preview' },
      ]
    : [
        { id: 'default', label: 'Default' },
        { id: 'mini', label: 'Live preview' },
      ];
---
<aside class="hero-switcher" aria-label={lang === 'sk' ? 'Prepínač hero variantov' : 'Hero variant switcher'}>
  <div class="hero-switcher-label mono">{lang === 'sk' ? 'Hero variant' : 'Hero variant'}</div>
  <div class="hero-switcher-chips" role="radiogroup">
    {variants.map((v) => (
      <button
        type="button"
        role="radio"
        aria-checked={v.id === 'default' ? 'true' : 'false'}
        data-variant={v.id}
        class:list={['hero-switcher-chip', 'mono', v.id === 'default' && 'is-active']}
        data-cursor="hover"
      >
        {v.label}
      </button>
    ))}
  </div>
  <button
    type="button"
    class="hero-switcher-close mono"
    aria-label={lang === 'sk' ? 'Skryť prepínač' : 'Hide switcher'}
    data-switcher-close
    data-cursor="hover"
  >×</button>
</aside>

{/* Tiny floating button shown when the switcher is collapsed. Click reopens. */}
<button
  type="button"
  class="hero-switcher-reopen mono"
  aria-label={lang === 'sk' ? 'Zobraziť prepínač hero variantov' : 'Show hero variant switcher'}
  data-switcher-reopen
  data-cursor="hover"
  hidden
>
  <span class="hero-switcher-reopen-icon" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
  </span>
  hero
</button>

<style>
  .hero-switcher {
    position: fixed;
    left: 16px;
    bottom: 16px;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px 10px 16px;
    background: color-mix(in srgb, var(--ink) 92%, transparent);
    color: var(--bg);
    border-radius: var(--radius-pill);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-family: var(--font-mono);
    /* Hidden by default; revealed by JS once localStorage hydration runs to
       avoid a flash on first paint. */
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .hero-switcher.is-ready {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-switcher.is-hidden {
    display: none;
  }

  .hero-switcher-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.55;
    white-space: nowrap;
  }

  .hero-switcher-chips {
    display: flex;
    gap: 4px;
    background: color-mix(in srgb, var(--bg) 12%, transparent);
    border-radius: var(--radius-pill);
    padding: 3px;
  }

  .hero-switcher-chip {
    appearance: none;
    background: transparent;
    color: inherit;
    border: 0;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }
  .hero-switcher-chip:hover:not(.is-active) {
    background: color-mix(in srgb, var(--bg) 18%, transparent);
  }
  .hero-switcher-chip.is-active {
    background: var(--accent);
    color: var(--ink);
  }

  .hero-switcher-close {
    appearance: none;
    background: transparent;
    color: inherit;
    border: 0;
    padding: 4px 6px;
    margin-left: 2px;
    font-family: inherit;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    opacity: 0.55;
    transition: opacity 0.15s ease;
  }
  .hero-switcher-close:hover {
    opacity: 1;
  }

  /* ── Reopen pill (shown when panel is collapsed) ─────────────────────── */
  .hero-switcher-reopen {
    position: fixed;
    left: 16px;
    bottom: 16px;
    z-index: 1000;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px 8px 12px;
    appearance: none;
    background: color-mix(in srgb, var(--ink) 92%, transparent);
    color: var(--bg);
    border: 0;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0.85;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .hero-switcher-reopen:hover {
    opacity: 1;
    transform: translateY(-1px);
  }
  .hero-switcher-reopen[hidden] {
    display: none;
  }

  /* 4 small bars suggesting "4 variants" inside the icon. */
  .hero-switcher-reopen-icon {
    display: inline-grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    width: 12px;
    height: 12px;
  }
  .hero-switcher-reopen-icon > span {
    background: var(--accent);
    border-radius: 1px;
  }

  @media (max-width: 640px) {
    .hero-switcher {
      left: 12px;
      right: 12px;
      bottom: 12px;
      justify-content: space-between;
      padding: 8px 12px;
    }
    .hero-switcher-label {
      display: none;
    }
    .hero-switcher-chip {
      font-size: 10px;
      padding: 6px 10px;
    }
    .hero-switcher-reopen {
      left: 12px;
      bottom: 12px;
    }
  }
</style>

<script>
  /**
   * Hero variant switcher logic.
   *
   * Source of truth: localStorage['heroVariant']. Falls back to 'default'.
   * Apply: hide all .hero-variant wrappers except the matching one, sync chip
   * is-active state.
   *
   * Survives Astro view transitions via the `astro:page-load` event; the panel
   * is also hidden in localStorage['heroSwitcherHidden'] === '1' if the user
   * dismissed it (one-shot, until they reset localStorage).
   */
  type Variant = 'default' | 'mini';
  const STORAGE_KEY = 'heroVariant';
  const HIDDEN_KEY = 'heroSwitcherHidden';
  const VALID: Variant[] = ['default', 'mini'];

  function readVariant(): Variant {
    try {
      const v = localStorage.getItem(STORAGE_KEY);
      return (VALID as string[]).includes(v ?? '') ? (v as Variant) : 'default';
    } catch {
      return 'default';
    }
  }

  function applyVariant(v: Variant) {
    document.querySelectorAll<HTMLElement>('[data-hero-variant]').forEach((el) => {
      const isActive = el.dataset.heroVariant === v;
      el.style.display = isActive ? '' : 'none';
      if (isActive) {
        // IntersectionObserver doesn't re-observe elements that flip from
        // display:none to block, so any [data-reveal] inside a freshly-shown
        // variant would stay opacity:0. Force them visible.
        el.querySelectorAll<HTMLElement>('[data-reveal]').forEach((r) => {
          r.classList.add('visible');
        });
      }
    });
    document.querySelectorAll<HTMLButtonElement>('.hero-switcher-chip').forEach((chip) => {
      const on = chip.dataset.variant === v;
      chip.classList.toggle('is-active', on);
      chip.setAttribute('aria-checked', on ? 'true' : 'false');
    });
  }

  function showPanel(panel: HTMLElement, reopen: HTMLButtonElement | null) {
    panel.classList.remove('is-hidden');
    requestAnimationFrame(() => panel.classList.add('is-ready'));
    if (reopen) reopen.hidden = true;
  }

  function hidePanel(panel: HTMLElement, reopen: HTMLButtonElement | null) {
    panel.classList.remove('is-ready');
    panel.classList.add('is-hidden');
    if (reopen) reopen.hidden = false;
  }

  function initSwitcher() {
    const panel = document.querySelector<HTMLElement>('.hero-switcher');
    const reopen = document.querySelector<HTMLButtonElement>('[data-switcher-reopen]');
    if (!panel) return;

    // Always apply the stored variant to the page so the user's choice
    // survives across reloads regardless of panel visibility.
    applyVariant(readVariant());

    // Honor previous "hide" choice — show only the small reopen pill.
    let hidden = false;
    try { hidden = localStorage.getItem(HIDDEN_KEY) === '1'; } catch { /* ignore */ }
    if (hidden) {
      panel.classList.add('is-hidden');
      if (reopen) reopen.hidden = false;
    } else {
      requestAnimationFrame(() => panel.classList.add('is-ready'));
    }

    panel.querySelectorAll<HTMLButtonElement>('.hero-switcher-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const v = (chip.dataset.variant as Variant) || 'default';
        try { localStorage.setItem(STORAGE_KEY, v); } catch { /* ignore */ }
        applyVariant(v);
      });
    });

    const closeBtn = panel.querySelector<HTMLButtonElement>('[data-switcher-close]');
    closeBtn?.addEventListener('click', () => {
      try { localStorage.setItem(HIDDEN_KEY, '1'); } catch { /* ignore */ }
      hidePanel(panel, reopen);
    });

    reopen?.addEventListener('click', () => {
      try { localStorage.removeItem(HIDDEN_KEY); } catch { /* ignore */ }
      showPanel(panel, reopen);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSwitcher);
  } else {
    initSwitcher();
  }
  document.addEventListener('astro:page-load', initSwitcher);
</script>
