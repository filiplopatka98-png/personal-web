---
/**
 * Hero variant switcher (TEMPORARY — remove before final launch).
 *
 * Renders a small floating panel with 4 chips so the user can preview each hero
 * variant on the home page. Selection persists in localStorage('heroVariant').
 *
 * To remove: delete this component, remove its <HeroSwitcher /> usage from
 * src/pages/index.astro and src/pages/en/index.astro, and pick ONE of the four
 * <div class="hero-variant" data-hero-variant="X"> wrappers in those files
 * (delete the other three).
 */
import { type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const variants: Array<{ id: string; label: string }> =
  lang === 'sk'
    ? [
        { id: 'default', label: 'Default' },
        { id: 'portrait', label: 'Portrét' },
        { id: 'mini', label: 'Live preview' },
        { id: 'now', label: 'Now playing' },
      ]
    : [
        { id: 'default', label: 'Default' },
        { id: 'portrait', label: 'Portrait' },
        { id: 'mini', label: 'Live preview' },
        { id: 'now', label: 'Now playing' },
      ];
---
<aside class="hero-switcher" aria-label={lang === 'sk' ? 'Prepínač hero variantov' : 'Hero variant switcher'}>
  <div class="hero-switcher-label mono">{lang === 'sk' ? 'Hero variant' : 'Hero variant'}</div>
  <div class="hero-switcher-chips" role="radiogroup">
    {variants.map((v) => (
      <button
        type="button"
        role="radio"
        aria-checked={v.id === 'default' ? 'true' : 'false'}
        data-variant={v.id}
        class:list={['hero-switcher-chip', 'mono', v.id === 'default' && 'is-active']}
        data-cursor="hover"
      >
        {v.label}
      </button>
    ))}
  </div>
  <button
    type="button"
    class="hero-switcher-close mono"
    aria-label={lang === 'sk' ? 'Skryť prepínač' : 'Hide switcher'}
    data-switcher-close
    data-cursor="hover"
  >×</button>
</aside>

<style>
  .hero-switcher {
    position: fixed;
    left: 16px;
    bottom: 16px;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px 10px 16px;
    background: color-mix(in srgb, var(--ink) 92%, transparent);
    color: var(--bg);
    border-radius: var(--radius-pill);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-family: var(--font-mono);
    /* Hidden by default; revealed by JS once localStorage hydration runs to
       avoid a flash on first paint. */
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .hero-switcher.is-ready {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-switcher.is-hidden {
    display: none;
  }

  .hero-switcher-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.55;
    white-space: nowrap;
  }

  .hero-switcher-chips {
    display: flex;
    gap: 4px;
    background: color-mix(in srgb, var(--bg) 12%, transparent);
    border-radius: var(--radius-pill);
    padding: 3px;
  }

  .hero-switcher-chip {
    appearance: none;
    background: transparent;
    color: inherit;
    border: 0;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }
  .hero-switcher-chip:hover:not(.is-active) {
    background: color-mix(in srgb, var(--bg) 18%, transparent);
  }
  .hero-switcher-chip.is-active {
    background: var(--accent);
    color: var(--ink);
  }

  .hero-switcher-close {
    appearance: none;
    background: transparent;
    color: inherit;
    border: 0;
    padding: 4px 6px;
    margin-left: 2px;
    font-family: inherit;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    opacity: 0.55;
    transition: opacity 0.15s ease;
  }
  .hero-switcher-close:hover {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .hero-switcher {
      left: 12px;
      right: 12px;
      bottom: 12px;
      justify-content: space-between;
      padding: 8px 12px;
    }
    .hero-switcher-label {
      display: none;
    }
    .hero-switcher-chip {
      font-size: 10px;
      padding: 6px 10px;
    }
  }
</style>

<script>
  /**
   * Hero variant switcher logic.
   *
   * Source of truth: localStorage['heroVariant']. Falls back to 'default'.
   * Apply: hide all .hero-variant wrappers except the matching one, sync chip
   * is-active state.
   *
   * Survives Astro view transitions via the `astro:page-load` event; the panel
   * is also hidden in localStorage['heroSwitcherHidden'] === '1' if the user
   * dismissed it (one-shot, until they reset localStorage).
   */
  type Variant = 'default' | 'portrait' | 'mini' | 'now';
  const STORAGE_KEY = 'heroVariant';
  const HIDDEN_KEY = 'heroSwitcherHidden';
  const VALID: Variant[] = ['default', 'portrait', 'mini', 'now'];

  function readVariant(): Variant {
    try {
      const v = localStorage.getItem(STORAGE_KEY);
      return (VALID as string[]).includes(v ?? '') ? (v as Variant) : 'default';
    } catch {
      return 'default';
    }
  }

  function applyVariant(v: Variant) {
    document.querySelectorAll<HTMLElement>('[data-hero-variant]').forEach((el) => {
      const isActive = el.dataset.heroVariant === v;
      el.style.display = isActive ? '' : 'none';
      if (isActive) {
        // IntersectionObserver doesn't re-observe elements that flip from
        // display:none to block, so any [data-reveal] inside a freshly-shown
        // variant would stay opacity:0. Force them visible.
        el.querySelectorAll<HTMLElement>('[data-reveal]').forEach((r) => {
          r.classList.add('visible');
        });
      }
    });
    document.querySelectorAll<HTMLButtonElement>('.hero-switcher-chip').forEach((chip) => {
      const on = chip.dataset.variant === v;
      chip.classList.toggle('is-active', on);
      chip.setAttribute('aria-checked', on ? 'true' : 'false');
    });
  }

  function initSwitcher() {
    const panel = document.querySelector<HTMLElement>('.hero-switcher');
    if (!panel) return;

    // Honor previous "hide forever" choice.
    let hidden = false;
    try { hidden = localStorage.getItem(HIDDEN_KEY) === '1'; } catch { /* ignore */ }
    if (hidden) {
      panel.classList.add('is-hidden');
      // Still apply stored variant so the page reflects the user's choice.
      applyVariant(readVariant());
      return;
    }

    applyVariant(readVariant());
    // Reveal the panel after first paint (avoids opacity-0 flash competing
    // with the rest of the page mount).
    requestAnimationFrame(() => panel.classList.add('is-ready'));

    panel.querySelectorAll<HTMLButtonElement>('.hero-switcher-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const v = (chip.dataset.variant as Variant) || 'default';
        try { localStorage.setItem(STORAGE_KEY, v); } catch { /* ignore */ }
        applyVariant(v);
      });
    });

    const closeBtn = panel.querySelector<HTMLButtonElement>('[data-switcher-close]');
    closeBtn?.addEventListener('click', () => {
      try { localStorage.setItem(HIDDEN_KEY, '1'); } catch { /* ignore */ }
      panel.classList.add('is-hidden');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSwitcher);
  } else {
    initSwitcher();
  }
  document.addEventListener('astro:page-load', initSwitcher);
</script>
