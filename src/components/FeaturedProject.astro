---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { t, type Lang } from '../i18n';

export interface Props {
  entry: CollectionEntry<'projects'>;
  lang: Lang;
}
const { entry, lang } = Astro.props;
const { data } = entry;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const detailHref = lang === 'sk'
  ? `${baseUrl}/projekty/${entry.slug}/`
  : `${baseUrl}/en/projects/${entry.slug}/`;
---
<section class="bg-[#1a1a1a] text-white py-16 px-10 -mx-6">
  <div class="max-w-extra mx-auto">
    <div class="font-mono text-[11px] uppercase tracking-widest text-accent mb-7">
      {t('featured.eyebrow', lang)}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h3 class="font-serif text-4xl font-normal leading-tight mb-5">
          {data.title}
        </h3>
        <p class="text-base leading-relaxed text-[#ccc] mb-7 max-w-md">{data.excerpt}</p>
        <div class="flex flex-wrap gap-7 mb-7 font-mono text-[11px] uppercase tracking-widest text-[#888]">
          {data.client && (
            <div>
              {t('projects.client.label', lang)}
              <strong class="block font-serif text-sm tracking-normal normal-case text-accent font-normal mt-0.5">{data.client}</strong>
            </div>
          )}
          {data.year && (
            <div>
              {t('projects.year.label', lang)}
              <strong class="block font-serif text-sm tracking-normal normal-case text-accent font-normal mt-0.5">{data.year}</strong>
            </div>
          )}
          {data.tags.length > 0 && (
            <div>
              {t('projects.tags.label', lang)}
              <strong class="block font-serif text-sm tracking-normal normal-case text-accent font-normal mt-0.5">{data.tags.slice(0, 2).join(' · ')}</strong>
            </div>
          )}
        </div>
        <a href={detailHref} class="font-mono text-xs uppercase tracking-widest text-accent link-underline">
          {t('featured.read', lang)} →
        </a>
      </div>
      <div class="rounded overflow-hidden">
        <Image
          src={data.cover}
          alt={data.title}
          widths={[640, 1280]}
          sizes="(max-width: 768px) 100vw, 50vw"
          class="w-full h-auto block"
        />
      </div>
    </div>
  </div>
</section>
