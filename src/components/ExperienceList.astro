---
import { type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const experience = lang === 'sk' ? [
  {
    years: 'Mar 2025 — dnes',
    role: 'Freelance Web Developer',
    desc: 'Samostatný freelance, remote. Weby a eshopy pre slovenských a českých klientov.',
  },
  {
    years: 'Jún 2022 — Mar 2025',
    role: 'WordPress Developer · Brain:IT',
    desc: 'Bratislava, full-time. WordPress, WooCommerce, custom témy, performance a SEO.',
  },
  {
    years: 'Jún 2020 — Máj 2022',
    role: 'Junior WordPress Developer · Visitero',
    desc: 'Žilina, part-time. PHP, WordPress, prvé klientské projekty.',
  },
] : [
  {
    years: 'Mar 2025 — present',
    role: 'Freelance Web Developer',
    desc: 'Solo freelance, remote. Sites and e-shops for SK/CZ clients.',
  },
  {
    years: 'Jun 2022 — Mar 2025',
    role: 'WordPress Developer · Brain:IT',
    desc: 'Bratislava, full-time. WordPress, WooCommerce, custom themes, performance & SEO.',
  },
  {
    years: 'Jun 2020 — May 2022',
    role: 'Junior WordPress Developer · Visitero',
    desc: 'Žilina, part-time. PHP, WordPress, first client projects.',
  },
];
---
<div class="exp-list">
  {experience.map((row) => (
    <div class="exp-row">
      <div class="exp-years mono">{row.years}</div>
      <div>
        <div class="exp-role">{row.role}</div>
        <div class="exp-desc">{row.desc}</div>
      </div>
    </div>
  ))}
</div>

<style>
  .exp-list { display: flex; flex-direction: column; }
  .exp-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 24px;
    padding: 20px 0;
    border-top: 1px solid color-mix(in srgb, var(--ink) 22%, transparent);
  }
  .exp-years { font-size: 12px; opacity: 0.6; font-family: var(--font-mono); }
  .exp-role { font-weight: 500; font-size: 17px; }
  .exp-desc { font-size: 14px; opacity: 0.7; margin-top: 4px; }
  @media (max-width: 768px) {
    .exp-row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
