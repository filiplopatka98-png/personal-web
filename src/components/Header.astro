---
import { t, type Lang } from '../i18n';
import { getStaticRoute, type StaticRouteKey } from '../i18n/routes';
import LangSwitch from './LangSwitch.astro';
import MobileMenu from './MobileMenu.astro';

export interface Props {
  lang: Lang;
  altLangUrl?: string;
}

const { lang, altLangUrl } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const navOrder: { key: StaticRouteKey; tKey: 'nav.work' | 'nav.services' | 'nav.blog' | 'nav.brief' }[] = [
  { key: 'work',     tKey: 'nav.work' },
  { key: 'services', tKey: 'nav.services' },
  { key: 'blog',     tKey: 'nav.blog' },
  { key: 'brief',    tKey: 'nav.brief' },
];

const homeHref = lang === 'sk' ? '/' : '/en/';
---
<header class="border-b border-border">
  <div class="max-w-content mx-auto px-6 py-5 flex items-center justify-between gap-6">
    <a href={`${baseUrl}${homeHref}`} class="font-serif text-xl no-underline" aria-label={t('site.title', lang)}>
      Filip Lopatka
    </a>

    {/* Desktop nav (md+) */}
    <nav aria-label="Primary" class="hidden md:flex items-center gap-6">
      {navOrder.map((item) => (
        <a
          href={`${baseUrl}${getStaticRoute(item.key, lang)}`}
          class="text-xs uppercase tracking-wider hover:text-accent-hover no-underline"
        >
          {t(item.tKey, lang)}
        </a>
      ))}
      <LangSwitch currentLang={lang} altLangUrl={altLangUrl} />
    </nav>

    {/* Mobile menu (sub-md) */}
    <MobileMenu lang={lang} altLangUrl={altLangUrl} />
  </div>
</header>
