---
import { t, type Lang } from '../i18n';
import { getStaticRoute, type StaticRouteKey } from '../i18n/routes';
import LangSwitch from './LangSwitch.astro';

export interface Props {
  lang: Lang;
  altLangUrl?: string;
}

const { lang, altLangUrl } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const navOrder: { key: StaticRouteKey; tKey: 'nav.about' | 'nav.services' | 'nav.projects' | 'nav.blog' | 'nav.contact' }[] = [
  { key: 'about',    tKey: 'nav.about' },
  { key: 'services', tKey: 'nav.services' },
  { key: 'projects', tKey: 'nav.projects' },
  { key: 'blog',     tKey: 'nav.blog' },
  { key: 'contact',  tKey: 'nav.contact' },
];

const homeHref = lang === 'sk' ? '/' : '/en/';
---
<header class="border-b border-border">
  <div class="max-w-content mx-auto px-6 py-5 flex flex-wrap items-center justify-between gap-x-6 gap-y-3">
    <a href={`${baseUrl}${homeHref}`} class="font-serif text-xl no-underline" aria-label={t('site.title', lang)}>
      Filip Lopatka
    </a>
    <nav aria-label="Primary" class="flex flex-wrap items-center gap-x-6 gap-y-2">
      {navOrder.map((item) => (
        <a
          href={`${baseUrl}${getStaticRoute(item.key, lang)}`}
          class="text-xs uppercase tracking-wider hover:text-accent-hover no-underline"
        >
          {t(item.tKey, lang)}
        </a>
      ))}
      <LangSwitch currentLang={lang} altLangUrl={altLangUrl} />
    </nav>
  </div>
</header>
