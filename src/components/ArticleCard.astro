---
import type { CollectionEntry } from 'astro:content';
import { t, type Lang } from '../i18n';

export interface Props {
  entry: CollectionEntry<'articles'>;
  lang: Lang;
}
const { entry, lang } = Astro.props;
const { data } = entry;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const cleanSlug = entry.slug.replace(/^(sk|en)\//, '');
const detailHref = lang === 'sk'
  ? `${baseUrl}/blog/${cleanSlug}/`
  : `${baseUrl}/en/blog/${cleanSlug}/`;

const fmt = new Intl.DateTimeFormat(lang === 'sk' ? 'sk-SK' : 'en-US', {
  month: 'short',
  year: 'numeric',
});
const dateStr = fmt.format(data.date);
const readStr = lang === 'sk' ? `${data.read} min čítania` : `${data.read} min read`;
---
<a href={detailHref} class="article-card" data-cursor="hover">
  <div class="article-meta mono">
    <span>{dateStr}</span>
    <span>{readStr}</span>
  </div>
  <div class="article-title display">{data.title}</div>
  <div class="article-cta mono">{t('cta.read', lang)} →</div>
</a>

<style>
  .article-card {
    border-top: 1px solid color-mix(in srgb, var(--ink) 33%, transparent);
    padding-top: 16px;
    display: block;
    text-decoration: none;
    color: var(--ink);
  }

  .article-meta {
    font-size: 12px;
    opacity: 0.75;
    display: flex;
    justify-content: space-between;
    margin-bottom: 16px;
    font-family: var(--font-mono);
  }

  .article-title {
    font-size: 24px;
    line-height: 1.15;
    font-family: var(--font-display);
  }

  .article-cta {
    font-size: 12px;
    margin-top: 24px;
    /* Solid darker variant for AA contrast on small mono CTA. */
    color: var(--accent-text);
    font-family: var(--font-mono);
  }
</style>
