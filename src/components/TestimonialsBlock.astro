---
import Reveal from './Reveal.astro';
import Blob from './Blob.astro';
import { t, type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const testimonials = lang === 'sk' ? [
  { q: 'Filip nám prerobil eshop a tržby vyskočili o 38 % za tri mesiace. Najmä vďaka rýchlosti a čistému checkoutu.', a: 'Zuzana K., Pekáreň Veverka' },
  { q: 'Komunikácia bola priama, deadliny dodržané, kód krásne čitateľný. Ďalší projekt už plánujeme.', a: 'Marek H., Tatra Apartmány' },
] : [
  { q: 'Filip rebuilt our shop and revenue jumped 38% in three months. Speed + clean checkout did it.', a: 'Zuzana K., Pekáreň Veverka' },
  { q: 'Direct comms, met every deadline, beautiful code. Already planning the next project.', a: 'Marek H., Tatra Apartmány' },
];
---
<section class="testimonials-section">
  <Blob color="var(--accent3)" size={300} position="bottom: 40px; left: 120px;" />
  <Reveal>
    <div class="testimonials-eyebrow mono">05 — {t('home.testimonialsEyebrow', lang)}</div>
  </Reveal>
  <div class="testimonials-grid">
    {testimonials.map((tst, i) => (
      <Reveal delay={i * 0.1}>
        <div class="testimonial">
          <p class="testimonial-quote display">„{tst.q}"</p>
          <div class="testimonial-author mono">— {tst.a}</div>
        </div>
      </Reveal>
    ))}
  </div>
</section>

<style>
  .testimonials-section {
    padding: 96px 56px;
    position: relative;
    /* Contain the decorative blob so it can't push body scrollWidth past
       the viewport. Also matches .home-hero / .proj-body convention. */
    overflow: hidden;
  }
  .testimonials-eyebrow {
    font-size: 13px;
    opacity: 0.6;
    margin-bottom: 24px;
    position: relative;
    font-family: var(--font-mono);
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    position: relative;
  }
  .testimonial {
    border-left: 2px solid var(--accent);
    padding-left: 24px;
  }
  .testimonial-quote {
    font-size: 26px;
    line-height: 1.3;
    font-style: italic;
    margin: 0;
    font-family: var(--font-display);
  }
  .testimonial-author {
    font-size: 12px;
    margin-top: 16px;
    opacity: 0.7;
    font-family: var(--font-mono);
  }
  @media (max-width: 1024px) {
    .testimonials-section { padding: 72px 32px; }
    .testimonials-grid { gap: 36px; }
    .testimonial-quote { font-size: 22px; }
  }
  @media (max-width: 768px) {
    .testimonials-section { padding: 56px 20px; }
    .testimonials-grid { grid-template-columns: 1fr; gap: 32px; }
    .testimonial-quote { font-size: 20px; }
  }
  @media (max-width: 480px) {
    .testimonials-section { padding: 48px 16px; }
    .testimonial-quote { font-size: 18px; }
  }
</style>
