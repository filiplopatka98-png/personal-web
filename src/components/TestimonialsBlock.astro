---
import Reveal from './Reveal.astro';
import Blob from './Blob.astro';
import { t, type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const testimonials = lang === 'sk' ? [
  { q: 'Filip nám spravil novú stránku a odvtedy sa nám cez ňu ozývajú noví zákazníci. Stihol to načas a keď potrebujem niečo zmeniť, stačí napísať a vybaví to.', a: 'Adam Kolarovič, majiteľ Profi House s.r.o.' },
  { q: 'Filip mi spravil web a naozaj mi cezeň chodí robota. Keď treba niečo upraviť, napíšem mu a hneď to vyrieši. Spoľahlivý chalan, odporúčam.', a: 'Ľubomír Krivošík, krivosik.sk' },
] : [
  { q: 'Filip built us a new website and now new customers reach out through it. He delivered on time, and whenever I need a change I just message him and he handles it.', a: 'Adam Kolarovič, owner of Profi House s.r.o.' },
  { q: 'Filip built my site and it genuinely brings me work. Whenever something needs tweaking I message him and he sorts it right away. Reliable guy — highly recommend.', a: 'Ľubomír Krivošík, krivosik.sk' },
];
---
<section class="testimonials-section">
  <Blob color="var(--accent3)" size={300} position="bottom: 40px; left: 120px;" />
  <Reveal>
    <div class="testimonials-eyebrow mono">05 — {t('home.testimonialsEyebrow', lang)}</div>
  </Reveal>
  <div class="testimonials-grid">
    {testimonials.map((tst, i) => (
      <Reveal delay={i * 0.1}>
        <div class="testimonial">
          <p class="testimonial-quote display">„{tst.q}"</p>
          <div class="testimonial-author mono">— {tst.a}</div>
        </div>
      </Reveal>
    ))}
  </div>
</section>

<style>
  .testimonials-section {
    padding: 96px 56px;
    position: relative;
    /* Contain the decorative blob so it can't push body scrollWidth past
       the viewport. Also matches .home-hero / .proj-body convention. */
    overflow: hidden;
  }
  .testimonials-eyebrow {
    font-size: 13px;
    opacity: 0.6;
    margin-bottom: 24px;
    position: relative;
    font-family: var(--font-mono);
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    position: relative;
  }
  .testimonial {
    border-left: 2px solid var(--accent);
    padding-left: 24px;
  }
  .testimonial-quote {
    font-size: 26px;
    line-height: 1.3;
    font-style: italic;
    margin: 0;
    font-family: var(--font-display);
  }
  .testimonial-author {
    font-size: 12px;
    margin-top: 16px;
    opacity: 0.7;
    font-family: var(--font-mono);
  }
  @media (max-width: 1024px) {
    .testimonials-section { padding: 72px 32px; }
    .testimonials-grid { gap: 36px; }
    .testimonial-quote { font-size: 22px; }
  }
  @media (max-width: 768px) {
    .testimonials-section { padding: 56px 20px; }
    .testimonials-grid { grid-template-columns: 1fr; gap: 32px; }
    .testimonial-quote { font-size: 20px; }
  }
  @media (max-width: 480px) {
    .testimonials-section { padding: 48px 16px; }
    .testimonial-quote { font-size: 18px; }
  }
</style>
