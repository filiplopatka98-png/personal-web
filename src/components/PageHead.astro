---
import Reveal from './Reveal.astro';
import Blob from './Blob.astro';

export interface Props {
  eyebrow: string;
  /** Title may contain raw HTML (em with accent color). Use set:html. */
  titleHtml: string;
  lead?: string;
  /** Decorative blob color (default var(--accent)). */
  blobColor?: string;
}
const { eyebrow, titleHtml, lead, blobColor = 'var(--accent)' } = Astro.props;
---
<div class="page-head">
  <Blob color={blobColor} size={280} position="top: -60px; right: 120px; opacity: 0.6;" />
  <Reveal>
    <div class="page-head-eyebrow mono">{eyebrow}</div>
    <h1 class="page-head-title display" set:html={titleHtml}></h1>
    {lead && <p class="page-head-lead">{lead}</p>}
  </Reveal>
</div>

<style>
  .page-head {
    padding: 80px 56px 60px;
    border-bottom: var(--border-soft);
    position: relative;
    overflow: hidden;
  }
  .page-head-eyebrow {
    font-size: 13px;
    opacity: 0.6;
    margin-bottom: 14px;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }
  .page-head-title {
    font-size: 108px;
    line-height: 0.92;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    max-width: 1100px;
    position: relative;
    z-index: 2;
  }
  .page-head-lead {
    font-size: 20px;
    line-height: 1.45;
    opacity: 0.75;
    max-width: 560px;
    margin: 32px 0 0;
    position: relative;
    z-index: 2;
  }
  .page-head-title :global(em) {
    color: var(--accent);
    font-style: italic;
  }
  @media (max-width: 768px) {
    .page-head { padding: 60px 20px 40px; }
    .page-head-title { font-size: 56px; }
    .page-head-lead { font-size: 16px; }
  }
</style>
