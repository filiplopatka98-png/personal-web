---
import Reveal from './Reveal.astro';

export interface Props {
  eyebrow: string;
  /** Title may contain raw HTML (em with accent color). Use set:html. */
  titleHtml: string;
  lead?: string;
}
const { eyebrow, titleHtml, lead } = Astro.props;
---
<div class="page-head-wrap">
  <div class="page-head glass">
    <Reveal>
      <div class="page-head-eyebrow mono">{eyebrow}</div>
      <h1 class="page-head-title display" set:html={titleHtml}></h1>
      {lead && <p class="page-head-lead">{lead}</p>}
    </Reveal>
  </div>
</div>

<style>
  .page-head-wrap {
    padding: 32px 24px 0;
  }
  .page-head {
    padding: 56px;
    border-radius: 32px;
    position: relative;
    overflow: hidden;
    max-width: 1320px;
    margin: 0 auto;
  }
  .page-head-eyebrow {
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 14px;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }
  .page-head-title {
    font-size: 108px;
    line-height: 0.92;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
    max-width: 1100px;
    color: var(--ink);
  }
  .page-head-lead {
    font-size: 20px;
    line-height: 1.45;
    color: var(--ink-soft);
    max-width: 560px;
    margin: 32px 0 0;
  }
  .page-head-title :global(em) {
    color: var(--accent);
    font-style: italic;
  }
  @media (max-width: 1024px) {
    .page-head { padding: 48px; }
    .page-head-title { font-size: 84px; }
  }
  @media (max-width: 768px) {
    .page-head-wrap { padding: 24px 16px 0; }
    .page-head { padding: 36px 28px; border-radius: 24px; }
    .page-head-title { font-size: 56px; }
    .page-head-lead { font-size: 16px; }
  }
</style>
