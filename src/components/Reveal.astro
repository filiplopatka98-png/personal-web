---
export interface Props {
  /** Animation delay in seconds (e.g. 0.1, 0.2 for stagger). */
  delay?: number;
  /** HTML tag to render (default 'div'). */
  as?: string;
  /** Extra classes to merge. */
  class?: string;
  /**
   * Above-the-fold / LCP content. Renders visible immediately and animates in
   * via a pure-CSS keyframe (no JS/IntersectionObserver gate), so the element
   * is painted on first paint and stays visible even if JS fails to run.
   * Use for the hero heading and any critical first-viewport content.
   */
  immediate?: boolean;
  /** Any other HTML attributes (data-*, aria-*, id, etc.) are forwarded to the rendered tag. */
  [key: string]: unknown;
}

const { delay = 0, as: Tag = 'div', class: className = '', immediate = false, ...rest } = Astro.props;
const delayStyle = delay > 0
  ? `${immediate ? 'animation-delay' : 'transition-delay'}:${delay}s;`
  : '';
---
{immediate ? (
  <Tag {...rest} class:list={['reveal', 'reveal-immediate', className]} style={delayStyle}>
    <slot />
  </Tag>
) : (
  <Tag {...rest} class:list={['reveal', className]} style={delayStyle} data-reveal>
    <slot />
  </Tag>
)}

<script>
  function initReveals() {
    const els = document.querySelectorAll<HTMLElement>('[data-reveal]:not(.visible)');
    if (!els.length) return;

    if (!('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -80px 0px' }
    );

    els.forEach((el) => io.observe(el));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReveals);
  } else {
    initReveals();
  }
  document.addEventListener('astro:page-load', initReveals);
</script>
