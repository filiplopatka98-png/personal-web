---
export interface Props {
  href: string;
  external?: boolean;
  class?: string;
}
const { href, external = false, class: className = '' } = Astro.props;

const base = 'inline-flex items-center gap-2 border border-text text-text font-sans font-medium text-base px-5 py-3 rounded no-underline hover:border-accent-hover hover:text-accent-hover transition-colors';
const targetAttr = external ? '_blank' : undefined;
const relAttr = external ? 'noopener noreferrer' : undefined;
---
<a href={href} class:list={[base, className]} target={targetAttr} rel={relAttr}>
  <slot />
</a>
