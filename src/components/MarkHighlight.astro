---
/**
 * Yellow highlight marker for emphasizing key words in body text.
 * Use sparingly — once or twice per paragraph at most.
 */
---
<mark class="bg-transparent text-text px-0.5" style="background: linear-gradient(180deg, transparent 60%, var(--color-accent) 60%, var(--color-accent) 92%, transparent 92%);">
  <slot />
</mark>
