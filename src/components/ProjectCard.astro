---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { type Lang } from '../i18n';

export interface Props {
  entry: CollectionEntry<'projects'>;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const { data } = entry;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const detailHref = lang === 'sk'
  ? `${baseUrl}/projekty/${entry.slug}/`
  : `${baseUrl}/en/projects/${entry.slug}/`;
---
<a href={detailHref} class="group block no-underline">
  <article class="rounded overflow-hidden border border-border hover:border-accent-hover transition-colors">
    <div class="aspect-[16/10] overflow-hidden bg-surface">
      <Image
        src={data.cover}
        alt={data.title}
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 600px"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
    <div class="p-5">
      <p class="font-mono text-xs uppercase tracking-wider text-text-muted mb-2">
        {data.year && <span>{data.year}</span>}
        {data.year && data.tags.length > 0 && <span class="mx-2">·</span>}
        {data.tags.slice(0, 2).join(' · ')}
      </p>
      <h3 class="font-serif font-medium mb-2 group-hover:text-accent-hover">
        {data.title}
      </h3>
      <p class="text-sm text-text-muted">{data.excerpt}</p>
    </div>
  </article>
</a>
