---
import type { CollectionEntry } from 'astro:content';
import { type Lang } from '../i18n';

export interface Props {
  entry: CollectionEntry<'projects'>;
  lang: Lang;
  /** "home" — smaller card with floating "case study" badge. "work" — full card with year-pill + 3 metrics row. */
  variant?: 'home' | 'work';
}
const { entry, lang, variant = 'home' } = Astro.props;
const { data } = entry;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
// entry.slug is "sk/veverka" or "en/veverka" — strip locale prefix
const cleanSlug = entry.slug.replace(/^(sk|en)\//, '');
const detailHref = lang === 'sk'
  ? `${baseUrl}/praca/${cleanSlug}/`
  : `${baseUrl}/en/work/${cleanSlug}/`;
const accentColor = `var(--${data.accent})`;
---
<a href={detailHref} class:list={['proj', 'glass', `is-${variant}`]} data-cursor="hover">
  <div class="proj-cover" style={`background:${accentColor}`}>
    <div class="proj-cover-label">/{cleanSlug}.png</div>
    {variant === 'home' && (
      <div class="proj-cover-badge glass-flat float-y">case<br/>study</div>
    )}
    {variant === 'work' && (
      <div class="proj-cover-pill glass-flat">↗ {data.year}</div>
    )}
  </div>
  <div class="proj-meta">
    <div>
      <div class="proj-name display">{data.name}</div>
      <div class="proj-kind mono">{data.kind}{variant === 'work' ? ` · ${data.role}` : ''}</div>
    </div>
    {variant === 'home' && (
      <div class="proj-year mono">{data.year}</div>
    )}
  </div>
  {variant === 'work' && data.metrics.length > 0 && (
    <div class="proj-metrics mono">
      {data.metrics.slice(0, 3).map((m) => (
        <div><span class="proj-metric-num display">{m.value}</span>{m.label}</div>
      ))}
    </div>
  )}
</a>

<style>
  .proj {
    display: block;
    text-decoration: none;
    color: var(--ink);
    padding: 18px;
    border-radius: 24px;
  }

  .proj-cover {
    aspect-ratio: 4 / 3;
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    background-image: repeating-linear-gradient(135deg, transparent 0 18px, rgba(255,255,255,0.18) 18px 19px);
  }

  .proj-cover-label {
    position: absolute;
    left: 16px;
    bottom: 14px;
    font-size: 11px;
    color: var(--ink);
    opacity: 0.85;
    font-family: var(--font-mono);
  }

  .proj-cover-badge {
    position: absolute;
    right: 18px;
    top: 18px;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    color: var(--ink);
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.2;
    text-align: center;
  }

  .proj-cover-pill {
    position: absolute;
    right: 18px;
    top: 18px;
    padding: 6px 12px;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .proj-meta {
    display: flex;
    justify-content: space-between;
    margin-top: 18px;
    gap: 16px;
    align-items: baseline;
  }

  .proj-name {
    font-size: 28px;
    line-height: 1.05;
    font-family: var(--font-display);
  }

  .proj.is-work {
    padding: 24px;
  }
  .proj.is-work .proj-meta {
    margin-top: 24px;
  }
  .proj.is-work .proj-name {
    font-size: 36px;
  }

  .proj-kind {
    font-size: 12px;
    color: var(--ink-soft);
    margin-top: 8px;
    font-family: var(--font-mono);
  }

  .proj-year {
    font-size: 12px;
    color: var(--ink-soft);
    font-family: var(--font-mono);
  }

  .proj-metrics {
    margin-top: 16px;
    display: flex;
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    flex-wrap: wrap;
  }

  .proj-metric-num {
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 18px;
    margin-right: 6px;
  }

  @media (max-width: 768px) {
    .proj.is-work .proj-name { font-size: 28px; }
    .proj-metrics { gap: 16px; }
  }
  @media (max-width: 480px) {
    .proj-name { font-size: 24px; }
    .proj.is-work .proj-name { font-size: 26px; }
  }
</style>
