---
import { t, type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const itemsRaw = t('ticker.items', lang);
const items = itemsRaw.split(',').map((s) => s.trim()).filter(Boolean);
---
<div class="marquee-wrap">
  {/* Decorative keyword ticker. Duplicated for a seamless loop and read twice
      by screen readers, so hide it from AT — the keywords are surfaced as real
      content elsewhere (services / hero). Motion pauses on hover and is fully
      stopped under prefers-reduced-motion (global.css). */}
  <div class="marquee-inner" aria-hidden="true">
    {Array.from({ length: 2 }).map(() => (
      <>
        {items.map((item) => (
          <>
            <span>{item}</span>
            <span class="marquee-sep">✦</span>
          </>
        ))}
      </>
    ))}
  </div>
</div>

<style>
  .marquee-wrap {
    border-top: var(--border-soft);
    border-bottom: var(--border-soft);
    padding: 18px 0;
    overflow: hidden;
    background: var(--bg2);
  }

  .marquee-inner {
    display: flex;
    gap: 48px;
    animation: scrollM var(--motion-marquee-duration) linear infinite;
    white-space: nowrap;
    font-family: var(--font-display);
    font-size: 42px;
    font-style: italic;
    color: var(--ink);
  }

  .marquee-sep {
    color: var(--accent);
  }

  /* WCAG 2.2.2 — let users stop the auto-scroll by hovering the ticker. */
  .marquee-wrap:hover .marquee-inner {
    animation-play-state: paused;
  }

  @media (max-width: 1024px) {
    .marquee-inner {
      font-size: 36px;
      gap: 36px;
    }
  }
  @media (max-width: 768px) {
    .marquee-inner {
      font-size: 28px;
      gap: 28px;
    }
  }
  @media (max-width: 480px) {
    .marquee-inner {
      font-size: 22px;
      gap: 22px;
    }
  }
</style>
