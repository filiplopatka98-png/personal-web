---
import { t, type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const itemsRaw = t('ticker.items', lang);
const items = itemsRaw.split(',').map((s) => s.trim()).filter(Boolean);
---
<div class="marquee-outer">
  <div class="marquee-wrap glass">
    <div class="marquee-inner">
      {Array.from({ length: 2 }).map(() => (
        <>
          {items.map((item) => (
            <>
              <span>{item}</span>
              <span class="marquee-sep">✦</span>
            </>
          ))}
        </>
      ))}
    </div>
  </div>
</div>

<style>
  .marquee-outer {
    padding: 0 24px;
  }

  .marquee-wrap {
    padding: 18px 0;
    overflow: hidden;
    border-radius: 28px;
    max-width: 1320px;
    margin: 0 auto;
  }

  .marquee-inner {
    display: flex;
    gap: 48px;
    animation: scrollM var(--motion-marquee-duration) linear infinite;
    white-space: nowrap;
    font-family: var(--font-display);
    font-size: 42px;
    font-style: italic;
    color: var(--ink);
  }

  .marquee-sep {
    color: var(--accent);
  }

  @media (max-width: 1024px) {
    .marquee-inner {
      font-size: 36px;
      gap: 36px;
    }
  }
  @media (max-width: 768px) {
    .marquee-outer { padding: 0 16px; }
    .marquee-wrap { border-radius: 22px; }
    .marquee-inner {
      font-size: 28px;
      gap: 28px;
    }
  }
  @media (max-width: 480px) {
    .marquee-inner {
      font-size: 22px;
      gap: 22px;
    }
  }
</style>
