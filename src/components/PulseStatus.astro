---
export interface Props {
  /** Status text shown next to pulse dot. */
  text: string;
  /** Status color: 'available' (green, default) or 'busy' (red). */
  status?: 'available' | 'busy';
  /** Extra classes to merge. */
  class?: string;
}
const { text, status = 'available', class: className = '' } = Astro.props;
const dotColor = status === 'available' ? 'var(--color-status-available)' : 'var(--color-status-busy)';
---
<div class:list={['flex items-center gap-2.5 font-mono text-xs uppercase tracking-widest text-text-muted', className]}>
  <span class="pulse-dot inline-block w-2 h-2 rounded-full" style={`background:${dotColor}`}></span>
  <span>{text}</span>
</div>
