---
import Reveal from './Reveal.astro';
import Plate from './Plate.astro';
import { type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---
<div class="hero-portrait-grid">
  <div>
    <Reveal as="h1" class="hero-title display">
      {lang === 'sk' ? (
        <Fragment>
          Web developer.<br/>
          <em class="hero-em">Rýchle</em> weby<br/>
          a&nbsp;eshopy pre<br/>
          malé firmy.
        </Fragment>
      ) : (
        <Fragment>
          Web developer.<br/>
          <em class="hero-em">Fast</em> sites<br/>
          and shops for<br/>
          small businesses.
        </Fragment>
      )}
    </Reveal>
  </div>
  <Reveal delay={0.15} class="hero-portrait-right">
    <Plate
      label="PORTRÉT — filip.jpg"
      color="var(--accent2)"
      ratio="4/5"
      caption="1200×1500 · grayscale"
    />
    <div class="hero-portrait-badge mono">
      ✱ Filip · BA, SK
    </div>
  </Reveal>
</div>

<style>
  .hero-portrait-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-title {
    font-size: calc(var(--text-hero) * 0.78);
    line-height: 0.94;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .hero-em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-portrait-right {
    position: relative;
  }

  .hero-portrait-badge {
    position: absolute;
    bottom: -18px;
    left: -18px;
    background: var(--bg);
    padding: 10px 16px;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, var(--ink) 33%, transparent);
    font-family: var(--font-mono);
    font-size: 12px;
    transform: rotate(-3deg);
  }

  @media (max-width: 768px) {
    .hero-portrait-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-title {
      font-size: 56px;
    }
  }
</style>
