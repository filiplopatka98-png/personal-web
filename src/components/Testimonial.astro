---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'testimonials'>;
}

const { entry } = Astro.props;
const { data } = entry;
---
<figure class="border-l-4 border-accent pl-6 py-2">
  <blockquote class="font-serif text-lg italic mb-4 leading-relaxed">
    &ldquo;{data.quote}&rdquo;
  </blockquote>
  <figcaption class="flex items-center gap-3">
    {data.photo && (
      <Image
        src={data.photo}
        alt={data.author}
        width={48}
        height={48}
        class="w-12 h-12 rounded-full object-cover"
      />
    )}
    <div>
      <p class="font-medium text-sm">{data.author}</p>
      <p class="font-mono text-xs uppercase tracking-wider text-text-muted">{data.role}</p>
    </div>
  </figcaption>
</figure>
