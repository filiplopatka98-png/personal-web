---
import Squiggle from './Squiggle.astro';
import Reveal from './Reveal.astro';
import { type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---
<Reveal as="h1" class="hero-title display">
  {lang === 'sk' ? (
    <Fragment>
      Budujem <em class="hero-em">rýchle</em>,<br/>
      prístupné weby<br/>
      a <span class="hero-squiggle-wrap">eshopy<Squiggle /></span> pre malé<br/>
      a stredné firmy.
    </Fragment>
  ) : (
    <Fragment>
      I build <em class="hero-em">fast</em>,<br/>
      accessible websites<br/>
      and <span class="hero-squiggle-wrap">shops<Squiggle /></span> for small<br/>
      and mid businesses.
    </Fragment>
  )}
</Reveal>

<style>
  /*
   * NOTE: All selectors here use :global() because <Reveal> renders the .hero-title
   * h1, and Astro does NOT propagate this component's data-astro-cid scope marker
   * to the Reveal-rendered element. Without :global(), these rules would compile
   * to attribute selectors that never match. See also Squiggle wrap styling.
   */
  :global(.hero-title) {
    font-size: var(--text-hero);
    line-height: 0.92;
    margin: 0;
    max-width: 1100px;
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  :global(.hero-em) {
    font-style: italic;
    color: var(--accent);
    padding-left: 0.08em;
    padding-right: 0.06em;
  }

  :global(.hero-squiggle-wrap) {
    position: relative;
    display: inline-block;
    padding-bottom: 0.22em;
  }

  /* Responsive hero title sizes per RESPONSIVE.md. */
  @media (max-width: 1024px) {
    :global(.hero-title) { font-size: 84px; line-height: 0.95; }
  }
  @media (max-width: 768px) {
    :global(.hero-title) { font-size: 56px; line-height: 0.96; }
  }
  @media (max-width: 480px) {
    :global(.hero-title) { font-size: 44px; }
  }
</style>
