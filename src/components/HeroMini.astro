---
import Reveal from './Reveal.astro';
import Plate from './Plate.astro';
import { type Lang } from '../i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const metrics = lang === 'sk' ? [
  { n: '+38%', l: 'tržby' },
  { n: '0.7s', l: 'LCP' },
  { n: '100', l: 'CWV' },
] : [
  { n: '+38%', l: 'revenue' },
  { n: '0.7s', l: 'LCP' },
  { n: '100', l: 'CWV' },
];
---
<div class="hero-mini-grid">
  <div>
    <div class="hero-mini-eyebrow mono">
      ★ {lang === 'sk' ? 'Posledný spustený projekt' : 'Latest launch'}
    </div>
    <Reveal as="h1" class="hero-title display">
      {lang === 'sk' ? (
        <Fragment>
          Eshop, ktorý<br/>
          <em class="hero-em">letí</em> na 0.7s LCP<br/>
          a&nbsp;rastie o&nbsp;38%.
        </Fragment>
      ) : (
        <Fragment>
          An e-shop that<br/>
          <em class="hero-em">flies</em> at 0.7s LCP<br/>
          and grew 38%.
        </Fragment>
      )}
    </Reveal>
    <p class="hero-mini-lead">
      {lang === 'sk' ? (
        <Fragment>
          Som <strong>Filip</strong> — staviam weby, ktoré merateľne pomôžu biznisu. WordPress, Next.js, React, dôraz na výkon a SEO.
        </Fragment>
      ) : (
        <Fragment>
          I'm <strong>Filip</strong> — I build sites that measurably help businesses. WordPress, Next.js, React, performance & SEO.
        </Fragment>
      )}
    </p>
  </div>

  <Reveal delay={0.1}>
    <div class="hero-mini-card glass">
      <div class="hero-mini-chrome">
        <span class="dot" style="background: var(--accent);"></span>
        <span class="dot" style="background: var(--accent2);"></span>
        <span class="dot" style="background: #999;"></span>
        <div class="glass-flat hero-mini-url mono">pekarenveverka.sk</div>
      </div>
      <Plate label="LIVE PREVIEW" color="var(--accent)" ratio="4/3" caption="screen-1 · production" />
      <div class="hero-mini-metrics">
        {metrics.map((m) => (
          <div class="glass-flat hero-mini-metric">
            <div class="hero-mini-metric-num">{m.n}</div>
            <div class="hero-mini-metric-label mono">{m.l}</div>
          </div>
        ))}
      </div>
    </div>
  </Reveal>
</div>

<style>
  .hero-mini-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 40px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-mini-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 14px;
  }

  .hero-title {
    font-size: calc(var(--text-hero) * 0.82);
    line-height: 0.92;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .hero-em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-mini-lead {
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 460px;
    margin-top: 24px;
  }

  .hero-mini-card {
    padding: 18px;
    border-radius: 22px;
    position: relative;
  }

  .hero-mini-chrome {
    display: flex;
    gap: 6px;
    margin-bottom: 12px;
    align-items: center;
  }

  .hero-mini-chrome .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    box-shadow: 0 0 6px currentColor;
  }

  .hero-mini-url {
    flex: 1;
    margin-left: 8px;
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    border-radius: 999px;
  }

  .hero-mini-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    margin-top: 14px;
  }

  .hero-mini-metric {
    padding: 12px 14px;
    border-radius: 14px;
  }

  .hero-mini-metric-num {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--accent);
  }

  .hero-mini-metric-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-soft);
    margin-top: 2px;
  }

  @media (max-width: 1024px) {
    .hero-title { font-size: 72px; line-height: 0.95; }
  }
  @media (max-width: 768px) {
    .hero-mini-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-title {
      font-size: 56px;
      line-height: 0.96;
    }
  }
  @media (max-width: 480px) {
    .hero-title { font-size: 44px; }
  }
</style>
