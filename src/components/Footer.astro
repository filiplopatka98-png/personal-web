---
import { t, type Lang } from '../i18n';
import { getStaticRoute } from '../i18n/routes';
import Reveal from './Reveal.astro';
import { WEB3FORMS_ACCESS_KEY } from '../config';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const briefHref = `${baseUrl}${getStaticRoute('brief', lang)}`;
const privacyHref = `${baseUrl}${getStaticRoute('privacy', lang)}`;
const imprintHref = `${baseUrl}${getStaticRoute('imprint', lang)}`;

// Title with line break — handoff style: split on first space
const titleStr = t('footer.title', lang);
const spaceIdx = titleStr.indexOf(' ');
const titleFirst = spaceIdx > 0 ? titleStr.slice(0, spaceIdx) : titleStr;
const titleRest = spaceIdx > 0 ? titleStr.slice(spaceIdx + 1) : '';

const CONTACT_EMAIL = t('menu.email', lang);
---
<footer class="cd-footer">
  <div class="rotating-text" aria-hidden="true">
    <svg viewBox="0 0 200 200">
      <defs>
        <path id="footerCircle" d="M 100,100 m -75,0 a 75,75 0 1,1 150,0 a 75,75 0 1,1 -150,0" />
      </defs>
      <text fill="var(--accent)" font-family="var(--font-mono)" font-size="11" letter-spacing="2">
        <textPath href="#footerCircle">{t('footer.rotating', lang)}</textPath>
      </text>
    </svg>
  </div>

  <div class="footer-grid">
    <Reveal>
      <div class="footer-eyebrow">{t('footer.eyebrow', lang)}</div>
      <h2 class="footer-title display">
        {titleFirst}{titleRest && <><br/>{titleRest}</>}
      </h2>
      <p class="footer-lead">{t('footer.lead', lang)}</p>
      <div class="footer-links">
        <a data-cursor="hover" href={`mailto:${t('menu.email', lang)}`}>{t('menu.email', lang)} →</a>
        <a data-cursor="hover" href={t('menu.whatsappHref', lang)} target="_blank" rel="noopener noreferrer">WhatsApp {t('menu.whatsapp', lang)} →</a>
        <a data-cursor="hover" href={`https://${t('menu.linkedin', lang)}`} target="_blank" rel="noopener noreferrer">LinkedIn →</a>
        <a data-cursor="hover" href={`https://${t('menu.facebook', lang)}`} target="_blank" rel="noopener noreferrer">Facebook →</a>
        <a data-cursor="hover" href={`https://${t('menu.instagram', lang)}`} target="_blank" rel="noopener noreferrer">Instagram →</a>
      </div>
      <div class="footer-cta">
        <a href={briefHref} data-cursor="hover" class="footer-brief-btn">
          {t('footer.briefStart', lang)}
        </a>
      </div>
    </Reveal>

    <Reveal delay={0.1} class="footer-form-wrap">
      <form
        class="footer-form"
        data-contact-form
        data-contact-email={CONTACT_EMAIL}
        data-w3f-key={WEB3FORMS_ACCESS_KEY}
        data-subject={t('footer.formSubject', lang)}
        data-sending={t('footer.formSending', lang)}
        data-success={t('footer.formSuccess', lang)}
        data-error={t('footer.formError', lang)}
        novalidate
      >
        <!-- Web3Forms honeypot: real users leave this empty; bots that fill it get rejected. -->
        <input type="checkbox" name="botcheck" class="footer-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="form-field">
          <label for="footer-form-name">{t('footer.formName', lang)}</label>
          <input type="text" name="name" id="footer-form-name" required autocomplete="name" />
        </div>
        <div class="form-field">
          <label for="footer-form-email">{t('footer.formEmail', lang)}</label>
          <input type="email" name="email" id="footer-form-email" required autocomplete="email" />
        </div>
        <div class="form-field">
          <label for="footer-form-message">{t('footer.formDesc', lang)}</label>
          <textarea name="message" id="footer-form-message" rows="4" required></textarea>
        </div>
        <button type="submit" data-cursor="hover" class="footer-submit">
          {t('footer.formSend', lang)}
        </button>
        <p class="footer-form-status" data-status role="alert" hidden></p>
      </form>
    </Reveal>
  </div>

  <div class="footer-bottom">
    <div>{t('footer.copy', lang)}</div>
    <nav class="footer-legal" aria-label={lang === 'sk' ? 'Právne informácie' : 'Legal'}>
      <a data-cursor="hover" href={privacyHref}>{t('legal.privacy.nav', lang)}</a>
      <span aria-hidden="true">·</span>
      <a data-cursor="hover" href={imprintHref}>{t('legal.imprint.nav', lang)}</a>
    </nav>
    <div>{t('footer.made', lang)}</div>
  </div>
</footer>

<style>
  .cd-footer {
    padding: 80px 56px;
    background: var(--ink);
    color: var(--bg);
    position: relative;
    overflow: hidden;
  }

  .rotating-text {
    position: absolute;
    right: -80px;
    top: -80px;
    width: 380px;
    height: 380px;
    animation: rotate-cd var(--motion-rotate-duration) linear infinite;
    pointer-events: none;
  }

  .rotating-text svg {
    width: 100%;
    height: 100%;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    position: relative;
  }

  .footer-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.65;
    margin-bottom: 8px;
  }

  .footer-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 10vw, 96px);
    line-height: 0.9;
    margin: 0 0 32px;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .footer-lead {
    font-size: 18px;
    opacity: 0.7;
    max-width: 440px;
    line-height: 1.5;
    margin: 0;
  }

  .footer-links {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 14px;
  }

  .footer-links a {
    color: var(--bg);
    text-decoration: none;
  }

  .footer-cta {
    margin-top: 24px;
  }

  .footer-brief-btn {
    background: var(--accent);
    color: var(--ink);
    border: 0;
    padding: 14px 22px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    display: inline-block;
  }

  .footer-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-field label {
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--bg) 55%, transparent);
    color: var(--bg);
    padding: 8px 0;
    font-family: var(--font-body);
    font-size: 16px;
    margin-top: 6px;
  }

  .form-field textarea {
    resize: none;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-bottom-color: var(--accent);
  }

  .footer-submit {
    margin-top: 16px;
    background: var(--accent);
    color: var(--ink);
    border: 0;
    padding: 16px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    cursor: pointer;
  }
  .footer-submit:disabled {
    opacity: 0.6;
    cursor: default;
  }

  /* Honeypot — hidden from users and AT, kept in the DOM to catch bots. */
  .footer-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  /* Submit status — success/error feedback after the Web3Forms POST. */
  .footer-form-status {
    margin: 4px 0 0;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
  }
  .footer-form-status.is-error {
    color: var(--accent);
  }
  /* On success, collapse the fields and show only the thank-you status. */
  .footer-form.is-sent .form-field,
  .footer-form.is-sent .footer-submit {
    display: none;
  }
  .footer-form.is-sent .footer-form-status {
    font-size: 16px;
    opacity: 0.9;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 80px;
    padding-top: 24px;
    border-top: 1px solid color-mix(in srgb, var(--bg) 22%, transparent);
    font-family: var(--font-mono);
    font-size: 12px;
    opacity: 0.65;
    position: relative;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-legal {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer-legal a {
    color: var(--bg);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .footer-legal a:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .footer-legal span {
    opacity: 0.65;
  }

  /* Tablet — dial 280×280 / -60px, padding tightens. */
  @media (max-width: 1024px) {
    .cd-footer {
      padding: 64px 32px;
    }
    .rotating-text {
      width: 280px;
      height: 280px;
      right: -60px;
      top: -60px;
    }
    .footer-title {
      font-size: 80px;
    }
  }

  /* Mobile — 1-col grid, dial 200×200 with -80px offset and 0.5 opacity. */
  @media (max-width: 768px) {
    .cd-footer {
      padding: 56px 20px;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .rotating-text {
      width: 200px;
      height: 200px;
      right: -80px;
      top: -80px;
      opacity: 0.65;
    }
    .footer-title {
      font-size: 56px !important;
    }
  }

  /* Small phone — even tighter padding. */
  @media (max-width: 480px) {
    .cd-footer {
      padding: 48px 16px;
    }
    .footer-title {
      font-size: 44px !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rotating-text {
      animation: none;
    }
  }
</style>

<script>
  function initFooterContact() {
    const forms = document.querySelectorAll<HTMLFormElement>('form[data-contact-form]');
    forms.forEach((form) => {
      if ((form as any).__contactInit) return;
      (form as any).__contactInit = true;

      const submitBtn = form.querySelector<HTMLButtonElement>('.footer-submit');
      const statusEl = form.querySelector<HTMLElement>('[data-status]');
      const email = form.getAttribute('data-contact-email') || '';

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }

        const data = new FormData(form);
        const val = (k: string) => (data.get(k) ?? '').toString().trim();
        const subjectPrefix = form.dataset.subject || 'Message from lopatka.sk';
        const payload = {
          access_key: form.dataset.w3fKey || '',
          subject: `${subjectPrefix} — ${val('name') || val('email') || 'kontakt'}`,
          from_name: val('name') || 'lopatka.sk',
          replyto: val('email'),
          botcheck: (data.get('botcheck') ?? '').toString(),
          Meno: val('name'),
          Email: val('email'),
          Sprava: val('message'),
        };

        if (statusEl) { statusEl.hidden = true; statusEl.textContent = ''; statusEl.classList.remove('is-error'); }
        let originalLabel = '';
        if (submitBtn) {
          originalLabel = submitBtn.textContent ?? '';
          submitBtn.disabled = true;
          submitBtn.textContent = form.dataset.sending || 'Odosielam…';
        }

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(payload),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || !json.success) throw new Error(json.message || 'submit failed');
          form.reset();
          form.classList.add('is-sent');
          if (statusEl) {
            statusEl.textContent = form.dataset.success || 'Ďakujem!';
            statusEl.hidden = false;
          }
        } catch {
          if (statusEl) {
            const tmpl = form.dataset.error || 'Nepodarilo sa odoslať. Skús to znova.';
            statusEl.textContent = tmpl.replace('{email}', email);
            statusEl.classList.add('is-error');
            statusEl.hidden = false;
          }
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalLabel;
          }
        }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooterContact);
  } else {
    initFooterContact();
  }
  document.addEventListener('astro:page-load', initFooterContact);
</script>
