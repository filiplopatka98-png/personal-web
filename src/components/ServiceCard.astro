---
import type { CollectionEntry } from 'astro:content';
import { t, type Lang } from '../i18n';
import { getStaticRoute } from '../i18n/routes';

export interface Props {
  entry: CollectionEntry<'services'>;
  lang: Lang;
  /** 1-based index for the "0X · duration" eyebrow line. */
  index: number;
}
const { entry, lang, index } = Astro.props;
const { data } = entry;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const briefHref = `${baseUrl}${getStaticRoute('brief', lang)}`;
const num = String(index).padStart(2, '0');
---
<article class:list={['service-card', 'glass', data.featured && 'glass-tint', data.featured && 'is-featured']}>
  {data.featured && (
    <div class="service-popular mono">{t('services.popular', lang)}</div>
  )}
  <div class="service-eyebrow mono">{num} · {data.duration}</div>
  <h3 class="service-name display">{data.name}</h3>
  <div class="service-price display">{data.price}</div>
  <p class="service-tagline">{data.tagline}</p>
  <p class="service-desc">{data.desc}</p>

  <div class="service-includes-block">
    <div class="service-section-label mono">{t('services.includes', lang)}</div>
    <ul class="service-includes">
      {data.includes.map((item) => (
        <li><span class="service-check" aria-hidden="true">✓</span>{item}</li>
      ))}
    </ul>
  </div>

  {data.notFor && (
    <div class="service-notfor">
      <strong class="mono">{t('services.notFor', lang)}:</strong> {data.notFor}
    </div>
  )}

  <a href={briefHref} class="service-cta mono" data-cursor="hover">
    {t('services.requestQuote', lang)} →
  </a>
</article>

<style>
  .service-card {
    padding: 36px 32px;
    border-radius: 28px;
    color: var(--ink);
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .service-card.is-featured {
    color: var(--ink-on-accent);
  }

  .service-popular {
    position: absolute;
    top: -12px;
    right: 24px;
    background: rgba(255, 255, 255, 0.95);
    color: var(--ink-on-accent);
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 1);
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    z-index: 2;
  }

  .service-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    opacity: 0.75;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .service-name {
    font-size: 48px;
    line-height: 1;
    letter-spacing: -0.02em;
    font-family: var(--font-display);
    font-weight: 400;
    margin: 12px 0 8px;
  }

  .service-price {
    font-family: var(--font-display);
    font-size: 24px;
    font-style: italic;
    color: var(--accent);
  }
  .service-card.is-featured .service-price {
    color: var(--ink-on-accent);
  }

  .service-tagline {
    font-size: 15px;
    line-height: 1.5;
    opacity: 0.9;
    margin: 16px 0 0;
  }

  .service-desc {
    font-size: 14px;
    line-height: 1.5;
    opacity: 0.78;
    margin: 8px 0 0;
  }

  .service-includes-block {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px dashed var(--divider);
  }
  .service-card.is-featured .service-includes-block {
    border-top-color: rgba(26, 20, 16, 0.25);
  }

  .service-section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.75;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }

  .service-includes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .service-includes li {
    display: flex;
    gap: 10px;
    font-size: 14px;
    line-height: 1.4;
  }
  .service-check {
    color: var(--accent);
    flex-shrink: 0;
  }
  .service-card.is-featured .service-check {
    color: var(--ink-on-accent);
  }

  .service-notfor {
    margin-top: 20px;
    font-size: 12px;
    opacity: 0.75;
  }
  .service-notfor strong {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  /* Per-card CTA: unfeatured = accent-tinted glass on neutral parent;
     featured = light glass on tinted parent. Per COMPONENTS_DELTA.md. */
  .service-cta {
    display: inline-block;
    margin-top: 24px;
    align-self: flex-start;
    padding: 12px 22px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    transition: opacity 0.15s ease;
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--accent) 78%, white) 0%,
      color-mix(in oklab, var(--accent) 92%, transparent) 100%);
    border: 1px solid color-mix(in oklab, var(--accent) 60%, white 40%);
    color: var(--ink-on-accent);
    box-shadow:
      0 18px 36px -14px color-mix(in oklab, var(--accent) 70%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  .service-card.is-featured .service-cta {
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(255, 255, 255, 0.6);
    color: var(--ink-on-accent);
    box-shadow:
      0 8px 20px -8px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }
  .service-cta:hover { opacity: 0.88; }

  @media (max-width: 768px) {
    .service-card { padding: 28px 22px; }
    .service-name { font-size: 38px; }
    .service-price { font-size: 22px; }
  }
  @media (max-width: 480px) {
    .service-name { font-size: 32px; }
    .service-price { font-size: 20px; }
  }
</style>
