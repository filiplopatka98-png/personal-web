---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'services'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

// Simple icon mapping — extend as services grow
const iconMap: Record<string, string> = {
  wordpress: '◆',
  frontend: '◊',
  ai: '✦',
  audit: '○',
};
const iconChar = iconMap[data.icon] ?? '·';
---
<article class="border border-border rounded p-6 hover:border-accent-hover transition-colors">
  <div class="text-2xl text-accent-hover mb-3" aria-hidden="true">{iconChar}</div>
  <h3 class="font-serif font-medium mb-3">{data.title}</h3>
  <div class="text-sm text-text-muted">
    <Content />
  </div>
  {data.priceFrom && (
    <p class="font-mono text-xs uppercase tracking-wider text-text mt-4">
      {data.priceFrom}
    </p>
  )}
</article>
