---
import { t, type Lang } from '../i18n';
import { getStaticRoute, type StaticRouteKey } from '../i18n/routes';
import LangSwitch from './LangSwitch.astro';

export interface Props {
  lang: Lang;
  altLangUrl?: string;
}

const { lang, altLangUrl } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const navOrder: { key: StaticRouteKey; tKey: 'nav.work' | 'nav.services' | 'nav.blog' | 'nav.brief' }[] = [
  { key: 'work',     tKey: 'nav.work' },
  { key: 'services', tKey: 'nav.services' },
  { key: 'blog',     tKey: 'nav.blog' },
  { key: 'brief',    tKey: 'nav.brief' },
];
---
<details class="mobile-menu md:hidden">
  <summary
    class="list-none cursor-pointer p-2 -mr-2"
    aria-label={t('nav.openMenu', lang)}
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M3 6h18M3 12h18M3 18h18" class="menu-icon-open" />
      <path d="M18 6L6 18M6 6l12 12" class="menu-icon-close" />
    </svg>
  </summary>
  <nav aria-label="Mobile" class="absolute right-0 top-full mt-2 bg-surface border border-border rounded p-4 flex flex-col gap-3 shadow-lg z-50 min-w-[200px]">
    {navOrder.map((item) => (
      <a
        href={`${baseUrl}${getStaticRoute(item.key, lang)}`}
        class="text-xs uppercase tracking-wider hover:text-accent-hover no-underline"
      >
        {t(item.tKey, lang)}
      </a>
    ))}
    <div class="border-t border-border pt-3 mt-1">
      <LangSwitch currentLang={lang} altLangUrl={altLangUrl} />
    </div>
  </nav>
</details>

<style>
  /* Reset default disclosure marker */
  .mobile-menu summary::-webkit-details-marker { display: none; }
  .mobile-menu summary::marker { content: ''; }

  /* Toggle icons via :open state */
  .mobile-menu .menu-icon-close { display: none; }
  .mobile-menu[open] .menu-icon-open { display: none; }
  .mobile-menu[open] .menu-icon-close { display: inline; }

  .mobile-menu { position: relative; }
</style>
