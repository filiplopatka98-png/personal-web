---
import { t, type Lang } from '../i18n';
import AvailabilityPill from './AvailabilityPill.astro';
import NowPlaying from './NowPlaying.astro';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = lang === 'sk' ? `${baseUrl}/` : `${baseUrl}/en/`;
---
<div class="nav-wrapper">
  <nav class="glass nav-pill" aria-label="Primary">
    <a href={homeHref} class="nav-logo" aria-label="Filip Lopatka — homepage">
      <div class="nav-logo-box">fl</div>
      <span class="nav-logo-text">filip lopatka</span>
    </a>

    <div class="nav-now">
      <NowPlaying lang={lang} />
    </div>

    <div class="nav-right">
      <div class="nav-pill-availability">
        <AvailabilityPill lang={lang} />
      </div>
      <button
        type="button"
        data-cursor="hover"
        data-menu-open
        aria-label={t('nav.openMenu', lang)}
        class="glass glass-tint nav-menu-btn"
      >
        <span class="nav-menu-bars" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
        {t('nav.menu', lang)}
      </button>
    </div>
  </nav>
</div>

<style>
  .nav-wrapper {
    position: sticky;
    top: 18px;
    z-index: 50;
    padding: 0 24px;
    display: flex;
    justify-content: center;
    pointer-events: none;
  }

  .nav-pill {
    pointer-events: auto;
    width: 100%;
    max-width: 1320px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px 12px 22px;
    border-radius: 999px;
    gap: 16px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
  }

  .nav-logo-box {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, var(--accent), color-mix(in oklab, var(--accent) 60%, white));
    border-radius: 8px;
    display: grid;
    place-items: center;
    color: var(--ink-on-accent);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
  }

  .nav-logo-text {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.02em;
  }

  .nav-now {
    display: flex;
    align-items: center;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-menu-btn {
    border: 0;
    padding: 10px 18px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    color: var(--ink-on-accent);
  }

  .nav-menu-bars {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
  }

  .nav-menu-bars span {
    width: 14px;
    height: 1.5px;
    background: var(--ink-on-accent);
  }

  @media (max-width: 1024px) {
    .nav-wrapper { top: 14px; padding: 0 16px; }
    .nav-now { display: none; }
  }

  @media (max-width: 768px) {
    .nav-wrapper { top: 10px; padding: 0 12px; }
    .nav-pill { padding: 8px 10px 8px 16px; }
    .nav-now, .nav-pill-availability { display: none; }
    .nav-menu-btn {
      padding: 10px 14px;
      font-size: 0;
      gap: 0;
    }
    .nav-menu-bars {
      gap: 4px;
    }
    .nav-menu-bars span {
      width: 18px;
    }
  }
</style>
