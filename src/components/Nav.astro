---
import { t, type Lang } from '../i18n';
import AvailabilityPill from './AvailabilityPill.astro';
import NowPlaying from './NowPlaying.astro';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = lang === 'sk' ? `${baseUrl}/` : `${baseUrl}/en/`;
---
<nav
  class="nav-bar"
  aria-label="Primary"
>
  <a href={homeHref} class="nav-logo">
    <div class="nav-logo-box">fl</div>
    <span class="nav-logo-text">filip lopatka</span>
  </a>

  <div class="nav-now">
    <NowPlaying lang={lang} />
  </div>

  <div class="nav-right">
    <div class="nav-pill">
      <AvailabilityPill lang={lang} />
    </div>
    <button
      type="button"
      data-cursor="hover"
      data-menu-open
      aria-label={t('nav.openMenu', lang)}
      class="nav-menu-btn"
    >
      <span class="nav-menu-bars" aria-hidden="true">
        <span></span>
        <span></span>
      </span>
      {t('nav.menu', lang)}
    </button>
  </div>
</nav>

<style>
  .nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 56px;
    border-bottom: var(--border-soft);
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 50;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
  }

  .nav-logo-box {
    width: 28px;
    height: 28px;
    background: var(--ink);
    border-radius: 8px;
    display: grid;
    place-items: center;
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
  }

  .nav-logo-text {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.02em;
  }

  .nav-now {
    display: flex;
    align-items: center;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-menu-btn {
    background: var(--ink);
    color: var(--bg);
    border: 0;
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }

  .nav-menu-bars {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
  }

  .nav-menu-bars span {
    width: 14px;
    height: 1.5px;
    background: var(--bg);
  }

  /* Tablet: hide the noisy "TERAZ pracujem na…" indicator; keep status pill. */
  @media (max-width: 1024px) {
    .nav-bar {
      padding: 18px 32px;
    }
    .nav-now {
      display: none;
    }
  }

  /* Mobile: hide both .nav-now and .nav-pill, drop "Menu" text label. */
  @media (max-width: 768px) {
    .nav-bar {
      padding: 14px 20px;
      flex-wrap: wrap;
      gap: 12px;
    }
    .nav-now,
    .nav-pill {
      display: none;
    }
    /* Drop the "Menu" word — keep only the icon — saves precious horizontal space. */
    .nav-menu-btn {
      padding: 10px 14px;
      font-size: 0;
      gap: 0;
    }
    .nav-menu-bars {
      gap: 4px;
    }
    .nav-menu-bars span {
      width: 18px;
    }
  }
</style>
