---
/**
 * Plate — placeholder visual block for project screenshots.
 *
 * Two modes:
 * 1. **CSS placeholder** (default): coloured box with diagonal stripes,
 *    file-name label top-left, optional caption bottom-left. Used when a
 *    real screenshot/mockup hasn't been generated for the project yet.
 * 2. **Real image** (when `imageSrc` provided): renders the image with
 *    no extra framing — assumes the image already has its own frame
 *    (e.g. a laptop mockup PNG from `npm run shots`). Caption shown
 *    below as a small mono line.
 */
export interface Props {
  /** File-name label shown top-left in placeholder mode, e.g. "veverka-hero.png". */
  label: string;
  /** Background tint — CSS color, defaults to var(--ink-soft). */
  color?: string;
  /** Aspect ratio, e.g. "4/3" (default), "4/5", "16/9". Ignored when `imageSrc` is set. */
  ratio?: string;
  /** Optional caption shown bottom-left (placeholder) / below (image). */
  caption?: string;
  /** Border radius in px (default 14). Used only in placeholder mode. */
  radius?: number;
  /** Extra classes to merge. */
  class?: string;
  /** When provided, render this image instead of the CSS placeholder. */
  imageSrc?: string;
  /** Alt text for the image. Falls back to `label` when omitted. */
  imageAlt?: string;
}

const {
  label,
  color = 'var(--ink-soft)',
  ratio = '4/3',
  caption,
  radius = 14,
  class: className = '',
  imageSrc,
  imageAlt,
} = Astro.props;

const styleStr = `aspect-ratio:${ratio};background:repeating-linear-gradient(135deg, transparent 0 20px, rgba(255,255,255,0.18) 20px 21px), linear-gradient(135deg, color-mix(in oklab, ${color} 80%, transparent) 0%, color-mix(in oklab, ${color} 40%, transparent) 100%), linear-gradient(135deg, rgba(255,255,255,0.55) 0%, rgba(255,255,255,0.18) 100%);border-radius:${radius}px;`;
---
{imageSrc ? (
  <figure class:list={['plate-image-wrap', className]}>
    <img
      src={imageSrc}
      alt={imageAlt ?? label}
      class="plate-image"
      loading="lazy"
      decoding="async"
    />
    {caption && (
      <figcaption class="plate-image-caption mono">{caption}</figcaption>
    )}
  </figure>
) : (
  <div class:list={['glass plate-placeholder', className]} style={`aspect-ratio:${ratio};border-radius:${radius}px;`} aria-hidden="true">
    <div class="plate-fill" style={styleStr}></div>
    <div class="plate-label mono">▢ {label}</div>
    {caption && (
      <div class="plate-caption mono">{caption}</div>
    )}
  </div>
)}

<style>
  .plate-placeholder {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .plate-fill {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 1;
  }
  .plate-label {
    position: absolute;
    top: 14px;
    left: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink);
    opacity: 0.85;
    z-index: 2;
  }
  .plate-caption {
    position: absolute;
    bottom: 14px;
    left: 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink);
    opacity: 0.7;
    z-index: 2;
  }
  .plate-image-wrap {
    margin: 0;
    display: block;
  }
  .plate-image {
    display: block;
    width: 100%;
    height: auto;
  }
  .plate-image-caption {
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }
</style>
