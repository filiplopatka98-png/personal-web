---
/**
 * Plate — placeholder visual block for project screenshots.
 *
 * Two modes:
 * 1. **CSS placeholder** (default): coloured box with diagonal stripes,
 *    file-name label top-left, optional caption bottom-left. Used when a
 *    real screenshot/mockup hasn't been generated for the project yet.
 * 2. **Real image** (when `imageSrc` provided): renders the image with
 *    no extra framing — assumes the image already has its own frame
 *    (e.g. a laptop mockup PNG from `npm run shots`). Caption shown
 *    below as a small mono line.
 */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  /** File-name label shown top-left in placeholder mode, e.g. "veverka-hero.png". */
  label: string;
  /** Background tint — CSS color, defaults to var(--bg2). */
  color?: string;
  /** Aspect ratio, e.g. "4/3" (default), "4/5", "16/9". Ignored when `image` is set. */
  ratio?: string;
  /** Optional caption shown bottom-left (placeholder) / below (image). */
  caption?: string;
  /** Border radius in px (default 14). Used only in placeholder mode. */
  radius?: number;
  /** Extra classes to merge. */
  class?: string;
  /** When provided, render this optimized image instead of the CSS placeholder. */
  image?: ImageMetadata;
  /** Alt text for the image. Falls back to `label` when omitted. */
  imageAlt?: string;
  /** Responsive `sizes` hint — how wide the image renders across breakpoints. */
  sizes?: string;
}

const {
  label,
  color = 'var(--bg2)',
  ratio = '4/3',
  caption,
  radius = 14,
  class: className = '',
  image,
  imageAlt,
  sizes = '(max-width: 1024px) 100vw, 1000px',
} = Astro.props;

const styleStr = `aspect-ratio:${ratio};background:${color};background-image:repeating-linear-gradient(135deg, transparent 0 18px, color-mix(in srgb, var(--ink) 8%, transparent) 18px 19px);border-radius:${radius}px;`;

// Responsive widths capped to the source width. Includes hi-DPI sizes up to
// ~2560px so laptop-mockup screenshots stay crisp on retina/2x displays
// (a ~1100px plate needs ~2200px on a 2x screen).
const widthPool = [400, 640, 960, 1280, 1760, 2200, 2560];
const widths = image
  ? (() => {
      const w = widthPool.filter((x) => x <= image.width);
      return w.length ? w : [image.width];
    })()
  : [];
---
{image ? (
  <figure class:list={['plate-image-wrap', className]}>
    <Picture
      src={image}
      alt={imageAlt ?? label}
      widths={widths}
      sizes={sizes}
      formats={['avif', 'webp']}
      fallbackFormat="webp"
      class="plate-image"
      loading="lazy"
      decoding="async"
    />
    {caption && (
      <figcaption class="plate-image-caption mono">{caption}</figcaption>
    )}
  </figure>
) : (
  <div class:list={['relative w-full overflow-hidden', className]} style={styleStr} aria-hidden="true">
    <div class="absolute top-3.5 left-4 font-mono text-[12px] opacity-70" style="color: var(--ink);">▢ {label}</div>
    {caption && (
      <div class="absolute bottom-3.5 left-4 font-mono text-[12px] opacity-60" style="color: var(--ink);">{caption}</div>
    )}
  </div>
)}

<style>
  .plate-image-wrap {
    margin: 0;
    display: block;
  }
  .plate-image {
    display: block;
    width: 100%;
    height: auto;
    /* Mockup PNGs from `npm run shots` are pre-shadowed; no extra effect needed. */
  }
  .plate-image-caption {
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }
</style>
